# ── App ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# CORS origin for the Next.js frontend (Vercel URL in prod, localhost in dev)
FRONTEND_ORIGIN=http://localhost:3001

# IANA timezone for calendar-day logic (leave dates, attendance check-in day)
TIMEZONE=Asia/Kolkata

# ── Database ────────────────────────────────────────────────────────
# Local dev (docker-compose Postgres). On Railway this is injected automatically.
DATABASE_URL=postgresql://peoplehub:peoplehub@localhost:5432/peoplehub?schema=public

# ── Auth / JWT ──────────────────────────────────────────────────────
# Use long random strings in production (e.g. `openssl rand -hex 32`).
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_TTL=900s
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_TTL=7d

# Name of the HTTP-only refresh cookie
REFRESH_COOKIE_NAME=peoplehub_rt

# Base64-encoded 32-byte key for AES-256-GCM encryption of PII columns
# (PAN, PF/ESIC numbers, bank account numbers). Generate with:
# openssl rand -base64 32
ENCRYPTION_KEY=change-me-base64-32-byte-key

# ── Seed admin (used by prisma/seed.ts) ─────────────────────────────
SEED_ADMIN_EMAIL=nithin.gangadhar@phaze-dynamics.com
SEED_ADMIN_PASSWORD=ChangeMe123!

# ── Vault file storage (Cloudflare R2, S3-compatible) ───────────────
# Optional locally: the app boots without these, but Vault file
# upload/download will error until all of R2_ENDPOINT/R2_ACCESS_KEY_ID/
# R2_SECRET_ACCESS_KEY/R2_BUCKET are set. Endpoint is the R2 S3 API URL,
# e.g. https://<accountid>.r2.cloudflarestorage.com
R2_ENDPOINT=
R2_REGION=auto
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Presigned upload/download URL lifetime, seconds (short-lived by design).
R2_PRESIGN_TTL_SECONDS=300

# ── Vault preview conversion (Gotenberg — separate Railway service) ──
# Base URL of the Gotenberg service that converts Office docs → PDF.
# Optional: without it, PDF/image previews still work; Office-doc
# conversions fail gracefully (previewStatus → FAILED).
GOTENBERG_URL=
GOTENBERG_TIMEOUT_MS=60000
