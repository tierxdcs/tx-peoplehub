// Prisma schema for tx-peoplehub ERP foundation.
// Single-company (no tenant scoping). Add ERP domain models as new modules.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// RBAC role. SUPER_ADMIN manages ADMIN accounts; ADMIN manages employee
/// identity/access only (no operational data visibility); MANAGER sees their
/// own vertical plus their downstream reports; EMPLOYEE sees only their own.
enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  EMPLOYEE
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

/// Login/system-access lifecycle, independent of the employment `status`
/// soft-delete above. PENDING_ACCESS employees exist as HR records but
/// cannot authenticate.
enum AccessStatus {
  PENDING_ACCESS
  ACTIVE
  INACTIVE
}

enum EmploymentType {
  FULL_TIME_PERMANENT
  CONTRACT
  INTERN
  PART_TIME
}

/// Fixed set of signature-style fonts for the internal e-signature display
/// layer. Kept in sync with the frontend's loaded Google Fonts.
enum SignatureFont {
  DANCING_SCRIPT
  CAVEAT
  PACIFICO
  GREAT_VIBES
}

enum LeaveAccrualType {
  FIXED_ANNUAL
  MONTHLY_ACCRUAL
  UNTRACKED
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum StatutoryConfigType {
  PF
  ESI
  PROFESSIONAL_TAX
  TDS_SLAB
  STANDARD_DEDUCTION
}

enum PayrollRunStatus {
  DRAFT
  PROCESSING
  COMPLETED
  LOCKED
}

enum PayslipStatus {
  GENERATED
  PAID
}

// ---- Sales module ----

enum CustomerStatus {
  ACTIVE
  INACTIVE
}

enum LeadPriority {
  HIGH
  MEDIUM
  LOW
}

enum LeadSource {
  REFERRAL
  WEBSITE
  COLD_OUTREACH
  EVENT
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  DISQUALIFIED
  CONVERTED
}

enum OpportunityStage {
  PROSPECTING
  QUALIFICATION
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum BidStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  SENT
  ACCEPTED
  EXPIRED
}

enum OrderStatus {
  CONFIRMED
  IN_PRODUCTION
  READY_TO_SHIP
  SHIPPED
  DELIVERED
  CANCELLED
}

/// Type of a configurable Bid/No-Bid assessment question. SELECT uses the
/// question's `options` JSON; the others ignore it.
enum BidAssessmentQuestionType {
  BOOLEAN
  TEXT
  SCALE
  SELECT
}

/// Lifecycle of a Bid/No-Bid decision assessment. A rejected assessment is
/// never reopened — the rep submits a fresh record (preserving history), and
/// only the most-recent assessment's status gates Bid creation.
enum BidAssessmentStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

/// Intra-state (CGST+SGST) vs inter-state (IGST). This phase applies one
/// active rate per bid/order; see TaxConfig.
enum SalesTaxType {
  CGST_SGST
  IGST
}

// ---- Vault (document management) module ----

/// PERSONAL = auto-provisioned per employee at onboarding (one each, private,
/// undeletable). DEFAULT = SUPER_ADMIN-created org folders. CUSTOM =
/// Manager-created team folders.
enum VaultFolderType {
  PERSONAL
  DEFAULT
  CUSTOM
}

enum VaultVisibilityScope {
  PRIVATE
  TEAM
  VERTICAL
  COMPANY_WIDE
}

enum VaultFolderStatus {
  ACTIVE
  ARCHIVED
}

/// Who an explicit VaultFolderPermission grant targets. granteeId is
/// polymorphic: an Employee id, a Vertical id, or a Role name respectively.
enum VaultGranteeType {
  EMPLOYEE
  VERTICAL
  ROLE
}

/// A VaultFile row is created before the browser has finished its direct
/// upload to R2 (PENDING); confirm-upload flips it ACTIVE. DELETED is the
/// soft-delete state (whole-file only).
enum VaultFileStatus {
  PENDING
  ACTIVE
  DELETED
}

/// Preview-conversion lifecycle for a version. Everything stays
/// NOT_APPLICABLE in Phase 2 — the Gotenberg pipeline that sets
/// PENDING/READY/FAILED is Phase 4.
enum PreviewStatus {
  NOT_APPLICABLE
  PENDING
  READY
  FAILED
}

/// What an internal share targets. resourceId is polymorphic (a VaultFile id
/// or a VaultFolder id per this type), so no DB FK on it.
enum VaultShareResourceType {
  FILE
  FOLDER
}

/// Granted access level for an internal share. VIEW = read; EDIT = read+write.
/// Additive only — a share never reduces access the recipient already has.
enum VaultSharePermission {
  VIEW
  EDIT
}

/// Business vertical (Sales, HR, Production, ...). A table, not an enum, so
/// new verticals can be added by the business without a code deploy.
model Vertical {
  id           String        @id @default(uuid())
  name         String        @unique
  code         String        @unique
  isActive     Boolean       @default(true)
  employees    Employee[]
  vaultFolders VaultFolder[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("verticals")
}

/// Internal employee. Authenticates via email + bcrypt password hash.
/// verticalId/reportingManagerId are required for every role except
/// SUPER_ADMIN — enforced in the service layer, not expressible as a plain
/// NOT NULL constraint here. role/passwordHash are nullable to support
/// two-step HR onboarding: HR creates the personnel record first
/// (accessStatus = PENDING_ACCESS, no role/login yet); Admin grants system
/// access afterward (assigns role, sets password, activates login).
model Employee {
  id                 String         @id @default(uuid())
  employeeId         String         @unique
  firstName          String
  lastName           String
  email              String         @unique
  passwordHash       String?
  verticalId         String?
  vertical           Vertical?      @relation(fields: [verticalId], references: [id], onDelete: Restrict)
  role               Role?
  reportingManagerId String?
  reportingManager   Employee?      @relation("ReportingChain", fields: [reportingManagerId], references: [id], onDelete: SetNull)
  reports            Employee[]     @relation("ReportingChain")
  status             EmployeeStatus @default(ACTIVE)
  deactivatedAt      DateTime?
  accessStatus       AccessStatus   @default(PENDING_ACCESS)

  /// Sales Head designation (not a Role). Exactly one active holder at a
  /// time — enforced at the service layer (designate unsets the previous
  /// holder in one transaction), not by a DB constraint.
  isSalesHead Boolean @default(false)

  /// Internal e-signature (a display layer, NOT a legally-binding e-sign).
  /// Self-service typed text rendered in a chosen signature-style font;
  /// snapshotted onto approval records at approval time.
  signatureText String?
  signatureFont SignatureFont?

  // HR onboarding fields — populated by POST /employees/onboard.
  dateOfBirth              DateTime?
  gender                   String?
  personalEmail            String?
  mobile                   String?
  designation              String?
  employmentType           EmploymentType?
  dateOfJoining            DateTime?
  workLocation             String?
  officialEmail            String?         @unique
  emergencyContactName     String?
  emergencyContactRelation String?
  emergencyContactPhone    String?

  statutoryInfo EmployeeStatutoryInfo?
  bankDetails   EmployeeBankDetails?

  salaryStructures        SalaryStructure[] @relation("SalaryStructureOwner")
  salaryStructuresEntered SalaryStructure[] @relation("SalaryStructureEnteredBy")
  payrollRunsInitiated    PayrollRun[]
  payslips                Payslip[]

  leaveBalances          LeaveBalance[]
  leaveRequestsSubmitted LeaveRequest[] @relation("LeaveRequester")
  leaveRequestsApproved  LeaveRequest[] @relation("LeaveApprover")
  attendanceRecords      Attendance[]

  // Sales ownership / authorship back-relations.
  customersOwned     Customer[]    @relation("CustomerOwner")
  leadsOwned         Lead[]        @relation("LeadOwner")
  opportunitiesOwned Opportunity[] @relation("OpportunityOwner")
  bidsCreated        Bid[]         @relation("BidCreator")
  bidsApproved       Bid[]         @relation("BidApprover")
  ordersOwned        Order[]       @relation("OrderOwner")

  bidAssessmentsSubmitted BidDecisionAssessment[] @relation("BidAssessmentSubmitter")
  bidAssessmentsReviewed  BidDecisionAssessment[] @relation("BidAssessmentReviewer")

  ocSheetsCreated        OrderConfirmationSheet[] @relation("OcCreator")
  ocSignedCopiesUploaded OrderConfirmationSheet[] @relation("OcSignedCopyUploader")
  ocSheetsInternalSigned OrderConfirmationSheet[] @relation("OcInternalSigner")

  vaultFoldersOwned       VaultFolder[]            @relation("VaultFolderOwner")
  vaultPermissionsGranted VaultFolderPermission[]  @relation("VaultPermissionGrantor")
  vaultFilesUploaded      VaultFile[]              @relation("VaultFileUploader")
  vaultVersionsUploaded   VaultFileVersion[]       @relation("VaultVersionUploader")
  vaultSharesReceived     VaultInternalShare[]     @relation("VaultShareRecipient")
  vaultSharesGranted      VaultInternalShare[]     @relation("VaultShareGrantor")
  vaultExternalLinks      VaultExternalShareLink[] @relation("VaultExternalShareCreator")

  auditLogs AuditLog[] @relation("AuditActor")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([verticalId])
  @@index([reportingManagerId])
  @@index([accessStatus])
  @@map("employees")
}

/// Effective-dated salary breakdown — replaces the old single-row
/// EmployeeCompensation. Multiple rows per employee over time; the
/// "current" structure is whichever row has the latest effectiveFrom <=
/// today (see SalaryStructuresService.getCurrent). History is append-only
/// — a change creates a new row rather than editing a prior one, so past
/// payroll runs remain reproducible. Decimal, never Float — these are
/// monetary amounts. Restricted to ADMIN/SUPER_ADMIN reads regardless of
/// who entered them (same access rule as the table it replaces).
model SalaryStructure {
  id               String    @id @default(uuid())
  employeeId       String
  employee         Employee  @relation("SalaryStructureOwner", fields: [employeeId], references: [id], onDelete: Cascade)
  effectiveFrom    DateTime
  basic            Decimal   @db.Decimal(14, 2)
  hra              Decimal   @db.Decimal(14, 2)
  specialAllowance Decimal   @default(0) @db.Decimal(14, 2)
  otherAllowances  Decimal?  @db.Decimal(14, 2)
  ctcAnnual        Decimal   @db.Decimal(14, 2)
  createdById      String?
  createdBy        Employee? @relation("SalaryStructureEnteredBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([employeeId, effectiveFrom])
  @@map("salary_structures")
}

/// Government IDs. panNumber/pfAccountNumber/esicNumber are stored as
/// application-layer ciphertext (AES-256-GCM, see core/crypto) — never
/// plaintext. aadhaarLast4 stores only the last 4 digits, never the full
/// number, so it isn't sensitive enough to need encryption.
model EmployeeStatutoryInfo {
  id              String   @id @default(uuid())
  employeeId      String   @unique
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  panNumber       String
  aadhaarLast4    String
  pfAccountNumber String
  esicNumber      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("employee_statutory_info")
}

/// bankAccountNumber is stored as application-layer ciphertext (see
/// core/crypto) — never plaintext.
model EmployeeBankDetails {
  id                String   @id @default(uuid())
  employeeId        String   @unique
  employee          Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  bankAccountNumber String
  ifscCode          String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("employee_bank_details")
}

/// Leave type (Casual, Sick, Earned, Unpaid, ...). A table, not an enum, so
/// new leave types can be added by the business without a code deploy —
/// same philosophy as Vertical.
model LeaveType {
  id              String           @id @default(uuid())
  code            String           @unique
  name            String
  accrualType     LeaveAccrualType
  annualQuota     Decimal?         @db.Decimal(5, 1)
  carryForwardCap Decimal?         @db.Decimal(5, 1)
  isActive        Boolean          @default(true)
  balances        LeaveBalance[]
  requests        LeaveRequest[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@map("leave_types")
}

/// Per-employee, per-year balance for a tracked leave type. `remaining` is
/// deliberately not stored (= allocated + carriedForward - used, computed
/// in the entity layer) to avoid drift — same rationale as other computed
/// fields in this schema.
model LeaveBalance {
  id               String    @id @default(uuid())
  employeeId       String
  employee         Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveTypeId      String
  leaveType        LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Restrict)
  year             Int
  allocated        Decimal   @default(0) @db.Decimal(5, 1)
  used             Decimal   @default(0) @db.Decimal(5, 1)
  carriedForward   Decimal   @default(0) @db.Decimal(5, 1)
  /// "YYYY-MM" of the last month this balance was credited by the EL
  /// accrual job — idempotency guard against double-crediting on rerun.
  lastAccrualMonth String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([employeeId, leaveTypeId, year])
  @@map("leave_balances")
}

/// A single leave request, routed for approval through the requester's
/// existing reportingManagerId hierarchy (no separate approver-assignment
/// model needed).
model LeaveRequest {
  id                            String             @id @default(uuid())
  employeeId                    String
  employee                      Employee           @relation("LeaveRequester", fields: [employeeId], references: [id], onDelete: Cascade)
  leaveTypeId                   String
  leaveType                     LeaveType          @relation(fields: [leaveTypeId], references: [id], onDelete: Restrict)
  startDate                     DateTime
  endDate                       DateTime
  numberOfDays                  Decimal            @db.Decimal(4, 1)
  reason                        String
  status                        LeaveRequestStatus @default(PENDING)
  approverId                    String?
  approver                      Employee?          @relation("LeaveApprover", fields: [approverId], references: [id], onDelete: SetNull)
  approvedAt                    DateTime?
  approverComments              String?
  /// Snapshot of the approving manager's e-signature at approval time.
  approverSignatureTextSnapshot String?
  approverSignatureFontSnapshot SignatureFont?
  createdAt                     DateTime           @default(now())
  updatedAt                     DateTime           @updatedAt

  @@index([employeeId])
  @@index([status])
  @@index([startDate, endDate])
  @@map("leave_requests")
}

/// Daily attendance record. `status` (PRESENT/ABSENT/ON_LEAVE/HALF_DAY) is
/// deliberately not a column — it's derived on read from
/// checkInTime/checkOutTime plus approved-leave lookups, so there is one
/// source of truth for how status is computed (Admin corrections set times
/// directly, never status).
model Attendance {
  id           String    @id @default(uuid())
  employeeId   String
  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date         DateTime
  checkInTime  DateTime?
  checkOutTime DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([employeeId, date])
  @@map("attendance")
}

/// Versioned, effective-dated statutory rate/threshold configuration
/// (PF, ESI, Professional Tax, TDS slabs, standard deduction). Every rate
/// used in a payroll computation must come from a row here, never be
/// hardcoded in service logic — India's wage-definition and tax rules
/// change independently of this codebase's release cycle, and a payroll
/// run must reproduce the exact calculation that was correct on its own
/// period even after rates change going forward.
///
/// DELIBERATELY NOT SEEDED. This table starts empty and must stay empty
/// until a CA / payroll-compliance specialist has verified real rates
/// against primary sources (EPFO/ESIC circulars, Income Tax Department
/// notifications, state Professional Tax departments) — see the Payroll
/// module's README. PayrollRunsService.processRun() refuses to run
/// against missing config rather than silently computing zero deductions.
model StatutoryConfig {
  id            String              @id @default(uuid())
  configType    StatutoryConfigType
  /// Only meaningful for PROFESSIONAL_TAX (varies by state).
  state         String?
  effectiveFrom DateTime
  effectiveTo   DateTime?
  /// Shape varies by configType — e.g. PF: {employeeRate, employerRate,
  /// epsRate, wageCeiling, adminCharge}; TDS_SLAB: [{slabFrom, slabTo,
  /// rate}, ...]. Validated per-configType in StatutoryConfigService, not
  /// at the schema level (Prisma has no discriminated-JSON support).
  configData    Json
  /// Where this rate came from / who approved it — required for audit
  /// traceability, not optional metadata.
  sourceNote    String
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([configType, state, effectiveFrom])
  @@map("statutory_configs")
}

/// One payroll period for the whole company. Lifecycle: DRAFT (created,
/// no payslips yet) -> PROCESSING (computation in flight) -> COMPLETED
/// (payslips generated) -> LOCKED (immutable; corrections require a new
/// period's adjustment, never a retroactive edit).
model PayrollRun {
  id            String           @id @default(uuid())
  month         Int
  year          Int
  status        PayrollRunStatus @default(DRAFT)
  initiatedById String
  initiatedBy   Employee         @relation(fields: [initiatedById], references: [id], onDelete: Restrict)
  processedAt   DateTime?
  lockedAt      DateTime?
  payslips      Payslip[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@unique([month, year])
  @@map("payroll_runs")
}

/// One per employee per PayrollRun. `statutoryConfigSnapshot` freezes the
/// exact StatutoryConfig row contents used at generation time — a later
/// StatutoryConfig update must never retroactively change what an already-
/// generated payslip's numbers mean.
model Payslip {
  id                      String        @id @default(uuid())
  payrollRunId            String
  payrollRun              PayrollRun    @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employeeId              String
  employee                Employee      @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  grossEarnings           Decimal       @db.Decimal(14, 2)
  basicPaid               Decimal       @db.Decimal(14, 2)
  hraPaid                 Decimal       @db.Decimal(14, 2)
  specialAllowancePaid    Decimal       @db.Decimal(14, 2)
  otherAllowancesPaid     Decimal       @db.Decimal(14, 2)
  pfEmployee              Decimal       @db.Decimal(14, 2)
  pfEmployer              Decimal       @db.Decimal(14, 2)
  esiEmployee             Decimal?      @db.Decimal(14, 2)
  esiEmployer             Decimal?      @db.Decimal(14, 2)
  professionalTax         Decimal?      @db.Decimal(14, 2)
  tdsDeducted             Decimal       @db.Decimal(14, 2)
  unpaidLeaveDeduction    Decimal       @default(0) @db.Decimal(14, 2)
  netPay                  Decimal       @db.Decimal(14, 2)
  statutoryConfigSnapshot Json
  status                  PayslipStatus @default(GENERATED)
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  @@unique([payrollRunId, employeeId])
  @@map("payslips")
}

/// Append-only audit trail of mutating actions. Written by AuditInterceptor.
model AuditLog {
  id        String    @id @default(cuid())
  actorId   String?
  actor     Employee? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  action    String // HTTP method + route, e.g. "POST /employees"
  entity    String? // logical entity name, e.g. "Employee"
  entityId  String?
  before    Json?
  after     Json?
  ip        String?
  createdAt DateTime  @default(now())

  @@index([actorId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================================================
// Sales module
// ============================================================================

/// Per-(entity, year) monotonic counter backing year-prefixed, annually
/// resetting human-readable numbers (LD-2026-0001, BID-2026-0001,
/// ORD-2026-0001). A plain Postgres sequence (like employee_id_seq) can't
/// reset per calendar year, so numbering uses this counter table instead:
/// an atomic `INSERT ... ON CONFLICT (entity, year) DO UPDATE SET
/// lastValue = ... + 1 RETURNING lastValue` inside the record's own insert
/// transaction (see SalesNumberingService). The first row for a new year
/// starts the count fresh at 1.
model SalesSequence {
  entity    String
  year      Int
  lastValue Int      @default(0)
  updatedAt DateTime @updatedAt

  @@id([entity, year])
  @@map("sales_sequences")
}

/// A customer account owned by a Sales rep. shippingAddress defaults to
/// billingAddress at the application layer when null.
model Customer {
  id              String            @id @default(uuid())
  name            String
  gstin           String?
  billingAddress  Json
  shippingAddress Json?
  industry        String?
  ownerId         String
  owner           Employee          @relation("CustomerOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  status          CustomerStatus    @default(ACTIVE)
  contacts        CustomerContact[]
  opportunities   Opportunity[]
  bids            Bid[]
  orders          Order[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([ownerId])
  @@index([status])
  @@map("customers")
}

model CustomerContact {
  id          String   @id @default(uuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name        String
  email       String?
  phone       String?
  designation String?
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([customerId])
  @@map("customer_contacts")
}

/// Product catalog. unitPrice is the current list price; a Bid/Order line
/// item snapshots the price at creation time rather than referencing this
/// live (see BidLineItem.unitPrice).
model Product {
  id             String          @id @default(uuid())
  sku            String          @unique
  name           String
  description    String?
  unitPrice      Decimal         @db.Decimal(14, 2)
  unitOfMeasure  String
  hsnCode        String?
  isActive       Boolean         @default(true)
  bidLineItems   BidLineItem[]
  orderLineItems OrderLineItem[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@map("products")
}

model Lead {
  id                       String       @id @default(uuid())
  leadNumber               String       @unique
  companyName              String
  contactName              String
  email                    String?
  phone                    String?
  requirement              String
  priority                 LeadPriority @default(MEDIUM)
  source                   LeadSource   @default(OTHER)
  status                   LeadStatus   @default(NEW)
  ownerId                  String
  owner                    Employee     @relation("LeadOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  disqualifiedReason       String?
  convertedToOpportunityId String?      @unique
  convertedToOpportunity   Opportunity? @relation("LeadConversion", fields: [convertedToOpportunityId], references: [id], onDelete: SetNull)
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt

  @@index([ownerId])
  @@index([status])
  @@map("leads")
}

model Opportunity {
  id                String                  @id @default(uuid())
  leadId            String?
  lead              Lead?                   @relation("LeadConversion")
  customerId        String?
  customer          Customer?               @relation(fields: [customerId], references: [id], onDelete: SetNull)
  name              String
  stage             OpportunityStage        @default(PROSPECTING)
  estimatedValue    Decimal                 @db.Decimal(14, 2)
  expectedCloseDate DateTime
  ownerId           String
  owner             Employee                @relation("OpportunityOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  lostReason        String?
  bids              Bid[]
  bidAssessments    BidDecisionAssessment[]
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@index([ownerId])
  @@index([stage])
  @@map("opportunities")
}

/// A formal bid/tender response against an opportunity. Monetary totals are
/// computed from line items + discount + tax (see BidsService). A bid with
/// discountPercent > 10 routes to the creator's manager for approval before
/// it can be SENT (same escalation guard as leave approvals).
model Bid {
  id                            String         @id @default(uuid())
  bidNumber                     String         @unique
  opportunityId                 String
  opportunity                   Opportunity    @relation(fields: [opportunityId], references: [id], onDelete: Restrict)
  customerId                    String
  customer                      Customer       @relation(fields: [customerId], references: [id], onDelete: Restrict)
  status                        BidStatus      @default(DRAFT)
  validUntil                    DateTime
  tenderReferenceNumber         String?
  technicalSpecification        String?
  /// Placeholder for a future file-storage module: metadata only
  /// ([{filename, url}]), no upload infrastructure in this phase.
  attachments                   Json?
  subtotal                      Decimal        @default(0) @db.Decimal(14, 2)
  discountPercent               Decimal        @default(0) @db.Decimal(5, 2)
  discountAmount                Decimal        @default(0) @db.Decimal(14, 2)
  taxType                       SalesTaxType?
  taxRate                       Decimal?       @db.Decimal(5, 2)
  taxAmount                     Decimal        @default(0) @db.Decimal(14, 2)
  totalAmount                   Decimal        @default(0) @db.Decimal(14, 2)
  createdById                   String
  createdBy                     Employee       @relation("BidCreator", fields: [createdById], references: [id], onDelete: Restrict)
  approverId                    String?
  approver                      Employee?      @relation("BidApprover", fields: [approverId], references: [id], onDelete: SetNull)
  approvedAt                    DateTime?
  approverComments              String?
  /// Snapshot of the approving manager's e-signature at discount-approval time.
  approverSignatureTextSnapshot String?
  approverSignatureFontSnapshot SignatureFont?
  lineItems                     BidLineItem[]
  orders                        Order[]
  createdAt                     DateTime       @default(now())
  updatedAt                     DateTime       @updatedAt

  @@index([opportunityId])
  @@index([customerId])
  @@index([status])
  @@index([createdById])
  @@map("bids")
}

model BidLineItem {
  id                  String   @id @default(uuid())
  bidId               String
  bid                 Bid      @relation(fields: [bidId], references: [id], onDelete: Cascade)
  productId           String
  product             Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity            Decimal  @db.Decimal(14, 2)
  /// Snapshot of Product.unitPrice at bid-creation time — never a live
  /// reference, so the bid preserves exactly what was proposed.
  unitPrice           Decimal  @db.Decimal(14, 2)
  lineDiscountPercent Decimal? @db.Decimal(5, 2)
  lineTotal           Decimal  @db.Decimal(14, 2)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([bidId])
  @@map("bid_line_items")
}

model Order {
  id                 String                   @id @default(uuid())
  orderNumber        String                   @unique
  bidId              String?
  bid                Bid?                     @relation(fields: [bidId], references: [id], onDelete: SetNull)
  customerId         String
  customer           Customer                 @relation(fields: [customerId], references: [id], onDelete: Restrict)
  status             OrderStatus              @default(CONFIRMED)
  /// Snapshot of the source bid's totalAmount at conversion time — the
  /// order's booked value. Frozen here rather than recomputed from line
  /// items so it survives independently of the bid (which can be edited in
  /// a later revision). Decimal, never Float.
  totalAmount        Decimal                  @default(0) @db.Decimal(14, 2)
  /// Reserved FK for the future Production module — not enforced yet.
  productionRunId    String?
  /// Reserved FK for the future SCM/logistics module — not enforced yet.
  shipmentId         String?
  ownerId            String
  owner              Employee                 @relation("OrderOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  lineItems          OrderLineItem[]
  confirmationSheets OrderConfirmationSheet[]
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  @@index([ownerId])
  @@index([customerId])
  @@index([status])
  @@map("orders")
}

model OrderLineItem {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity  Decimal  @db.Decimal(14, 2)
  unitPrice Decimal  @db.Decimal(14, 2)
  lineTotal Decimal  @db.Decimal(14, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@map("order_line_items")
}

/// Lifecycle of an Order Confirmation Sheet. DRAFT is editable; generating the
/// PDF locks it (AWAITING_CUSTOMER_SIGNATURE); the rep uploads the customer-
/// signed scan (AWAITING_INTERNAL_SIGNATURE); the Sales Head countersigns
/// (EXECUTED) or rejects (REJECTED). EXECUTED is the hard gate that unblocks
/// the Order's CONFIRMED -> IN_PRODUCTION transition.
enum OrderConfirmationStatus {
  DRAFT
  AWAITING_CUSTOMER_SIGNATURE
  AWAITING_INTERNAL_SIGNATURE
  REJECTED
  EXECUTED
}

enum OrderConfirmationDeliveryType {
  FULL_TRUCKLOAD
  PARTIAL_TRUCKLOAD
  CUSTOMER_PICKUP_EXWORKS
  COURIER_EXPRESS
  OTHER
}

enum OrderConfirmationQualityReport {
  MATERIAL_TEST_CERTIFICATE
  FACTORY_ACCEPTANCE_TEST_REPORT
  CALIBRATION_CERTIFICATE
  COMPLIANCE_CERTIFICATE
  OTHER
}

/// A formal, customer-agreed requirements document tied to a CONFIRMED order:
/// delivery/packaging/quality terms, executed by customer signature + Sales
/// Head countersignature. Numbered OC-YYYY-#### via SalesNumberingService.
/// Revisions are new rows (revisionNumber+1), so full history is preserved.
/// The single signed-copy attachment lives in R2 (signedCopyStorageKey),
/// reusing the Vault storage client directly — not the Vault folder model.
model OrderConfirmationSheet {
  id                 String                  @id @default(uuid())
  confirmationNumber String                  @unique
  orderId            String
  order              Order                   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  revisionNumber     Int                     @default(1)
  status             OrderConfirmationStatus @default(DRAFT)

  requirementsOverview String @db.Text

  deliveryDate     DateTime
  deliveryLocation String                        @db.Text
  deliveryType     OrderConfirmationDeliveryType

  qualityReportsExpected OrderConfirmationQualityReport[]
  qualityReportNotes     String?                          @db.Text

  installationCommissioningRequired Boolean @default(false)
  installationNotes                 String? @db.Text

  warrantyTerms               String  @db.Text
  paymentMilestones           String  @db.Text
  siteReadinessRequirements   String? @db.Text
  specialHandlingInstructions String? @db.Text

  // Packaging — deliberately structured (§2.1); required at the form level.
  packagingType                  String  @db.Text
  protectiveMeasures             String  @db.Text
  packagingComplianceStandard    String? @db.Text
  labelingRequirements           String  @db.Text
  customerPackagingSpecReference String? @db.Text

  // Delivery coordination point of contact.
  customerContactName  String
  customerContactPhone String
  customerContactEmail String

  pdfGeneratedAt DateTime?

  signedCopyStorageKey   String?
  signedCopyUploadedById String?
  signedCopyUploadedBy   Employee? @relation("OcSignedCopyUploader", fields: [signedCopyUploadedById], references: [id], onDelete: SetNull)
  signedCopyUploadedAt   DateTime?

  internalSignedById            String?
  internalSignedBy              Employee?      @relation("OcInternalSigner", fields: [internalSignedById], references: [id], onDelete: SetNull)
  internalSignedAt              DateTime?
  internalReviewComments        String?        @db.Text
  /// Snapshot of the Sales Head's e-signature at countersignature time —
  /// rendered onto the internal-signature line of the printed sheet.
  approverSignatureTextSnapshot String?
  approverSignatureFontSnapshot SignatureFont?

  createdById String
  createdBy   Employee @relation("OcCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([orderId])
  @@index([status])
  @@map("order_confirmation_sheets")
}

/// Versioned, effective-dated GST rate — same pattern as StatutoryConfig,
/// though lower compliance stakes (a wrong bid rate is correctable before
/// invoicing). One active rate per taxType; not per-HSN yet. Do NOT hardcode
/// GST percentages in service code — every rate comes from a row here.
model TaxConfig {
  id            String       @id @default(uuid())
  taxType       SalesTaxType
  rate          Decimal      @db.Decimal(5, 2)
  effectiveFrom DateTime
  effectiveTo   DateTime?
  sourceNote    String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([taxType, effectiveFrom])
  @@map("tax_configs")
}

/// Configurable Bid/No-Bid questionnaire item — editable by Admin, same
/// extensible-table pattern as Vertical/LeaveType (not hardcoded). The
/// question text is snapshotted onto each response at submission time, so
/// editing/deactivating a question here never rewrites answered history.
model BidAssessmentQuestion {
  id           String                    @id @default(uuid())
  text         String
  type         BidAssessmentQuestionType
  /// Only used for SELECT-type questions: JSON array of option strings.
  options      Json?
  displayOrder Int                       @default(0)
  isActive     Boolean                   @default(true)
  responses    BidAssessmentResponse[]
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt

  @@index([isActive, displayOrder])
  @@map("bid_assessment_questions")
}

/// A rep's Bid/No-Bid decision submission for an Opportunity, reviewed by the
/// designated Sales Head (or SUPER_ADMIN fallback). Rejection is not reopened
/// — a resubmission is a new row; only the most-recent per Opportunity gates
/// Bid creation.
model BidDecisionAssessment {
  id                            String                  @id @default(uuid())
  opportunityId                 String
  opportunity                   Opportunity             @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  submittedById                 String
  submittedBy                   Employee                @relation("BidAssessmentSubmitter", fields: [submittedById], references: [id], onDelete: Restrict)
  status                        BidAssessmentStatus     @default(PENDING_REVIEW)
  reviewedById                  String?
  reviewedBy                    Employee?               @relation("BidAssessmentReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt                    DateTime?
  reviewerComments              String?
  /// Snapshot of the reviewer's e-signature at approval time (nullable — none
  /// if the reviewer had no signature configured).
  approverSignatureTextSnapshot String?
  approverSignatureFontSnapshot SignatureFont?
  responses                     BidAssessmentResponse[]
  createdAt                     DateTime                @default(now())
  updatedAt                     DateTime                @updatedAt

  @@index([opportunityId, createdAt])
  @@index([status])
  @@map("bid_decision_assessments")
}

/// One answer within a BidDecisionAssessment. `questionTextSnapshot` freezes
/// the wording as asked (same snapshot principle as Bid line-item prices and
/// Payslip statutory config). `answerValue` stores every type as text; the
/// display layer parses per the question's `type`.
model BidAssessmentResponse {
  id                   String                @id @default(uuid())
  assessmentId         String
  assessment           BidDecisionAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  questionId           String
  question             BidAssessmentQuestion @relation(fields: [questionId], references: [id], onDelete: Restrict)
  questionTextSnapshot String
  answerValue          String
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@index([assessmentId])
  @@map("bid_assessment_responses")
}

/// Vault folder tree. Access = default scope rules (per visibilityScope) +
/// explicit VaultFolderPermission grants, most-permissive-wins, SUPER_ADMIN
/// override — computed in VaultAccessService, never trusted from the client.
/// PERSONAL folders: exactly one per employee (partial unique index in the
/// migration), PRIVATE, undeletable, versioning not exposed.
model VaultFolder {
  id                  String                  @id @default(uuid())
  name                String
  parentFolderId      String?
  parentFolder        VaultFolder?            @relation("VaultFolderTree", fields: [parentFolderId], references: [id], onDelete: Restrict)
  childFolders        VaultFolder[]           @relation("VaultFolderTree")
  type                VaultFolderType
  ownerId             String
  /// Cascade: production never hard-deletes employees (soft-delete via
  /// status INACTIVE); a hard delete (e.g. test cleanup) takes the person's
  /// folders with it rather than blocking on the auto-provisioned PERSONAL one.
  owner               Employee                @relation("VaultFolderOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  visibilityScope     VaultVisibilityScope
  /// Required when visibilityScope = VERTICAL (service-enforced).
  scopeVerticalId     String?
  scopeVertical       Vertical?               @relation(fields: [scopeVerticalId], references: [id], onDelete: Restrict)
  versioningEnabled   Boolean                 @default(false)
  maxVersionsRetained Int?                    @default(5)
  status              VaultFolderStatus       @default(ACTIVE)
  permissions         VaultFolderPermission[]
  files               VaultFile[]
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  @@index([ownerId])
  @@index([parentFolderId])
  @@index([visibilityScope, scopeVerticalId])
  @@map("vault_folders")
}

/// Explicit grant beyond a folder's default scope — additive only (grants
/// never reduce scope-derived access). granteeId is polymorphic per
/// granteeType (Employee id / Vertical id / Role name), so no FK on it.
model VaultFolderPermission {
  id                 String           @id @default(uuid())
  folderId           String
  folder             VaultFolder      @relation(fields: [folderId], references: [id], onDelete: Cascade)
  granteeType        VaultGranteeType
  granteeId          String
  canRead            Boolean          @default(false)
  canWrite           Boolean          @default(false)
  canDelete          Boolean          @default(false)
  canCreateSubfolder Boolean          @default(false)
  grantedById        String
  grantedBy          Employee         @relation("VaultPermissionGrantor", fields: [grantedById], references: [id], onDelete: Cascade)
  createdAt          DateTime         @default(now())

  @@unique([folderId, granteeType, granteeId])
  @@index([granteeType, granteeId])
  @@map("vault_folder_permissions")
}

/// Stable identity for a document. Its bytes live in one-or-more
/// VaultFileVersions; currentVersionId points at the live one. The backend
/// never stores or streams bytes — only R2 object keys (storageKey on the
/// version). A file always belongs to a folder (folderId required). Deletion
/// is whole-file soft-delete (status DELETED cascades to every version).
model VaultFile {
  id               String             @id @default(uuid())
  folderId         String
  folder           VaultFolder        @relation(fields: [folderId], references: [id], onDelete: Restrict)
  name             String
  /// The live version. Nullable only transiently: a PENDING file exists
  /// before its first version row is linked. No DB-level FK back-reference
  /// (would be a cycle with VaultFileVersion.fileId) — set in the service.
  currentVersionId String?            @unique
  uploadedById     String
  uploadedBy       Employee           @relation("VaultFileUploader", fields: [uploadedById], references: [id], onDelete: Cascade)
  status           VaultFileStatus    @default(PENDING)
  versions         VaultFileVersion[] @relation("VaultFileVersions")
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([folderId, status])
  @@map("vault_files")
}

/// One immutable version of a file's bytes. versionNumber is sequential per
/// file. Append-only: a restore adds a new version copying an older one; a
/// version row is never mutated, and only ever hard-deleted by retention
/// pruning (which also deletes the R2 object). storageKey is the R2 object
/// key. Preview fields stay NOT_APPLICABLE/unset until Phase 4.
model VaultFileVersion {
  id                 String                   @id @default(uuid())
  fileId             String
  file               VaultFile                @relation("VaultFileVersions", fields: [fileId], references: [id], onDelete: Cascade)
  versionNumber      Int
  mimeType           String
  sizeBytes          BigInt
  storageKey         String
  previewStorageKey  String?
  previewStatus      PreviewStatus            @default(NOT_APPLICABLE)
  changeNote         String?
  uploadedById       String
  uploadedBy         Employee                 @relation("VaultVersionUploader", fields: [uploadedById], references: [id], onDelete: Cascade)
  externalShareLinks VaultExternalShareLink[]
  createdAt          DateTime                 @default(now())

  @@unique([fileId, versionNumber])
  @@index([fileId])
  @@map("vault_file_versions")
}

/// An additive internal share: grants one employee VIEW/EDIT on one file or
/// folder, ON TOP OF whatever the resource's default scope / folder
/// permissions already give them. Folded into VaultAccessService — never
/// reduces existing access. resourceId is polymorphic per resourceType, so
/// there is no FK on it (a share is cleaned up in the service, or orphaned
/// harmlessly if the resource is hard-deleted).
model VaultInternalShare {
  id                   String                 @id @default(uuid())
  resourceType         VaultShareResourceType
  resourceId           String
  sharedWithEmployeeId String
  sharedWithEmployee   Employee               @relation("VaultShareRecipient", fields: [sharedWithEmployeeId], references: [id], onDelete: Cascade)
  permission           VaultSharePermission
  sharedById           String
  sharedBy             Employee               @relation("VaultShareGrantor", fields: [sharedById], references: [id], onDelete: Cascade)
  createdAt            DateTime               @default(now())

  // One live share per (resource, recipient): re-sharing updates the level.
  @@unique([resourceType, resourceId, sharedWithEmployeeId])
  @@index([sharedWithEmployeeId])
  @@index([resourceType, resourceId])
  @@map("vault_internal_shares")
}

/// A public, unauthenticated external share link. `token` is a cryptographically
/// random secret (the only credential), permission is ALWAYS VIEW (no edit,
/// ever). For a FILE it PINS `pinnedVersionId` — the version current at
/// creation time — and keeps serving that even after newer versions land
/// (not a live "current" pointer). Optional passwordHash + expiresAt (default
/// 24h) + revokedAt gate access. PERSONAL folders can't be link-shared whole
/// (service-enforced); individual files within them can.
model VaultExternalShareLink {
  id              String                   @id @default(uuid())
  resourceType    VaultShareResourceType
  resourceId      String
  token           String                   @unique
  /// Always VIEW — kept as a column for audit clarity, never anything else.
  permission      VaultSharePermission     @default(VIEW)
  /// Pinned version for FILE links (null for FOLDER links). No FK action on
  /// delete beyond SetNull so a pruned version doesn't cascade-remove the link
  /// row (the link simply stops resolving — handled in the service).
  pinnedVersionId String?
  pinnedVersion   VaultFileVersion?        @relation(fields: [pinnedVersionId], references: [id], onDelete: SetNull)
  passwordHash    String?
  expiresAt       DateTime
  revokedAt       DateTime?
  createdById     String
  createdBy       Employee                 @relation("VaultExternalShareCreator", fields: [createdById], references: [id], onDelete: Cascade)
  accessLogs      VaultExternalAccessLog[]
  createdAt       DateTime                 @default(now())

  @@index([resourceType, resourceId])
  @@map("vault_external_share_links")
}

/// Audit trail for every public-link access ATTEMPT (success or failure —
/// expired/revoked/bad-password hits are logged too). IP + user agent captured
/// for security review.
model VaultExternalAccessLog {
  id          String                 @id @default(uuid())
  shareLinkId String
  shareLink   VaultExternalShareLink @relation(fields: [shareLinkId], references: [id], onDelete: Cascade)
  accessedAt  DateTime               @default(now())
  ipAddress   String?
  userAgent   String?

  @@index([shareLinkId])
  @@map("vault_external_access_logs")
}
