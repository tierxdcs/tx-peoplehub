// ── Stores Phase 3: Material Indent + Issue ──────────────────────────────
//
// Production raises a MaterialIndent for stock; Stores fulfils it with one or
// more MaterialIssueNotes. Each issue generates a STOCK_OUT (a negative ON_HAND
// StockAdjustment + StockBalance decrement) through the SAME ledger path as
// the rest of inventory, and — crucially — reuses the existing availability
// rule (available = onHand − reserved − blocked) so material reserved for one
// project (via the BOM/Kickoff StockReservation system) can never be issued to
// a different one. Short issues are allowed; the indent's status is DERIVED
// from cumulative issued vs requested, never stored/set by hand.

enum MaterialIndentStatus {
  OPEN
  PARTIALLY_ISSUED
  FULLY_ISSUED
  CANCELLED
}

/// Production's request for material against stock. Optionally tied to a
/// project kickoff, which is what lets the issue honour that project's own
/// reservations (and refuse to consume another project's).
model MaterialIndent {
  id           String               @id @default(uuid())
  /// IND-YYYY-#### via the shared year-prefixed sequence (SalesNumberingService).
  indentNumber String               @unique
  status       MaterialIndentStatus @default(OPEN)

  /// Optional link to the project this material is for. Drives reservation-aware
  /// issuing: an issue against a kickoff-linked indent may draw on that
  /// kickoff's reservations; a null link may only draw on unreserved stock.
  projectKickoffId String?
  projectKickoff   ProjectKickoff? @relation(fields: [projectKickoffId], references: [id], onDelete: SetNull)

  itemId String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Restrict)

  requestedQuantity Decimal   @db.Decimal(14, 4)
  requiredByDate    DateTime?
  notes             String?   @db.Text

  raisedById String
  raisedBy   Employee @relation("MaterialIndentRaisedBy", fields: [raisedById], references: [id], onDelete: Restrict)

  issueNotes MaterialIssueNote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([itemId])
  @@index([projectKickoffId])
  @@map("material_indents")
}

/// A Stores issue of material against an indent. Each note issues a quantity
/// from a specific store/bin location, generating a STOCK_OUT. Cumulative
/// issued quantity across notes drives the parent indent's derived status.
model MaterialIssueNote {
  id        String @id @default(uuid())
  /// MIN-YYYY-#### via the shared year-prefixed sequence.
  minNumber String @unique

  materialIndentId String
  materialIndent   MaterialIndent @relation(fields: [materialIndentId], references: [id], onDelete: Restrict)

  itemId String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Restrict)

  storeLocationId String
  storeLocation   StoreLocation @relation(fields: [storeLocationId], references: [id], onDelete: Restrict)

  issuedQuantity Decimal @db.Decimal(14, 4)
  /// Free-text bin location within the store (matches the reference ERP).
  binLocation    String?
  notes          String? @db.Text

  issuedById String
  issuedBy   Employee @relation("MaterialIssueIssuedBy", fields: [issuedById], references: [id], onDelete: Restrict)
  issuedAt   DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([materialIndentId])
  @@index([itemId])
  @@map("material_issue_notes")
}

// ── Logistics & Dispatch ─────────────────────────────────────────────────
//
// Delivery Challans for outbound shipments. Dispatching a DC generates STOCK_OUT
// movements for the shipped finished goods (via the existing ledger) and seeds a
// DRAFT SalesInvoice in AR (never issued here — Finance's maker-checker owns
// that). Partial dispatch across multiple DCs per order line is supported;
// "previously dispatched" and order fulfilment status are COMPUTED, never stored.

enum TransportMode {
  ROAD
  RAIL
  AIR
  SEA
  COURIER
}

enum DeliveryChallanStatus {
  DRAFT
  DISPATCHED
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

model DeliveryChallan {
  id         String                @id @default(uuid())
  /// DC-YYYY-#### via the shared year-prefixed SalesNumberingService.
  dcNumber   String                @unique
  orderId    String
  order      Order                 @relation(fields: [orderId], references: [id], onDelete: Restrict)
  customerId String
  customer   Customer              @relation(fields: [customerId], references: [id], onDelete: Restrict)
  status     DeliveryChallanStatus @default(DRAFT)

  customerPoReference String?
  dispatchDate        DateTime

  consigneeName      String
  consigneeAddress   String  @db.Text
  consigneeGstin     String?
  /// Drives place-of-supply on the seeded draft invoice.
  consigneeStateCode String

  transportMode               TransportMode
  transporterName             String?
  vehicleOrAwbNumber          String?
  driverName                  String?
  driverPhone                 String?
  specialDeliveryInstructions String?       @db.Text
  /// Checklist of documents included (DC, invoice, e-way bill, packing list,
  /// COC, FAT report, quality certificate, ISPM-15/phyto), as a JSON map.
  documentsIncluded           Json?

  /// Captured for OTD tracking; actual set on POD capture.
  promisedDeliveryDate DateTime?
  actualDeliveryDate   DateTime?

  linkedInvoiceId String?       @unique
  linkedInvoice   SalesInvoice? @relation("DeliveryChallanInvoice", fields: [linkedInvoiceId], references: [id], onDelete: SetNull)

  eWayBillNumber     String?
  eWayBillDate       DateTime?
  eWayBillValidUntil DateTime?

  /// Proof of delivery (R2 object key) + who signed + notes.
  podFileKey    String?
  podReceivedBy String?
  podNotes      String? @db.Text

  createdById String
  createdBy   Employee @relation("DeliveryChallanCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  lines     DeliveryChallanLine[]
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  @@index([orderId])
  @@index([customerId])
  @@index([status])
  @@map("delivery_challans")
}

model DeliveryChallanLine {
  id                String          @id @default(uuid())
  deliveryChallanId String
  deliveryChallan   DeliveryChallan @relation(fields: [deliveryChallanId], references: [id], onDelete: Cascade)
  itemId            String
  item              Item            @relation(fields: [itemId], references: [id], onDelete: Restrict)
  /// Required — partial-dispatch tracking depends on knowing which order line
  /// each dispatched quantity belongs to.
  orderLineId       String
  orderLine         OrderLineItem   @relation(fields: [orderLineId], references: [id], onDelete: Restrict)

  description   String
  hsnCode       String?
  quantity      Decimal @db.Decimal(14, 4)
  unitOfMeasure String
  unitRate      Decimal @db.Decimal(18, 2)
  lineValue     Decimal @db.Decimal(18, 2)
  sequence      Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([deliveryChallanId])
  @@index([orderLineId])
  @@index([itemId])
  @@map("delivery_challan_lines")
}

// ── RFQ Builder (SCM) ────────────────────────────────────────────────────
//
// Float Requests for Quotation to ≥3 vendors/suppliers, collect sealed quotes
// through a token-authed public form, compare, and award (lowest-cost OR a
// documented override). Reuses the shared token-invite behaviour, R2 storage
// guardrails, and pre-fills a DRAFT PurchaseOrder on award. Sealed-bid: quotes
// are not readable by SCM until the RFQ CLOSES (enforced in the service).

enum RfqStatus {
  DRAFT
  ISSUED
  CLOSED
  AWARDED
  CANCELLED
}

/// Per-invitee quote lifecycle.
enum RfqQuoteStatus {
  INVITED
  VIEWED
  SUBMITTED
  DECLINED
}

model Rfq {
  id          String    @id @default(uuid())
  /// RFQ-YYYY-#### via the shared year-prefixed SalesNumberingService.
  rfqNumber   String    @unique
  title       String
  description String?   @db.Text
  status      RfqStatus @default(DRAFT)

  /// Set when generated from a kickoff stock shortfall.
  projectKickoffId String?
  projectKickoff   ProjectKickoff? @relation(fields: [projectKickoffId], references: [id], onDelete: SetNull)

  submissionDeadline    DateTime
  requiredByDate        DateTime?
  deliveryLocation      String?   @db.Text
  paymentTermsRequested String?

  /// The winning invitee. Named relation so it doesn't clash with the
  /// Rfq→RfqInvitee list relation below.
  awardedInviteeId   String?     @unique
  awardedInvitee     RfqInvitee? @relation("RfqAwardedInvitee", fields: [awardedInviteeId], references: [id], onDelete: SetNull)
  awardDecisionById  String?
  awardDecisionBy    Employee?   @relation("RfqAwardDecisionBy", fields: [awardDecisionById], references: [id], onDelete: SetNull)
  awardDecisionAt    DateTime?
  /// Mandatory when the awarded quote is NOT the lowest total (service-enforced).
  awardJustification String?     @db.Text

  createdById String
  createdBy   Employee @relation("RfqCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  lines    RfqLine[]
  invitees RfqInvitee[] @relation("RfqInvitees")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([projectKickoffId])
  @@map("rfqs")
}

model RfqLine {
  id                 String  @id @default(uuid())
  rfqId              String
  rfq                Rfq     @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  itemId             String
  item               Item    @relation(fields: [itemId], references: [id], onDelete: Restrict)
  quantity           Decimal @db.Decimal(14, 4)
  unitOfMeasure      String
  specificationNotes String? @db.Text
  sequence           Int     @default(0)

  quoteLines RfqQuoteLine[]

  @@index([rfqId])
  @@index([itemId])
  @@map("rfq_lines")
}

model RfqInvitee {
  id    String @id @default(uuid())
  rfqId String
  rfq   Rfq    @relation("RfqInvitees", fields: [rfqId], references: [id], onDelete: Cascade)

  /// Exactly one of supplierId / vendorId (CHECK constraint in migration).
  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  vendorId   String?
  vendor     Vendor?   @relation(fields: [vendorId], references: [id], onDelete: Restrict)

  /// Shared token-invite mechanism (see src/common/utils/token-invite.ts).
  inviteToken    String    @unique
  tokenExpiresAt DateTime
  passwordHash   String?
  revokedAt      DateTime?

  /// The invitee's qualification classification snapshotted AT INVITE TIME —
  /// the award decision reflects what was known then, not later changes.
  qualificationStatusSnapshot String

  quoteStatus   RfqQuoteStatus @default(INVITED)
  submittedAt   DateTime?
  declineReason String?        @db.Text

  quote         RfqQuote?
  /// Back-relation for Rfq.awardedInvitee (named to disambiguate).
  awardedForRfq Rfq?      @relation("RfqAwardedInvitee")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([rfqId])
  @@index([supplierId])
  @@index([vendorId])
  @@map("rfq_invitees")
}

model RfqQuote {
  id        String     @id @default(uuid())
  inviteeId String     @unique
  invitee   RfqInvitee @relation(fields: [inviteeId], references: [id], onDelete: Cascade)

  quotedLeadTimeDays  Int?
  paymentTermsOffered String?
  validityDays        Int?
  notes               String? @db.Text
  /// R2 object refs, reusing the vault storage guardrails.
  attachmentFileKeys  Json?
  /// Snapshot of the summed line totals at submission.
  totalQuotedValue    Decimal @default(0) @db.Decimal(18, 2)

  /// Save-and-resume: a quote row exists in draft until submittedAt is set on
  /// the parent invitee. Lines are upserted on each save.
  lines RfqQuoteLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("rfq_quotes")
}

model RfqQuoteLine {
  id        String   @id @default(uuid())
  quoteId   String
  quote     RfqQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  rfqLineId String
  rfqLine   RfqLine  @relation(fields: [rfqLineId], references: [id], onDelete: Restrict)

  unitPrice            Decimal @db.Decimal(18, 2)
  lineTotal            Decimal @db.Decimal(18, 2)
  deliveryLeadTimeDays Int?
  remarks              String? @db.Text

  @@unique([quoteId, rfqLineId])
  @@index([rfqLineId])
  @@map("rfq_quote_lines")
}
