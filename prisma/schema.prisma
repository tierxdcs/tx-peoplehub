// ── Stores Phase 2: Goods Receipt + QC Inspection Gate + NCR ─────────────
//
// The QC gate is the defining rule of this phase: creating/submitting a GRN
// produces ZERO stock movement. A GRN sits in PENDING_QC until a QC inspector
// records accepted/rejected quantities per line. ONLY the accepted quantity
// then generates a STOCK_IN (a positive ON_HAND StockAdjustment + StockBalance
// increment) in the finalize transaction. Rejected quantity never enters stock
// and instead spawns a NonConformanceReport. "Previously received" and the
// PO's PARTIALLY/FULLY_RECEIVED status are computed on read from accepted
// quantities — never stored.

enum GoodsReceiptNoteStatus {
  DRAFT
  PENDING_QC
  QC_PASSED
  QC_PARTIAL
  QC_FAILED
  CANCELLED
}

/// Condition of the packaging as received at the GRN gate (spec §3.1).
enum PackingCondition {
  GOOD
  DAMAGED
  PARTIALLY_DAMAGED
}

enum NonConformanceReportStatus {
  OPEN
  DISPOSITIONED
  CLOSED
}

/// How a QC rejection is dispositioned once an NCR is raised.
enum NcrDispositionType {
  RETURN_TO_SUPPLIER
  SCRAP
  USE_AS_IS
  REWORK
}

/// A receipt of goods against a Purchase Order. Submitting it moves DRAFT →
/// PENDING_QC with NO stock impact. QC finalization is a separate step.
model GoodsReceiptNote {
  id        String                 @id @default(uuid())
  /// GRN-YYYY-#### via the shared year-prefixed sequence (SalesNumberingService).
  grnNumber String                 @unique
  status    GoodsReceiptNoteStatus @default(DRAFT)

  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Restrict)

  receivedById String
  receivedBy   Employee @relation("GrnReceivedBy", fields: [receivedById], references: [id], onDelete: Restrict)
  receivedDate DateTime @default(now())

  /// Set when a QC inspector finalizes inspection.
  inspectedById String?
  inspectedBy   Employee? @relation("GrnInspectedBy", fields: [inspectedById], references: [id], onDelete: SetNull)
  inspectedAt   DateTime?

  /// Logistics / receiving details captured at the gate (spec §3.1). All
  /// nullable — older GRNs (and DRAFTs) may leave any of them unset.
  vendorDeliveryChallanNumber String?
  deliveryChallanDate         DateTime?
  vehicleOrAwbNumber          String?
  driverOrCourier             String?
  totalPackagesReceived       Int?
  packingCondition            PackingCondition?

  /// Stores supervisor who signed off the receipt (distinct from receivedBy).
  supervisorSignOffId String?
  supervisorSignOff   Employee? @relation("GrnSupervisorSignOff", fields: [supervisorSignOffId], references: [id], onDelete: SetNull)

  /// Free-text receiving remarks (spec's receivingRemarks). Structured logistics
  /// data lives in the dedicated columns above, NOT here.
  notes String? @db.Text

  lines GoodsReceiptNoteLine[]
  ncrs  NonConformanceReport[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([purchaseOrderId])
  @@map("goods_receipt_notes")
}

/// One received line. acceptedQuantity/rejectedQuantity are null until QC
/// finalization; after finalization accepted + rejected == receivedQuantity.
model GoodsReceiptNoteLine {
  id    String           @id @default(uuid())
  grnId String
  grn   GoodsReceiptNote @relation(fields: [grnId], references: [id], onDelete: Cascade)

  purchaseOrderLineId String
  purchaseOrderLine   PurchaseOrderLine @relation(fields: [purchaseOrderLineId], references: [id], onDelete: Restrict)

  itemId String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Restrict)

  /// Where accepted stock lands on QC pass.
  storeLocationId String
  storeLocation   StoreLocation @relation(fields: [storeLocationId], references: [id], onDelete: Restrict)

  receivedQuantity Decimal  @db.Decimal(14, 4)
  acceptedQuantity Decimal? @db.Decimal(14, 4)
  rejectedQuantity Decimal? @db.Decimal(14, 4)
  rejectionReason  String?  @db.Text
  sequence         Int      @default(0)

  /// At most one NCR per rejected line.
  ncr            NonConformanceReport?
  apInvoiceLines AccountsPayableInvoiceLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([grnId])
  @@index([purchaseOrderLineId])
  @@index([itemId])
  @@map("goods_receipt_note_lines")
}

/// Raised automatically whenever QC rejects any quantity on a GRN line. Carries
/// its own disposition workflow (return / scrap / use-as-is / rework).
model NonConformanceReport {
  id        String                     @id @default(uuid())
  /// NCR-YYYY-#### via the shared year-prefixed sequence.
  ncrNumber String                     @unique
  status    NonConformanceReportStatus @default(OPEN)

  grnId String
  grn   GoodsReceiptNote @relation(fields: [grnId], references: [id], onDelete: Cascade)

  grnLineId String               @unique
  grnLine   GoodsReceiptNoteLine @relation(fields: [grnLineId], references: [id], onDelete: Cascade)

  itemId String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Restrict)

  rejectedQuantity Decimal @db.Decimal(14, 4)
  rejectionReason  String? @db.Text

  disposition      NcrDispositionType?
  dispositionNotes String?             @db.Text

  raisedById String
  raisedBy   Employee @relation("NcrRaisedBy", fields: [raisedById], references: [id], onDelete: Restrict)

  dispositionedById String?
  dispositionedBy   Employee? @relation("NcrDispositionedBy", fields: [dispositionedById], references: [id], onDelete: SetNull)
  dispositionedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([grnId])
  @@map("non_conformance_reports")
}

// ── Finance Phase 3: Accounts Payable and Payments ─────────────────────

