  documentNumber     String
  partyName          String
  currencyCode       String           @db.VarChar(3)
  foreignOutstanding Decimal          @db.Decimal(18, 2)
  originalRate       Decimal          @db.Decimal(18, 6)
  closingRate        Decimal          @db.Decimal(18, 6)
  carryingAmountInr  Decimal          @db.Decimal(18, 2)
  revaluedAmountInr  Decimal          @db.Decimal(18, 2)
  gainLossInr        Decimal          @db.Decimal(18, 2)

  @@unique([runId, side, documentId])
  @@index([runId, currencyCode])
  @@map("fx_revaluation_lines")
}

model FinanceAdvanceApplication {
  id                String             @id @default(uuid())
  applicationNumber String             @unique
  side              FinanceAdvanceSide
  sourceId          String
  targetInvoiceId   String
  applicationDate   DateTime
  currencyCode      String             @db.VarChar(3)
  amount            Decimal            @db.Decimal(18, 2)
  exchangeRateToInr Decimal            @default(1) @db.Decimal(18, 6)
  journalEntryId    String             @unique
  createdById       String
  approvedById      String
  createdAt         DateTime           @default(now())

  @@index([side, sourceId])
  @@index([side, targetInvoiceId])
  @@map("finance_advance_applications")
}

// ── Stores Phase 3: Material Indent + Issue ──────────────────────────────
//
// Production raises a MaterialIndent for stock; Stores fulfils it with one or
// more MaterialIssueNotes. Each issue generates a STOCK_OUT (a negative ON_HAND
// StockAdjustment + StockBalance decrement) through the SAME ledger path as
// the rest of inventory, and — crucially — reuses the existing availability
// rule (available = onHand − reserved − blocked) so material reserved for one
// project (via the BOM/Kickoff StockReservation system) can never be issued to
// a different one. Short issues are allowed; the indent's status is DERIVED
// from cumulative issued vs requested, never stored/set by hand.

enum MaterialIndentStatus {
  OPEN
  PARTIALLY_ISSUED
  FULLY_ISSUED
  CANCELLED
}

/// Production's request for material against stock. Optionally tied to a
/// project kickoff, which is what lets the issue honour that project's own
/// reservations (and refuse to consume another project's).
model MaterialIndent {
  id           String               @id @default(uuid())
  /// IND-YYYY-#### via the shared year-prefixed sequence (SalesNumberingService).
  indentNumber String               @unique
  status       MaterialIndentStatus @default(OPEN)

  /// Optional link to the project this material is for. Drives reservation-aware
  /// issuing: an issue against a kickoff-linked indent may draw on that
  /// kickoff's reservations; a null link may only draw on unreserved stock.
  projectKickoffId String?
  projectKickoff   ProjectKickoff? @relation(fields: [projectKickoffId], references: [id], onDelete: SetNull)

  itemId String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Restrict)

  requestedQuantity Decimal   @db.Decimal(14, 4)
  requiredByDate    DateTime?
  notes             String?   @db.Text

  raisedById String
  raisedBy   Employee @relation("MaterialIndentRaisedBy", fields: [raisedById], references: [id], onDelete: Restrict)

  issueNotes MaterialIssueNote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([itemId])
  @@index([projectKickoffId])
  @@map("material_indents")
}

/// A Stores issue of material against an indent. Each note issues a quantity
/// from a specific store/bin location, generating a STOCK_OUT. Cumulative
/// issued quantity across notes drives the parent indent's derived status.
model MaterialIssueNote {
  id        String @id @default(uuid())
  /// MIN-YYYY-#### via the shared year-prefixed sequence.
  minNumber String @unique

  materialIndentId String
  materialIndent   MaterialIndent @relation(fields: [materialIndentId], references: [id], onDelete: Restrict)

  itemId String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Restrict)

  storeLocationId String
  storeLocation   StoreLocation @relation(fields: [storeLocationId], references: [id], onDelete: Restrict)

  issuedQuantity Decimal @db.Decimal(14, 4)
  /// Free-text bin location within the store (matches the reference ERP).
  binLocation    String?
  notes          String? @db.Text

  issuedById String
  issuedBy   Employee @relation("MaterialIssueIssuedBy", fields: [issuedById], references: [id], onDelete: Restrict)
  issuedAt   DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([materialIndentId])
  @@index([itemId])
  @@map("material_issue_notes")
}
