  generatedAt   DateTime                  @default(now())
  exceptions    ReconciliationException[]

  @@map("close_reconciliation_runs")
}

model ReconciliationException {
  id             String                        @id @default(uuid())
  runId          String
  run            CloseReconciliationRun        @relation(fields: [runId], references: [id], onDelete: Cascade)
  exceptionKey   String
  controlType    String
  title          String
  severity       ReconciliationSeverity
  status         ReconciliationExceptionStatus @default(OPEN)
  ledgerAmount   Decimal?                      @db.Decimal(18, 2)
  sourceAmount   Decimal?                      @db.Decimal(18, 2)
