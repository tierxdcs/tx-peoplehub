// Prisma schema for tx-peoplehub ERP foundation.
// Single-company (no tenant scoping). Add ERP domain models as new modules.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// RBAC role. SUPER_ADMIN manages ADMIN accounts; ADMIN manages employee
/// identity/access only (no operational data visibility); MANAGER sees their
/// own vertical plus their downstream reports; EMPLOYEE sees only their own.
enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  EMPLOYEE
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

/// Login/system-access lifecycle, independent of the employment `status`
/// soft-delete above. PENDING_ACCESS employees exist as HR records but
/// cannot authenticate.
enum AccessStatus {
  PENDING_ACCESS
  ACTIVE
  INACTIVE
}

enum EmploymentType {
  FULL_TIME_PERMANENT
  CONTRACT
  INTERN
  PART_TIME
}

/// Fixed set of signature-style fonts for the internal e-signature display
/// layer. Kept in sync with the frontend's loaded Google Fonts.
enum SignatureFont {
  DANCING_SCRIPT
  CAVEAT
  PACIFICO
  GREAT_VIBES
}

// ---- Kanban module ----

enum KanbanBoardStatus {
  ACTIVE
  ARCHIVED
}

/// Card lifecycle — ARCHIVED is the soft-delete state.
enum KanbanCardStatus {
  ACTIVE
  ARCHIVED
}

/// Allowed sprint lengths (weeks). endDate is computed from startDate + weeks.
enum KanbanSprintDuration {
  ONE_WEEK
  TWO_WEEKS
  THREE_WEEKS
  FOUR_WEEKS
}

/// Generic in-app notification type. Distinct from the pending-approvals
/// counters (which represent things needing ACTION); these are things worth
/// KNOWING. Extensible — new types can be added without a redesign.
enum NotificationType {
  CARD_ASSIGNED
  CARD_COMMENTED
  CARD_UPDATED
  VENDOR_QUESTIONNAIRE_SUBMITTED
  SUPPLIER_QUESTIONNAIRE_SUBMITTED
  BOM_SUBMITTED
  BOM_APPROVED
  BOM_REJECTED
}

enum LeaveAccrualType {
  FIXED_ANNUAL
  MONTHLY_ACCRUAL
  UNTRACKED
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum StatutoryConfigType {
  PF
  ESI
  PROFESSIONAL_TAX
  TDS_SLAB
  STANDARD_DEDUCTION
}

enum PayrollRunStatus {
  DRAFT
  PROCESSING
  COMPLETED
  LOCKED
}

enum PayslipStatus {
  GENERATED
  PAID
}

// ---- Sales module ----

enum CustomerStatus {
  ACTIVE
  INACTIVE
}

enum LeadPriority {
  HIGH
  MEDIUM
  LOW
}

enum LeadSource {
  REFERRAL
  WEBSITE
  COLD_OUTREACH
  EVENT
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  DISQUALIFIED
  CONVERTED
}

enum OpportunityStage {
  PROSPECTING
  QUALIFICATION
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum BidStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  SENT
  ACCEPTED
  EXPIRED
}

enum OrderStatus {
  CONFIRMED
  IN_PRODUCTION
  READY_TO_SHIP
  SHIPPED
  DELIVERED
  CANCELLED
}

/// Type of a configurable Bid/No-Bid assessment question. SELECT uses the
/// question's `options` JSON; the others ignore it.
enum BidAssessmentQuestionType {
  BOOLEAN
  TEXT
  SCALE
  SELECT
}

/// Lifecycle of a Bid/No-Bid decision assessment. A rejected assessment is
/// never reopened — the rep submits a fresh record (preserving history), and
/// only the most-recent assessment's status gates Bid creation.
enum BidAssessmentStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

/// Intra-state (CGST+SGST) vs inter-state (IGST). This phase applies one
/// active rate per bid/order; see TaxConfig.
enum SalesTaxType {
  CGST_SGST
  IGST
}

/// Per-line-item delivery classification, assigned at project kickoff.
/// NPD = new product development; IN_HOUSE = manufactured internally;
/// VENDOR = outsourced/procured (captures a free-text vendor placeholder).
enum OrderLineDeliveryType {
  NPD
  IN_HOUSE
  VENDOR
}

// ---- Vault (document management) module ----

/// PERSONAL = auto-provisioned per employee at onboarding (one each, private,
/// undeletable). DEFAULT = SUPER_ADMIN-created org folders. CUSTOM =
/// Manager-created team folders.
enum VaultFolderType {
  PERSONAL
  DEFAULT
  CUSTOM
}

enum VaultVisibilityScope {
  PRIVATE
  TEAM
  VERTICAL
  COMPANY_WIDE
}

enum VaultFolderStatus {
  ACTIVE
  ARCHIVED
}

/// Who an explicit VaultFolderPermission grant targets. granteeId is
/// polymorphic: an Employee id, a Vertical id, or a Role name respectively.
enum VaultGranteeType {
  EMPLOYEE
  VERTICAL
  ROLE
}

/// A VaultFile row is created before the browser has finished its direct
/// upload to R2 (PENDING); confirm-upload flips it ACTIVE. DELETED is the
/// soft-delete state (whole-file only).
enum VaultFileStatus {
  PENDING
  ACTIVE
  DELETED
}

/// Preview-conversion lifecycle for a version. Everything stays
/// NOT_APPLICABLE in Phase 2 — the Gotenberg pipeline that sets
/// PENDING/READY/FAILED is Phase 4.
enum PreviewStatus {
  NOT_APPLICABLE
  PENDING
  READY
  FAILED
}

/// What an internal share targets. resourceId is polymorphic (a VaultFile id
/// or a VaultFolder id per this type), so no DB FK on it.
enum VaultShareResourceType {
  FILE
  FOLDER
}

/// Granted access level for an internal share. VIEW = read; EDIT = read+write.
/// Additive only — a share never reduces access the recipient already has.
enum VaultSharePermission {
  VIEW
  EDIT
}

/// Business vertical (Sales, HR, Production, ...). A table, not an enum, so
/// new verticals can be added by the business without a code deploy.
model Vertical {
  id           String        @id @default(uuid())
  name         String        @unique
  code         String        @unique
  isActive     Boolean       @default(true)
  employees    Employee[]
  vaultFolders VaultFolder[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("verticals")
}

/// Internal employee. Authenticates via email + bcrypt password hash.
/// verticalId/reportingManagerId are required for every role except
/// SUPER_ADMIN — enforced in the service layer, not expressible as a plain
/// NOT NULL constraint here. role/passwordHash are nullable to support
/// two-step HR onboarding: HR creates the personnel record first
/// (accessStatus = PENDING_ACCESS, no role/login yet); Admin grants system
/// access afterward (assigns role, sets password, activates login).
model Employee {
  id                 String         @id @default(uuid())
  employeeId         String         @unique
  firstName          String
  lastName           String
  email              String         @unique
  passwordHash       String?
  verticalId         String?
  vertical           Vertical?      @relation(fields: [verticalId], references: [id], onDelete: Restrict)
  role               Role?
  reportingManagerId String?
  reportingManager   Employee?      @relation("ReportingChain", fields: [reportingManagerId], references: [id], onDelete: SetNull)
  reports            Employee[]     @relation("ReportingChain")
  status             EmployeeStatus @default(ACTIVE)
  deactivatedAt      DateTime?
  accessStatus       AccessStatus   @default(PENDING_ACCESS)

  /// Bumped on an admin force-reset (and on a self-service change) to invalidate
  /// every previously-issued token: the access/refresh JWT carries the
  /// tokenVersion it was signed with, and the JWT strategy rejects any token
  /// whose version is behind the current one — logging out all other sessions.
  tokenVersion       Int     @default(0)
  /// Set true by an admin force-reset; the mustChangePassword guard then blocks
  /// every request except changing the password (and logout) until the user
  /// sets a new one, which clears this flag.
  mustChangePassword Boolean @default(false)

  /// Sales Head designation (not a Role). Exactly one active holder at a
  /// time — enforced at the service layer (designate unsets the previous
  /// holder in one transaction), not by a DB constraint.
  isSalesHead Boolean @default(false)

  /// Scrum Master capability (not a Role). Company-wide — a Scrum Master can
  /// create Kanban boards and add members from any vertical. Unlike Sales Head,
  /// MULTIPLE holders are allowed. SUPER_ADMIN is always a Scrum Master
  /// regardless of this flag (override in the access layer).
  isScrumMaster Boolean @default(false)

  /// Project Manager capability (not a Role). Runs project kickoffs and manages
  /// action items. MULTIPLE holders allowed; SUPER_ADMIN is always a PM
  /// regardless of this flag. Deliberately INDEPENDENT of isScrumMaster — a PM
  /// gets a working project board via privileged internal provisioning, so they
  /// don't need Scrum Master rights to run kickoffs.
  isProjectManager Boolean @default(false)

  /// Internal Auditor capability (not a Role). Conducts/finalizes vendor
  /// qualification audits. MULTIPLE holders allowed; SUPER_ADMIN is always an
  /// auditor regardless of this flag. MANAGER-or-above only, same pattern.
  isInternalAuditor Boolean @default(false)

  /// R&D Head capability (not a Role). Grants TECHNICAL BOM approval authority:
  /// approve/reject submitted Bills of Materials, and create/update Item Master
  /// technical data. MULTIPLE holders allowed. The employee must belong to the
  /// R&D vertical (code 'RND') — enforced at designation time (unlike the other
  /// flags, whose vertical checks live in the consuming access layer). NOTE:
  /// SUPER_ADMIN can manage this designation but does NOT automatically receive
  /// BOM approval authority — only a real isRdHead holder may approve a BOM.
  isRdHead Boolean @default(false)

  /// Finance/Accounts Head capability (not a Role). Exactly one active holder
  /// at a time, assigned only by SUPER_ADMIN. Accounts-vertical staff prepare
  /// finance records; only this holder may approve/post them.
  isAccountsHead Boolean @default(false)

  /// QC Inspector capability (not a Role). Inspects incoming goods (GRN QC gate)
  /// — deliberately SEPARATE from isInternalAuditor (supplier auditing vs.
  /// incoming-goods inspection are different people). MULTIPLE holders allowed;
  /// SUPER_ADMIN is always a QC inspector regardless of this flag; MANAGER-or-
  /// above only, same pattern as Internal Auditor.
  isQcInspector Boolean @default(false)

  /// Internal e-signature (a display layer, NOT a legally-binding e-sign).
  /// Self-service typed text rendered in a chosen signature-style font;
  /// snapshotted onto approval records at approval time.
  signatureText String?
  signatureFont SignatureFont?

  // HR onboarding fields — populated by POST /employees/onboard.
  dateOfBirth              DateTime?
  gender                   String?
  personalEmail            String?
  mobile                   String?
  designation              String?
  employmentType           EmploymentType?
  dateOfJoining            DateTime?
  workLocation             String?
  officialEmail            String?         @unique
  emergencyContactName     String?
  emergencyContactRelation String?
  emergencyContactPhone    String?

  statutoryInfo EmployeeStatutoryInfo?
  bankDetails   EmployeeBankDetails?

  salaryStructures        SalaryStructure[] @relation("SalaryStructureOwner")
  salaryStructuresEntered SalaryStructure[] @relation("SalaryStructureEnteredBy")
  payrollRunsInitiated    PayrollRun[]
  payslips                Payslip[]

  leaveBalances          LeaveBalance[]
  leaveRequestsSubmitted LeaveRequest[] @relation("LeaveRequester")
  leaveRequestsApproved  LeaveRequest[] @relation("LeaveApprover")
  attendanceRecords      Attendance[]

  // Sales ownership / authorship back-relations.
  customersOwned     Customer[]    @relation("CustomerOwner")
  leadsOwned         Lead[]        @relation("LeadOwner")
  opportunitiesOwned Opportunity[] @relation("OpportunityOwner")
  bidsCreated        Bid[]         @relation("BidCreator")
  bidsApproved       Bid[]         @relation("BidApprover")
  ordersOwned        Order[]       @relation("OrderOwner")

  bidAssessmentsSubmitted BidDecisionAssessment[] @relation("BidAssessmentSubmitter")
  bidAssessmentsReviewed  BidDecisionAssessment[] @relation("BidAssessmentReviewer")

  ocSheetsCreated        OrderConfirmationSheet[] @relation("OcCreator")
  ocSignedCopiesUploaded OrderConfirmationSheet[] @relation("OcSignedCopyUploader")
  ocSheetsInternalSigned OrderConfirmationSheet[] @relation("OcInternalSigner")

  vaultFoldersOwned       VaultFolder[]            @relation("VaultFolderOwner")
  vaultPermissionsGranted VaultFolderPermission[]  @relation("VaultPermissionGrantor")
  vaultFilesUploaded      VaultFile[]              @relation("VaultFileUploader")
  vaultVersionsUploaded   VaultFileVersion[]       @relation("VaultVersionUploader")
  vaultSharesReceived     VaultInternalShare[]     @relation("VaultShareRecipient")
  vaultSharesGranted      VaultInternalShare[]     @relation("VaultShareGrantor")
  vaultExternalLinks      VaultExternalShareLink[] @relation("VaultExternalShareCreator")

  // Kanban back-relations.
  kanbanBoardsCreated    KanbanBoard[]        @relation("KanbanBoardCreator")
  kanbanMemberships      KanbanBoardMember[]  @relation("KanbanBoardMember")
  kanbanMembersAdded     KanbanBoardMember[]  @relation("KanbanBoardMemberAddedBy")
  kanbanListsCreated     KanbanList[]         @relation("KanbanListCreator")
  kanbanSprintsCreated   KanbanSprint[]       @relation("KanbanSprintCreator")
  kanbanCardsCreated     KanbanCard[]         @relation("KanbanCardCreator")
  kanbanCardsAssigned    KanbanCard[]         @relation("KanbanCardAssignee")
  kanbanCommentsAuthored KanbanCardComment[]  @relation("KanbanCommentAuthor")
  kanbanActivityActed    KanbanCardActivity[] @relation("KanbanActivityActor")
  notifications          Notification[]       @relation("NotificationRecipient")

  // Project Kickoff back-relations.
  projectKickoffsCreated  ProjectKickoff[]    @relation("KickoffCreator")
  kickoffAttendances      KickoffAttendee[]   @relation("KickoffAttendeeEmployee")
  kickoffMilestonesOwned  KickoffMilestone[]  @relation("KickoffMilestoneOwner")
  kickoffActionItemsOwned KickoffActionItem[] @relation("KickoffActionItemOwner")
  kickoffRisksOwned       KickoffRisk[]       @relation("KickoffRiskOwner")

  // Vendor Qualification (SCM) back-relations.
  vendorsCreated        Vendor[]                    @relation("VendorCreator")
  vendorInvitesCreated  VendorQuestionnaireInvite[] @relation("VendorInviteCreator")
  vendorAuditsConducted VendorAudit[]               @relation("VendorAuditor")

  // Supplier Qualification (SCM raw-materials) back-relations.
  suppliersCreated        Supplier[]                    @relation("SupplierCreator")
  supplierInvitesCreated  SupplierQuestionnaireInvite[] @relation("SupplierInviteCreator")
  supplierAuditsConducted SupplierAudit[]               @relation("SupplierAuditor")

  // BOM / Item Master / Inventory back-relations.
  bomsCreated       Bom[]              @relation("BomCreator")
  bomsSubmitted     Bom[]              @relation("BomSubmitter")
  bomsApproved      Bom[]              @relation("BomApprover")
  bomsRejected      Bom[]              @relation("BomRejecter")
  bomEventsActed    BomEvent[]         @relation("BomEventActor")
  itemSupplierLinks ItemSupplier[]     @relation("ItemSupplierLinkedBy")
  stockAdjustments  StockAdjustment[]  @relation("StockAdjustmentActor")
  reservationsMade  StockReservation[] @relation("ReservationCreator")

  // Finance & Accounts back-relations.
  fiscalYearsCreated       FiscalYear[]             @relation("FiscalYearCreator")
  accountsCreated          LedgerAccount[]          @relation("LedgerAccountCreator")
  costCentersCreated       CostCenter[]             @relation("CostCenterCreator")
  exchangeRatesCreated     ExchangeRate[]           @relation("ExchangeRateCreator")
  journalsCreated          JournalEntry[]           @relation("JournalCreator")
  journalsSubmitted        JournalEntry[]           @relation("JournalSubmitter")
  journalsApproved         JournalEntry[]           @relation("JournalApprover")
  journalsRejected         JournalEntry[]           @relation("JournalRejecter")
  journalsReversed         JournalEntry[]           @relation("JournalReverser")
  billingMilestonesCreated BillingMilestone[]       @relation("BillingMilestoneCreator")
  salesInvoicesCreated     SalesInvoice[]           @relation("SalesInvoiceCreator")
  salesInvoicesSubmitted   SalesInvoice[]           @relation("SalesInvoiceSubmitter")
  salesInvoicesApproved    SalesInvoice[]           @relation("SalesInvoiceApprover")
  receiptsCreated          CustomerReceipt[]        @relation("CustomerReceiptCreator")
  receiptsSubmitted        CustomerReceipt[]        @relation("CustomerReceiptSubmitter")
  receiptsApproved         CustomerReceipt[]        @relation("CustomerReceiptApprover")
  apInvoicesCreated        AccountsPayableInvoice[] @relation("ApInvoiceCreator")
  apInvoicesSubmitted      AccountsPayableInvoice[] @relation("ApInvoiceSubmitter")
  apInvoicesApproved       AccountsPayableInvoice[] @relation("ApInvoiceApprover")
  apPaymentsCreated        AccountsPayablePayment[] @relation("ApPaymentCreator")
  apPaymentsSubmitted      AccountsPayablePayment[] @relation("ApPaymentSubmitter")
  apPaymentsApproved       AccountsPayablePayment[] @relation("ApPaymentApprover")
  financeNotesCreated      FinanceAdjustmentNote[]  @relation("FinanceNoteCreator")
  financeNotesSubmitted    FinanceAdjustmentNote[]  @relation("FinanceNoteSubmitter")
  financeNotesApproved     FinanceAdjustmentNote[]  @relation("FinanceNoteApprover")
  periodClosesPrepared     PeriodClose[]            @relation("PeriodClosePreparer")
  periodClosesApproved     PeriodClose[]            @relation("PeriodCloseApprover")
  tdsSectionsCreated       TdsSection[]             @relation("TdsSectionCreator")
  itcReconciliations       AccountsPayableInvoice[] @relation("ApInvoiceItcReconciler")
  bankAccountsCreated      FinanceBankAccount[]     @relation("BankAccountCreator")
  bankStatementsImported   BankStatement[]          @relation("BankStatementImporter")
  bankStatementsSubmitted  BankStatement[]          @relation("BankStatementSubmitter")
  bankStatementsApproved   BankStatement[]          @relation("BankStatementApprover")
  bankMatchesConfirmed     BankTransactionMatch[]   @relation("BankMatchConfirmer")
  budgetsCreated           FinanceBudget[]          @relation("BudgetCreator")
  budgetsSubmitted         FinanceBudget[]          @relation("BudgetSubmitter")
  budgetsApproved          FinanceBudget[]          @relation("BudgetApprover")
  fixedAssetsCreated       FixedAsset[]             @relation("FixedAssetCreator")
  fixedAssetsApproved      FixedAsset[]             @relation("FixedAssetApprover")
  financeSchedulesCreated  FinanceSchedule[]        @relation("FinanceScheduleCreator")
  financeSchedulesApproved FinanceSchedule[]        @relation("FinanceScheduleApprover")
  reservationsCancelled    StockReservation[]       @relation("ReservationCanceller")

  // Purchasing (Stores) back-relations.
  purchaseOrdersCreated PurchaseOrder[]        @relation("PurchaseOrderCreator")
  grnsReceived          GoodsReceiptNote[]     @relation("GrnReceivedBy")
  grnsInspected         GoodsReceiptNote[]     @relation("GrnInspectedBy")
  grnsSupervised        GoodsReceiptNote[]     @relation("GrnSupervisorSignOff")
  ncrsRaised            NonConformanceReport[] @relation("NcrRaisedBy")
  ncrsDispositioned     NonConformanceReport[] @relation("NcrDispositionedBy")
  materialIndentsRaised MaterialIndent[]       @relation("MaterialIndentRaisedBy")
  materialIssuesIssued  MaterialIssueNote[]    @relation("MaterialIssueIssuedBy")

  auditLogs AuditLog[] @relation("AuditActor")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([verticalId])
  @@index([reportingManagerId])
  @@index([accessStatus])
  @@map("employees")
}

/// Effective-dated salary breakdown — replaces the old single-row
/// EmployeeCompensation. Multiple rows per employee over time; the
/// "current" structure is whichever row has the latest effectiveFrom <=
/// today (see SalaryStructuresService.getCurrent). History is append-only
/// — a change creates a new row rather than editing a prior one, so past
/// payroll runs remain reproducible. Decimal, never Float — these are
/// monetary amounts. Restricted to ADMIN/SUPER_ADMIN reads regardless of
/// who entered them (same access rule as the table it replaces).
model SalaryStructure {
  id               String    @id @default(uuid())
  employeeId       String
  employee         Employee  @relation("SalaryStructureOwner", fields: [employeeId], references: [id], onDelete: Cascade)
  effectiveFrom    DateTime
  basic            Decimal   @db.Decimal(14, 2)
  hra              Decimal   @db.Decimal(14, 2)
  specialAllowance Decimal   @default(0) @db.Decimal(14, 2)
  otherAllowances  Decimal?  @db.Decimal(14, 2)
  ctcAnnual        Decimal   @db.Decimal(14, 2)
  createdById      String?
  createdBy        Employee? @relation("SalaryStructureEnteredBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([employeeId, effectiveFrom])
  @@map("salary_structures")
}

/// Government IDs. panNumber/pfAccountNumber/esicNumber are stored as
/// application-layer ciphertext (AES-256-GCM, see core/crypto) — never
/// plaintext. aadhaarLast4 stores only the last 4 digits, never the full
/// number, so it isn't sensitive enough to need encryption.
model EmployeeStatutoryInfo {
  id              String   @id @default(uuid())
  employeeId      String   @unique
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  panNumber       String
  aadhaarLast4    String
  pfAccountNumber String
  esicNumber      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("employee_statutory_info")
}

/// bankAccountNumber is stored as application-layer ciphertext (see
/// core/crypto) — never plaintext.
model EmployeeBankDetails {
  id                String   @id @default(uuid())
  employeeId        String   @unique
  employee          Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  bankAccountNumber String
  ifscCode          String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("employee_bank_details")
}

/// Leave type (Casual, Sick, Earned, Unpaid, ...). A table, not an enum, so
/// new leave types can be added by the business without a code deploy —
/// same philosophy as Vertical.
model LeaveType {
  id              String           @id @default(uuid())
  code            String           @unique
  name            String
  accrualType     LeaveAccrualType
  annualQuota     Decimal?         @db.Decimal(5, 1)
  carryForwardCap Decimal?         @db.Decimal(5, 1)
  isActive        Boolean          @default(true)
  balances        LeaveBalance[]
  requests        LeaveRequest[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@map("leave_types")
}

/// Per-employee, per-year balance for a tracked leave type. `remaining` is
/// deliberately not stored (= allocated + carriedForward - used, computed
/// in the entity layer) to avoid drift — same rationale as other computed
/// fields in this schema.
model LeaveBalance {
  id               String    @id @default(uuid())
  employeeId       String
  employee         Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveTypeId      String
  leaveType        LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Restrict)
  year             Int
  allocated        Decimal   @default(0) @db.Decimal(5, 1)
  used             Decimal   @default(0) @db.Decimal(5, 1)
  carriedForward   Decimal   @default(0) @db.Decimal(5, 1)
  /// "YYYY-MM" of the last month this balance was credited by the EL
  /// accrual job — idempotency guard against double-crediting on rerun.
  lastAccrualMonth String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([employeeId, leaveTypeId, year])
  @@map("leave_balances")
}

/// A single leave request, routed for approval through the requester's
/// existing reportingManagerId hierarchy (no separate approver-assignment
/// model needed).
model LeaveRequest {
  id                            String             @id @default(uuid())
  employeeId                    String
  employee                      Employee           @relation("LeaveRequester", fields: [employeeId], references: [id], onDelete: Cascade)
  leaveTypeId                   String
  leaveType                     LeaveType          @relation(fields: [leaveTypeId], references: [id], onDelete: Restrict)
  startDate                     DateTime
  endDate                       DateTime
  numberOfDays                  Decimal            @db.Decimal(4, 1)
  reason                        String
  status                        LeaveRequestStatus @default(PENDING)
  approverId                    String?
  approver                      Employee?          @relation("LeaveApprover", fields: [approverId], references: [id], onDelete: SetNull)
  approvedAt                    DateTime?
  approverComments              String?
  /// Snapshot of the approving manager's e-signature at approval time.
  approverSignatureTextSnapshot String?
  approverSignatureFontSnapshot SignatureFont?
  createdAt                     DateTime           @default(now())
  updatedAt                     DateTime           @updatedAt

  @@index([employeeId])
  @@index([status])
  @@index([startDate, endDate])
  @@map("leave_requests")
}

/// Daily attendance record. `status` (PRESENT/ABSENT/ON_LEAVE/HALF_DAY) is
/// deliberately not a column — it's derived on read from
/// checkInTime/checkOutTime plus approved-leave lookups, so there is one
/// source of truth for how status is computed (Admin corrections set times
/// directly, never status).
model Attendance {
  id           String    @id @default(uuid())
  employeeId   String
  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date         DateTime
  checkInTime  DateTime?
  checkOutTime DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([employeeId, date])
  @@map("attendance")
}

/// Versioned, effective-dated statutory rate/threshold configuration
/// (PF, ESI, Professional Tax, TDS slabs, standard deduction). Every rate
/// used in a payroll computation must come from a row here, never be
/// hardcoded in service logic — India's wage-definition and tax rules
/// change independently of this codebase's release cycle, and a payroll
/// run must reproduce the exact calculation that was correct on its own
/// period even after rates change going forward.
///
/// DELIBERATELY NOT SEEDED. This table starts empty and must stay empty
/// until a CA / payroll-compliance specialist has verified real rates
/// against primary sources (EPFO/ESIC circulars, Income Tax Department
/// notifications, state Professional Tax departments) — see the Payroll
/// module's README. PayrollRunsService.processRun() refuses to run
/// against missing config rather than silently computing zero deductions.
model StatutoryConfig {
  id            String              @id @default(uuid())
  configType    StatutoryConfigType
  /// Only meaningful for PROFESSIONAL_TAX (varies by state).
  state         String?
  effectiveFrom DateTime
  effectiveTo   DateTime?
  /// Shape varies by configType — e.g. PF: {employeeRate, employerRate,
  /// epsRate, wageCeiling, adminCharge}; TDS_SLAB: [{slabFrom, slabTo,
  /// rate}, ...]. Validated per-configType in StatutoryConfigService, not
  /// at the schema level (Prisma has no discriminated-JSON support).
  configData    Json
  /// Where this rate came from / who approved it — required for audit
  /// traceability, not optional metadata.
  sourceNote    String
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([configType, state, effectiveFrom])
  @@map("statutory_configs")
}

/// One payroll period for the whole company. Lifecycle: DRAFT (created,
/// no payslips yet) -> PROCESSING (computation in flight) -> COMPLETED
/// (payslips generated) -> LOCKED (immutable; corrections require a new
/// period's adjustment, never a retroactive edit).
model PayrollRun {
  id            String           @id @default(uuid())
  month         Int
  year          Int
  status        PayrollRunStatus @default(DRAFT)
  initiatedById String
  initiatedBy   Employee         @relation(fields: [initiatedById], references: [id], onDelete: Restrict)
  processedAt   DateTime?
  lockedAt      DateTime?
  payslips      Payslip[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@unique([month, year])
  @@map("payroll_runs")
}

/// One per employee per PayrollRun. `statutoryConfigSnapshot` freezes the
/// exact StatutoryConfig row contents used at generation time — a later
/// StatutoryConfig update must never retroactively change what an already-
/// generated payslip's numbers mean.
model Payslip {
  id                      String        @id @default(uuid())
  payrollRunId            String
  payrollRun              PayrollRun    @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employeeId              String
  employee                Employee      @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  grossEarnings           Decimal       @db.Decimal(14, 2)
  basicPaid               Decimal       @db.Decimal(14, 2)
  hraPaid                 Decimal       @db.Decimal(14, 2)
  specialAllowancePaid    Decimal       @db.Decimal(14, 2)
  otherAllowancesPaid     Decimal       @db.Decimal(14, 2)
  pfEmployee              Decimal       @db.Decimal(14, 2)
  pfEmployer              Decimal       @db.Decimal(14, 2)
  esiEmployee             Decimal?      @db.Decimal(14, 2)
  esiEmployer             Decimal?      @db.Decimal(14, 2)
  professionalTax         Decimal?      @db.Decimal(14, 2)
  tdsDeducted             Decimal       @db.Decimal(14, 2)
  unpaidLeaveDeduction    Decimal       @default(0) @db.Decimal(14, 2)
  netPay                  Decimal       @db.Decimal(14, 2)
  statutoryConfigSnapshot Json
  status                  PayslipStatus @default(GENERATED)
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  @@unique([payrollRunId, employeeId])
  @@map("payslips")
}

/// Append-only audit trail of mutating actions. Written by AuditInterceptor.
model AuditLog {
  id        String    @id @default(cuid())
  actorId   String?
  actor     Employee? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  action    String // HTTP method + route, e.g. "POST /employees"
  entity    String? // logical entity name, e.g. "Employee"
  entityId  String?
  before    Json?
  after     Json?
  ip        String?
  createdAt DateTime  @default(now())

  @@index([actorId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================================================
// Sales module
// ============================================================================

/// Per-(entity, year) monotonic counter backing year-prefixed, annually
/// resetting human-readable numbers (LD-2026-0001, BID-2026-0001,
/// ORD-2026-0001). A plain Postgres sequence (like employee_id_seq) can't
/// reset per calendar year, so numbering uses this counter table instead:
/// an atomic `INSERT ... ON CONFLICT (entity, year) DO UPDATE SET
/// lastValue = ... + 1 RETURNING lastValue` inside the record's own insert
/// transaction (see SalesNumberingService). The first row for a new year
/// starts the count fresh at 1.
model SalesSequence {
  entity    String
  year      Int
  lastValue Int      @default(0)
  updatedAt DateTime @updatedAt

  @@id([entity, year])
  @@map("sales_sequences")
}

/// A customer account owned by a Sales rep. shippingAddress defaults to
/// billingAddress at the application layer when null.
model Customer {
  id               String            @id @default(uuid())
  name             String
  gstin            String?
  billingAddress   Json
  shippingAddress  Json?
  industry         String?
  ownerId          String
  owner            Employee          @relation("CustomerOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  status           CustomerStatus    @default(ACTIVE)
  contacts         CustomerContact[]
  opportunities    Opportunity[]
  bids             Bid[]
  orders           Order[]
  salesInvoices    SalesInvoice[]
  customerReceipts CustomerReceipt[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([ownerId])
  @@index([status])
  @@map("customers")
}

model CustomerContact {
  id          String   @id @default(uuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name        String
  email       String?
  phone       String?
  designation String?
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([customerId])
  @@map("customer_contacts")
}

/// Product catalog. unitPrice is the current list price; a Bid/Order line
/// item snapshots the price at creation time rather than referencing this
/// live (see BidLineItem.unitPrice).
model Product {
  id                String             @id @default(uuid())
  sku               String             @unique
  name              String
  description       String?
  unitPrice         Decimal            @db.Decimal(14, 2)
  unitOfMeasure     String
  hsnCode           String?
  isActive          Boolean            @default(true)
  /// Bridge to the Item Master: the manufactured Item this sellable Product
  /// corresponds to (typically a FINISHED_GOOD). BOMs are keyed on Item, not
  /// Product, so an order line resolves product -> item -> released BOM ->
  /// multi-level explosion. Nullable: not every Product is manufactured.
  itemId            String?
  item              Item?              @relation("ProductItem", fields: [itemId], references: [id], onDelete: SetNull)
  bidLineItems      BidLineItem[]
  orderLineItems    OrderLineItem[]
  salesInvoiceLines SalesInvoiceLine[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([itemId])
  @@map("products")
}

model Lead {
  id                       String       @id @default(uuid())
  leadNumber               String       @unique
  companyName              String
  contactName              String
  email                    String?
  phone                    String?
  requirement              String
  priority                 LeadPriority @default(MEDIUM)
  source                   LeadSource   @default(OTHER)
  status                   LeadStatus   @default(NEW)
  ownerId                  String
  owner                    Employee     @relation("LeadOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  disqualifiedReason       String?
  convertedToOpportunityId String?      @unique
  convertedToOpportunity   Opportunity? @relation("LeadConversion", fields: [convertedToOpportunityId], references: [id], onDelete: SetNull)
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt

  @@index([ownerId])
  @@index([status])
  @@map("leads")
}

model Opportunity {
  id                String                  @id @default(uuid())
  leadId            String?
  lead              Lead?                   @relation("LeadConversion")
  customerId        String?
  customer          Customer?               @relation(fields: [customerId], references: [id], onDelete: SetNull)
  name              String
  stage             OpportunityStage        @default(PROSPECTING)
  estimatedValue    Decimal                 @db.Decimal(14, 2)
  expectedCloseDate DateTime
  ownerId           String
  owner             Employee                @relation("OpportunityOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  lostReason        String?
  bids              Bid[]
  bidAssessments    BidDecisionAssessment[]
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@index([ownerId])
  @@index([stage])
  @@map("opportunities")
}

/// A formal bid/tender response against an opportunity. Monetary totals are
/// computed from line items + discount + tax (see BidsService). A bid with
/// discountPercent > 10 routes to the creator's manager for approval before
/// it can be SENT (same escalation guard as leave approvals).
model Bid {
  id                            String         @id @default(uuid())
  bidNumber                     String         @unique
  opportunityId                 String
  opportunity                   Opportunity    @relation(fields: [opportunityId], references: [id], onDelete: Restrict)
  customerId                    String
  customer                      Customer       @relation(fields: [customerId], references: [id], onDelete: Restrict)
  status                        BidStatus      @default(DRAFT)
  validUntil                    DateTime
  tenderReferenceNumber         String?
  /// One-line subject for the Techno Commercial Proposal — used verbatim in
  /// both the "Subject:" line and the opening paragraph of the document.
  quotationSubject              String?
  /// Retained for internal use; NOT rendered in the Techno Commercial Proposal
  /// (the per-line Description column carries the technical detail instead).
  technicalSpecification        String?
  /// Placeholder for a future file-storage module: metadata only
  /// ([{filename, url}]), no upload infrastructure in this phase.
  attachments                   Json?
  subtotal                      Decimal        @default(0) @db.Decimal(14, 2)
  discountPercent               Decimal        @default(0) @db.Decimal(5, 2)
  discountAmount                Decimal        @default(0) @db.Decimal(14, 2)
  taxType                       SalesTaxType?
  taxRate                       Decimal?       @db.Decimal(5, 2)
  taxAmount                     Decimal        @default(0) @db.Decimal(14, 2)
  totalAmount                   Decimal        @default(0) @db.Decimal(14, 2)
  createdById                   String
  createdBy                     Employee       @relation("BidCreator", fields: [createdById], references: [id], onDelete: Restrict)
  approverId                    String?
  approver                      Employee?      @relation("BidApprover", fields: [approverId], references: [id], onDelete: SetNull)
  approvedAt                    DateTime?
  approverComments              String?
  /// Snapshot of the approving manager's e-signature at discount-approval time.
  approverSignatureTextSnapshot String?
  approverSignatureFontSnapshot SignatureFont?
  lineItems                     BidLineItem[]
  orders                        Order[]
  createdAt                     DateTime       @default(now())
  updatedAt                     DateTime       @updatedAt

  @@index([opportunityId])
  @@index([customerId])
  @@index([status])
  @@index([createdById])
  @@map("bids")
}

model BidLineItem {
  id                  String   @id @default(uuid())
  bidId               String
  bid                 Bid      @relation(fields: [bidId], references: [id], onDelete: Cascade)
  productId           String
  product             Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity            Decimal  @db.Decimal(14, 2)
  /// Snapshot of Product.unitPrice at bid-creation time — never a live
  /// reference, so the bid preserves exactly what was proposed.
  unitPrice           Decimal  @db.Decimal(14, 2)
  lineDiscountPercent Decimal? @db.Decimal(5, 2)
  lineTotal           Decimal  @db.Decimal(14, 2)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([bidId])
  @@map("bid_line_items")
}

model Order {
  id                 String                   @id @default(uuid())
  orderNumber        String                   @unique
  bidId              String?
  bid                Bid?                     @relation(fields: [bidId], references: [id], onDelete: SetNull)
  customerId         String
  customer           Customer                 @relation(fields: [customerId], references: [id], onDelete: Restrict)
  status             OrderStatus              @default(CONFIRMED)
  /// Snapshot of the source bid's totalAmount at conversion time — the
  /// order's booked value. Frozen here rather than recomputed from line
  /// items so it survives independently of the bid (which can be edited in
  /// a later revision). Decimal, never Float.
  totalAmount        Decimal                  @default(0) @db.Decimal(14, 2)
  /// Reserved FK for the future Production module — not enforced yet.
  productionRunId    String?
  /// Reserved FK for the future SCM/logistics module — not enforced yet.
  shipmentId         String?
  ownerId            String
  owner              Employee                 @relation("OrderOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  lineItems          OrderLineItem[]
  confirmationSheets OrderConfirmationSheet[]
  projectKickoffs    ProjectKickoff[]
  billingMilestones  BillingMilestone[]
  salesInvoices      SalesInvoice[]
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  @@index([ownerId])
  @@index([customerId])
  @@index([status])
  @@map("orders")
}

model OrderLineItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity  Decimal @db.Decimal(14, 2)
  unitPrice Decimal @db.Decimal(14, 2)
  lineTotal Decimal @db.Decimal(14, 2)

  /// Per-line delivery classification, set at project kickoff. Nullable — an
  /// order line has no classification until a PM assigns one. Additive to the
  /// existing bid→order flow (conversion leaves these null).
  deliveryType           OrderLineDeliveryType?
  /// PLACEHOLDER (see below): free-text vendor name captured when deliveryType
  /// = VENDOR, until an Approved Vendor Master module exists. Intentionally NOT
  /// a FK — there is no Vendor entity yet. When the Vendor Master is built,
  /// these free-text names will need a reconciliation/migration to real vendor
  /// records; the generic `vendorName` naming keeps that path open.
  vendorName             String?
  /// Loose contact capture (name/phone/email in one field) for the placeholder
  /// vendor — also temporary, folds into the future Vendor Master.
  vendorContactInfo      String?
  /// Rough expected lead time from the vendor, free text (e.g. "6-8 weeks").
  vendorExpectedLeadTime String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@map("order_line_items")
}

/// Lifecycle of an Order Confirmation Sheet. DRAFT is editable; generating the
/// PDF locks it (AWAITING_CUSTOMER_SIGNATURE); the rep uploads the customer-
/// signed scan (AWAITING_INTERNAL_SIGNATURE); the Sales Head countersigns
/// (EXECUTED) or rejects (REJECTED). EXECUTED is the hard gate that unblocks
/// the Order's CONFIRMED -> IN_PRODUCTION transition.
enum OrderConfirmationStatus {
  DRAFT
  AWAITING_CUSTOMER_SIGNATURE
  AWAITING_INTERNAL_SIGNATURE
  REJECTED
  EXECUTED
}

enum OrderConfirmationDeliveryType {
  FULL_TRUCKLOAD
  PARTIAL_TRUCKLOAD
  CUSTOMER_PICKUP_EXWORKS
  COURIER_EXPRESS
  OTHER
}

enum OrderConfirmationQualityReport {
  MATERIAL_TEST_CERTIFICATE
  FACTORY_ACCEPTANCE_TEST_REPORT
  CALIBRATION_CERTIFICATE
  COMPLIANCE_CERTIFICATE
  OTHER
}

/// A formal, customer-agreed requirements document tied to a CONFIRMED order:
/// delivery/packaging/quality terms, executed by customer signature + Sales
/// Head countersignature. Numbered OC-YYYY-#### via SalesNumberingService.
/// Revisions are new rows (revisionNumber+1), so full history is preserved.
/// The single signed-copy attachment lives in R2 (signedCopyStorageKey),
/// reusing the Vault storage client directly — not the Vault folder model.
model OrderConfirmationSheet {
  id                 String                  @id @default(uuid())
  confirmationNumber String                  @unique
  orderId            String
  order              Order                   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  revisionNumber     Int                     @default(1)
  status             OrderConfirmationStatus @default(DRAFT)

  requirementsOverview String @db.Text

  deliveryDate     DateTime
  deliveryLocation String                        @db.Text
  deliveryType     OrderConfirmationDeliveryType

  qualityReportsExpected OrderConfirmationQualityReport[]
  qualityReportNotes     String?                          @db.Text

  installationCommissioningRequired Boolean @default(false)
  installationNotes                 String? @db.Text

  warrantyTerms               String  @db.Text
  paymentMilestones           String  @db.Text
  siteReadinessRequirements   String? @db.Text
  specialHandlingInstructions String? @db.Text

  // Packaging — deliberately structured (§2.1); required at the form level.
  packagingType                  String  @db.Text
  protectiveMeasures             String  @db.Text
  packagingComplianceStandard    String? @db.Text
  labelingRequirements           String  @db.Text
  customerPackagingSpecReference String? @db.Text

  // Delivery coordination point of contact.
  customerContactName  String
  customerContactPhone String
  customerContactEmail String

  pdfGeneratedAt DateTime?

  signedCopyStorageKey   String?
  signedCopyUploadedById String?
  signedCopyUploadedBy   Employee? @relation("OcSignedCopyUploader", fields: [signedCopyUploadedById], references: [id], onDelete: SetNull)
  signedCopyUploadedAt   DateTime?

  internalSignedById            String?
  internalSignedBy              Employee?      @relation("OcInternalSigner", fields: [internalSignedById], references: [id], onDelete: SetNull)
  internalSignedAt              DateTime?
  internalReviewComments        String?        @db.Text
  /// Snapshot of the Sales Head's name + e-signature at countersignature time —
  /// rendered onto the internal-signature line of the printed sheet. Name is
  /// snapshotted (not live-joined) so the executed document is stable even if
  /// the signer is later renamed. Signature fields stay null if the signer had
  /// none configured (the printed line then shows just the name + date).
  internalSignedByName          String?
  approverSignatureTextSnapshot String?
  approverSignatureFontSnapshot SignatureFont?

  createdById String
  createdBy   Employee @relation("OcCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([orderId])
  @@index([status])
  @@map("order_confirmation_sheets")
}

/// Versioned, effective-dated GST rate — same pattern as StatutoryConfig,
/// though lower compliance stakes (a wrong bid rate is correctable before
/// invoicing). One active rate per taxType; not per-HSN yet. Do NOT hardcode
/// GST percentages in service code — every rate comes from a row here.
model TaxConfig {
  id            String       @id @default(uuid())
  taxType       SalesTaxType
  rate          Decimal      @db.Decimal(5, 2)
  effectiveFrom DateTime
  effectiveTo   DateTime?
  sourceNote    String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([taxType, effectiveFrom])
  @@map("tax_configs")
}

/// Configurable Bid/No-Bid questionnaire item — editable by Admin, same
/// extensible-table pattern as Vertical/LeaveType (not hardcoded). The
/// question text is snapshotted onto each response at submission time, so
/// editing/deactivating a question here never rewrites answered history.
model BidAssessmentQuestion {
  id           String                    @id @default(uuid())
  text         String
  type         BidAssessmentQuestionType
  /// Only used for SELECT-type questions: JSON array of option strings.
  options      Json?
  displayOrder Int                       @default(0)
  isActive     Boolean                   @default(true)
  responses    BidAssessmentResponse[]
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt

  @@index([isActive, displayOrder])
  @@map("bid_assessment_questions")
}

/// A rep's Bid/No-Bid decision submission for an Opportunity, reviewed by the
/// designated Sales Head (or SUPER_ADMIN fallback). Rejection is not reopened
/// — a resubmission is a new row; only the most-recent per Opportunity gates
/// Bid creation.
model BidDecisionAssessment {
  id                            String                  @id @default(uuid())
  opportunityId                 String
  opportunity                   Opportunity             @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  submittedById                 String
  submittedBy                   Employee                @relation("BidAssessmentSubmitter", fields: [submittedById], references: [id], onDelete: Restrict)
  status                        BidAssessmentStatus     @default(PENDING_REVIEW)
  reviewedById                  String?
  reviewedBy                    Employee?               @relation("BidAssessmentReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt                    DateTime?
  reviewerComments              String?
  /// Snapshot of the reviewer's e-signature at approval time (nullable — none
  /// if the reviewer had no signature configured).
  approverSignatureTextSnapshot String?
  approverSignatureFontSnapshot SignatureFont?
  responses                     BidAssessmentResponse[]
  createdAt                     DateTime                @default(now())
  updatedAt                     DateTime                @updatedAt

  @@index([opportunityId, createdAt])
  @@index([status])
  @@map("bid_decision_assessments")
}

/// One answer within a BidDecisionAssessment. `questionTextSnapshot` freezes
/// the wording as asked (same snapshot principle as Bid line-item prices and
/// Payslip statutory config). `answerValue` stores every type as text; the
/// display layer parses per the question's `type`.
model BidAssessmentResponse {
  id                   String                @id @default(uuid())
  assessmentId         String
  assessment           BidDecisionAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  questionId           String
  question             BidAssessmentQuestion @relation(fields: [questionId], references: [id], onDelete: Restrict)
  questionTextSnapshot String
  answerValue          String
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@index([assessmentId])
  @@map("bid_assessment_responses")
}

/// Vault folder tree. Access = default scope rules (per visibilityScope) +
/// explicit VaultFolderPermission grants, most-permissive-wins, SUPER_ADMIN
/// override — computed in VaultAccessService, never trusted from the client.
/// PERSONAL folders: exactly one per employee (partial unique index in the
/// migration), PRIVATE, undeletable, versioning not exposed.
model VaultFolder {
  id                  String                  @id @default(uuid())
  name                String
  parentFolderId      String?
  parentFolder        VaultFolder?            @relation("VaultFolderTree", fields: [parentFolderId], references: [id], onDelete: Restrict)
  childFolders        VaultFolder[]           @relation("VaultFolderTree")
  type                VaultFolderType
  ownerId             String
  /// Cascade: production never hard-deletes employees (soft-delete via
  /// status INACTIVE); a hard delete (e.g. test cleanup) takes the person's
  /// folders with it rather than blocking on the auto-provisioned PERSONAL one.
  owner               Employee                @relation("VaultFolderOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  visibilityScope     VaultVisibilityScope
  /// Required when visibilityScope = VERTICAL (service-enforced).
  scopeVerticalId     String?
  scopeVertical       Vertical?               @relation(fields: [scopeVerticalId], references: [id], onDelete: Restrict)
  versioningEnabled   Boolean                 @default(false)
  maxVersionsRetained Int?                    @default(5)
  status              VaultFolderStatus       @default(ACTIVE)
  permissions         VaultFolderPermission[]
  files               VaultFile[]
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  @@index([ownerId])
  @@index([parentFolderId])
  @@index([visibilityScope, scopeVerticalId])
  @@map("vault_folders")
}

/// Explicit grant beyond a folder's default scope — additive only (grants
/// never reduce scope-derived access). granteeId is polymorphic per
/// granteeType (Employee id / Vertical id / Role name), so no FK on it.
model VaultFolderPermission {
  id                 String           @id @default(uuid())
  folderId           String
  folder             VaultFolder      @relation(fields: [folderId], references: [id], onDelete: Cascade)
  granteeType        VaultGranteeType
  granteeId          String
  canRead            Boolean          @default(false)
  canWrite           Boolean          @default(false)
  canDelete          Boolean          @default(false)
  canCreateSubfolder Boolean          @default(false)
  grantedById        String
  grantedBy          Employee         @relation("VaultPermissionGrantor", fields: [grantedById], references: [id], onDelete: Cascade)
  createdAt          DateTime         @default(now())

  @@unique([folderId, granteeType, granteeId])
  @@index([granteeType, granteeId])
  @@map("vault_folder_permissions")
}

/// Stable identity for a document. Its bytes live in one-or-more
/// VaultFileVersions; currentVersionId points at the live one. The backend
/// never stores or streams bytes — only R2 object keys (storageKey on the
/// version). A file always belongs to a folder (folderId required). Deletion
/// is whole-file soft-delete (status DELETED cascades to every version).
model VaultFile {
  id               String             @id @default(uuid())
  folderId         String
  folder           VaultFolder        @relation(fields: [folderId], references: [id], onDelete: Restrict)
  name             String
  /// The live version. Nullable only transiently: a PENDING file exists
  /// before its first version row is linked. No DB-level FK back-reference
  /// (would be a cycle with VaultFileVersion.fileId) — set in the service.
  currentVersionId String?            @unique
  uploadedById     String
  uploadedBy       Employee           @relation("VaultFileUploader", fields: [uploadedById], references: [id], onDelete: Cascade)
  status           VaultFileStatus    @default(PENDING)
  versions         VaultFileVersion[] @relation("VaultFileVersions")
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([folderId, status])
  @@map("vault_files")
}

/// One immutable version of a file's bytes. versionNumber is sequential per
/// file. Append-only: a restore adds a new version copying an older one; a
/// version row is never mutated, and only ever hard-deleted by retention
/// pruning (which also deletes the R2 object). storageKey is the R2 object
/// key. Preview fields stay NOT_APPLICABLE/unset until Phase 4.
model VaultFileVersion {
  id                 String                   @id @default(uuid())
  fileId             String
  file               VaultFile                @relation("VaultFileVersions", fields: [fileId], references: [id], onDelete: Cascade)
  versionNumber      Int
  mimeType           String
  sizeBytes          BigInt
  storageKey         String
  previewStorageKey  String?
  previewStatus      PreviewStatus            @default(NOT_APPLICABLE)
  changeNote         String?
  uploadedById       String
  uploadedBy         Employee                 @relation("VaultVersionUploader", fields: [uploadedById], references: [id], onDelete: Cascade)
  externalShareLinks VaultExternalShareLink[]
  createdAt          DateTime                 @default(now())

  @@unique([fileId, versionNumber])
  @@index([fileId])
  @@map("vault_file_versions")
}

/// An additive internal share: grants one employee VIEW/EDIT on one file or
/// folder, ON TOP OF whatever the resource's default scope / folder
/// permissions already give them. Folded into VaultAccessService — never
/// reduces existing access. resourceId is polymorphic per resourceType, so
/// there is no FK on it (a share is cleaned up in the service, or orphaned
/// harmlessly if the resource is hard-deleted).
model VaultInternalShare {
  id                   String                 @id @default(uuid())
  resourceType         VaultShareResourceType
  resourceId           String
  sharedWithEmployeeId String
  sharedWithEmployee   Employee               @relation("VaultShareRecipient", fields: [sharedWithEmployeeId], references: [id], onDelete: Cascade)
  permission           VaultSharePermission
  sharedById           String
  sharedBy             Employee               @relation("VaultShareGrantor", fields: [sharedById], references: [id], onDelete: Cascade)
  createdAt            DateTime               @default(now())

  // One live share per (resource, recipient): re-sharing updates the level.
  @@unique([resourceType, resourceId, sharedWithEmployeeId])
  @@index([sharedWithEmployeeId])
  @@index([resourceType, resourceId])
  @@map("vault_internal_shares")
}

/// A public, unauthenticated external share link. `token` is a cryptographically
/// random secret (the only credential), permission is ALWAYS VIEW (no edit,
/// ever). For a FILE it PINS `pinnedVersionId` — the version current at
/// creation time — and keeps serving that even after newer versions land
/// (not a live "current" pointer). Optional passwordHash + expiresAt (default
/// 24h) + revokedAt gate access. PERSONAL folders can't be link-shared whole
/// (service-enforced); individual files within them can.
model VaultExternalShareLink {
  id              String                   @id @default(uuid())
  resourceType    VaultShareResourceType
  resourceId      String
  token           String                   @unique
  /// Always VIEW — kept as a column for audit clarity, never anything else.
  permission      VaultSharePermission     @default(VIEW)
  /// Pinned version for FILE links (null for FOLDER links). No FK action on
  /// delete beyond SetNull so a pruned version doesn't cascade-remove the link
  /// row (the link simply stops resolving — handled in the service).
  pinnedVersionId String?
  pinnedVersion   VaultFileVersion?        @relation(fields: [pinnedVersionId], references: [id], onDelete: SetNull)
  passwordHash    String?
  expiresAt       DateTime
  revokedAt       DateTime?
  createdById     String
  createdBy       Employee                 @relation("VaultExternalShareCreator", fields: [createdById], references: [id], onDelete: Cascade)
  accessLogs      VaultExternalAccessLog[]
  createdAt       DateTime                 @default(now())

  @@index([resourceType, resourceId])
  @@map("vault_external_share_links")
}

/// Audit trail for every public-link access ATTEMPT (success or failure —
/// expired/revoked/bad-password hits are logged too). IP + user agent captured
/// for security review.
model VaultExternalAccessLog {
  id          String                 @id @default(uuid())
  shareLinkId String
  shareLink   VaultExternalShareLink @relation(fields: [shareLinkId], references: [id], onDelete: Cascade)
  accessedAt  DateTime               @default(now())
  ipAddress   String?
  userAgent   String?

  @@index([shareLinkId])
  @@map("vault_external_access_logs")
}

// ---- Kanban models ----

/// A Trello-like board. NOT vertical-scoped — access is by explicit membership
/// (KanbanBoardMember) only, plus SUPER_ADMIN as a full override. Created by a
/// Scrum Master or SUPER_ADMIN; the creator is auto-added as a member.
model KanbanBoard {
  id              String              @id @default(uuid())
  name            String
  createdById     String
  createdBy       Employee            @relation("KanbanBoardCreator", fields: [createdById], references: [id], onDelete: Restrict)
  status          KanbanBoardStatus   @default(ACTIVE)
  members         KanbanBoardMember[]
  lists           KanbanList[]
  sprints         KanbanSprint[]
  labels          KanbanLabel[]
  projectKickoffs ProjectKickoff[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([status])
  @@map("kanban_boards")
}

/// Explicit board membership — the sole access mechanism (besides SUPER_ADMIN).
model KanbanBoardMember {
  id         String      @id @default(uuid())
  boardId    String
  board      KanbanBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  employeeId String
  employee   Employee    @relation("KanbanBoardMember", fields: [employeeId], references: [id], onDelete: Cascade)
  addedById  String
  addedBy    Employee    @relation("KanbanBoardMemberAddedBy", fields: [addedById], references: [id], onDelete: Restrict)
  addedAt    DateTime    @default(now())

  @@unique([boardId, employeeId])
  @@index([employeeId])
  @@map("kanban_board_members")
}

/// A column on a board. Created by Scrum Master / SUPER_ADMIN only.
model KanbanList {
  id          String       @id @default(uuid())
  boardId     String
  board       KanbanBoard  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  name        String
  /// Fractional ordering, same scheme as KanbanCard.position — reordering a
  /// list is a single-row update between two neighbours' positions.
  position    Float
  /// Marks a "done"-type column. A card sitting here is never flagged overdue
  /// even if its dueDate has passed. Settable by Scrum Master / SUPER_ADMIN.
  isDoneList  Boolean      @default(false)
  createdById String
  createdBy   Employee     @relation("KanbanListCreator", fields: [createdById], references: [id], onDelete: Restrict)
  cards       KanbanCard[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([boardId, position])
  @@map("kanban_lists")
}

/// A time-boxed sprint on a board. Status (UPCOMING/ACTIVE/COMPLETED) is
/// COMPUTED from dates at read time, never stored. endDate is computed once at
/// creation (startDate + durationWeeks*7d) and stored. SM / SUPER_ADMIN only.
model KanbanSprint {
  id            String               @id @default(uuid())
  boardId       String
  board         KanbanBoard          @relation(fields: [boardId], references: [id], onDelete: Cascade)
  name          String
  durationWeeks KanbanSprintDuration
  startDate     DateTime
  endDate       DateTime
  createdById   String
  createdBy     Employee             @relation("KanbanSprintCreator", fields: [createdById], references: [id], onDelete: Restrict)
  cards         KanbanCard[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([boardId])
  @@map("kanban_sprints")
}

/// A card in a list. Members create/edit/move/comment; only SM/SUPER_ADMIN may
/// set sprintId. assigneeId must be a member of the card's board.
model KanbanCard {
  id                String               @id @default(uuid())
  listId            String
  list              KanbanList           @relation(fields: [listId], references: [id], onDelete: Cascade)
  title             String
  description       String?              @db.Text
  assigneeId        String?
  assignee          Employee?            @relation("KanbanCardAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  startDate         DateTime?
  dueDate           DateTime?
  priority          LeadPriority         @default(MEDIUM)
  sprintId          String?
  sprint            KanbanSprint?        @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  /// Fractional ordering within the list — inserting between two cards uses a
  /// value between their positions, so a move is a single-row update (no
  /// reindex). Re-spaced only when adjacent values get too close.
  position          Float
  createdById       String
  createdBy         Employee             @relation("KanbanCardCreator", fields: [createdById], references: [id], onDelete: Restrict)
  status            KanbanCardStatus     @default(ACTIVE)
  comments          KanbanCardComment[]
  activity          KanbanCardActivity[]
  notifications     Notification[]
  labels            KanbanCardLabel[]
  kickoffActionItem KickoffActionItem?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([listId, position])
  @@index([sprintId])
  @@index([assigneeId])
  @@map("kanban_cards")
}

/// A board-scoped colored label. Definition (create/edit/delete) is restricted
/// to Scrum Master / SUPER_ADMIN; any member may attach an existing label to a
/// card (via KanbanCardLabel).
model KanbanLabel {
  id        String            @id @default(uuid())
  boardId   String
  board     KanbanBoard       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  name      String
  /// Free-form color token (e.g. a hex or a named swatch) — the UI maps it.
  color     String
  cards     KanbanCardLabel[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([boardId])
  @@map("kanban_labels")
}

/// Join table: which labels are attached to which cards.
model KanbanCardLabel {
  cardId  String
  card    KanbanCard  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  labelId String
  label   KanbanLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([cardId, labelId])
  @@index([labelId])
  @@map("kanban_card_labels")
}

/// A user-authored comment on a card.
model KanbanCardComment {
  id        String     @id @default(uuid())
  cardId    String
  card      KanbanCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  authorId  String
  author    Employee   @relation("KanbanCommentAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  text      String     @db.Text
  createdAt DateTime   @default(now())

  @@index([cardId, createdAt])
  @@map("kanban_card_comments")
}

/// Auto-generated, human-readable card timeline (separate from AuditLog).
/// Written whenever a card's list/assignee/sprint/priority/dates change.
model KanbanCardActivity {
  id          String     @id @default(uuid())
  cardId      String
  card        KanbanCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  actorId     String
  actor       Employee   @relation("KanbanActivityActor", fields: [actorId], references: [id], onDelete: Restrict)
  description String
  createdAt   DateTime   @default(now())

  @@index([cardId, createdAt])
  @@map("kanban_card_activity")
}

/// Generic in-app notification (things worth KNOWING). Distinct from the
/// pending-approvals counters (things needing ACTION). Poll-based, like the
/// rest of the app's notification surfaces.
model Notification {
  id                String           @id @default(uuid())
  employeeId        String
  employee          Employee         @relation("NotificationRecipient", fields: [employeeId], references: [id], onDelete: Cascade)
  type              NotificationType
  /// Deep-link target for card-based notifications (Kanban). Null for others.
  relatedCardId     String?
  relatedCard       KanbanCard?      @relation(fields: [relatedCardId], references: [id], onDelete: Cascade)
  /// Deep-link target for vendor-based notifications (SCM). Null for others.
  /// A notification carries at most one related-entity id, by type.
  relatedVendorId   String?
  relatedVendor     Vendor?          @relation(fields: [relatedVendorId], references: [id], onDelete: Cascade)
  /// Deep-link target for supplier-based notifications (SCM raw-materials).
  relatedSupplierId String?
  relatedSupplier   Supplier?        @relation(fields: [relatedSupplierId], references: [id], onDelete: Cascade)
  /// Deep-link target for BOM workflow notifications (R&D). Null for others.
  relatedBomId      String?
  relatedBom        Bom?             @relation(fields: [relatedBomId], references: [id], onDelete: Cascade)
  message           String
  isRead            Boolean          @default(false)
  createdAt         DateTime         @default(now())

  @@index([employeeId, isRead])
  @@map("notifications")
}

// ── Project Kickoff ──────────────────────────────────────────────────
// A structured record of the cross-functional kickoff held once an Order's
// Confirmation Sheet is EXECUTED. Action items are mirrored as real Kanban
// cards on an auto-provisioned project board; their status is READ from the
// card's list at query time (no stored action-item status → no drift).

enum KickoffMeetingMode {
  IN_PERSON
  VIRTUAL
  HYBRID
}

enum KickoffStatus {
  DRAFT
  COMPLETED
}

enum KickoffMilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  DELAYED
}

enum KickoffRiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum KickoffRiskStatus {
  OPEN
  MITIGATED
  CLOSED
}

model ProjectKickoff {
  id               String             @id @default(uuid())
  orderId          String
  order            Order              @relation(fields: [orderId], references: [id], onDelete: Restrict)
  projectName      String
  meetingDate      DateTime
  meetingMode      KickoffMeetingMode @default(VIRTUAL)
  meetingLocation  String?
  overviewAndScope String?            @db.Text
  minutesNotes     String?            @db.Text
  status           KickoffStatus      @default(DRAFT)
  /// The project board auto-provisioned at creation (§5). Restrict so a board
  /// backing a kickoff can't be deleted out from under it.
  kanbanBoardId    String
  kanbanBoard      KanbanBoard        @relation(fields: [kanbanBoardId], references: [id], onDelete: Restrict)
  createdById      String
  createdBy        Employee           @relation("KickoffCreator", fields: [createdById], references: [id], onDelete: Restrict)

  attendees         KickoffAttendee[]
  milestones        KickoffMilestone[]
  actionItems       KickoffActionItem[]
  risks             KickoffRisk[]
  stockReport       KickoffStockReport?
  stockReservations StockReservation[]  @relation("KickoffReservations")
  materialIndents   MaterialIndent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([createdById])
  @@map("project_kickoffs")
}

/// One attendance record. Exactly one of employeeId / externalName is set
/// (internal vs. external attendee) — enforced at the service layer.
model KickoffAttendee {
  id                   String         @id @default(uuid())
  kickoffId            String
  kickoff              ProjectKickoff @relation(fields: [kickoffId], references: [id], onDelete: Cascade)
  employeeId           String?
  employee             Employee?      @relation("KickoffAttendeeEmployee", fields: [employeeId], references: [id], onDelete: SetNull)
  externalName         String?
  externalOrganization String?
  designation          String?
  department           String?
  createdAt            DateTime       @default(now())

  @@index([kickoffId])
  @@map("kickoff_attendees")
}

/// A project-level checkpoint. Standalone (NOT linked to Kanban) — milestones
/// are checkpoints, distinct from individually-actionable tasks.
model KickoffMilestone {
  id         String                 @id @default(uuid())
  kickoffId  String
  kickoff    ProjectKickoff         @relation(fields: [kickoffId], references: [id], onDelete: Cascade)
  name       String
  targetDate DateTime
  ownerId    String?
  owner      Employee?              @relation("KickoffMilestoneOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  status     KickoffMilestoneStatus @default(PENDING)
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt

  @@index([kickoffId])
  @@map("kickoff_milestones")
}

/// An actionable task. Mirrored 1:1 to a Kanban card; the item's DISPLAYED
/// status is derived from that card's list at read time (no stored status).
model KickoffActionItem {
  id           String         @id @default(uuid())
  kickoffId    String
  kickoff      ProjectKickoff @relation(fields: [kickoffId], references: [id], onDelete: Cascade)
  description  String
  ownerId      String
  owner        Employee       @relation("KickoffActionItemOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  dueDate      DateTime?
  /// The linked Kanban card. Unique (1:1). SetNull so archiving the card
  /// doesn't delete the action item; the item just loses its live status.
  kanbanCardId String?        @unique
  kanbanCard   KanbanCard?    @relation(fields: [kanbanCardId], references: [id], onDelete: SetNull)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([kickoffId])
  @@map("kickoff_action_items")
}

/// A project risk with a likelihood/impact matrix and mitigation plan.
model KickoffRisk {
  id             String            @id @default(uuid())
  kickoffId      String
  kickoff        ProjectKickoff    @relation(fields: [kickoffId], references: [id], onDelete: Cascade)
  description    String
  likelihood     KickoffRiskLevel  @default(MEDIUM)
  impact         KickoffRiskLevel  @default(MEDIUM)
  mitigationPlan String?           @db.Text
  ownerId        String?
  owner          Employee?         @relation("KickoffRiskOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  status         KickoffRiskStatus @default(OPEN)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([kickoffId])
  @@map("kickoff_risks")
}

// ── Vendor Qualification (SCM) ─────────────────────────────────────
// Vendor Master + self-assessment questionnaire (vendor fills online via a
// token link) + internal audit with weighted scoring → classification. This
// is the first real Vendor/Vendor Master; Project Kickoff's free-text
// vendorName reconciles to Vendor.companyName in a FUTURE task (keep
// companyName a plain matchable string).

enum VendorStatus {
  PENDING_QUESTIONNAIRE
  QUESTIONNAIRE_SUBMITTED
  UNDER_AUDIT
  APPROVED_PREFERRED
  APPROVED
  CONDITIONALLY_APPROVED
  NOT_APPROVED
}

enum VendorQuestionnaireStatus {
  SENT
  SUBMITTED
}

enum VendorAuditType {
  PHYSICAL
  VIRTUAL
}

model Vendor {
  id                       String                   @id @default(uuid())
  /// Plain, matchable company name — the future reconciliation target for
  /// Project Kickoff's free-text vendorName. Deliberately not normalized away.
  companyName              String
  registeredAddress        String                   @db.Text
  factoryAddress           String                   @db.Text
  yearEstablished          String
  numberOfEmployees        String
  annualTurnover           String
  msmeUdyamCertificate     String?
  contactPersonName        String
  contactPersonDesignation String
  contactEmail             String
  contactPhone             String
  website                  String?
  status                   VendorStatus             @default(PENDING_QUESTIONNAIRE)
  createdById              String
  createdBy                Employee                 @relation("VendorCreator", fields: [createdById], references: [id], onDelete: Restrict)
  questionnaires           VendorQuestionnaire[]
  audits                   VendorAudit[]
  notifications            Notification[]
  purchaseOrders           PurchaseOrder[]
  apInvoices               AccountsPayableInvoice[]
  apPayments               AccountsPayablePayment[]
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt

  @@index([status])
  @@map("vendors")
}

/// One questionnaire revision. Section content is stored as opaque JSON (one
/// column per VSAQ section) — 100+ narrative fields don't each need a column;
/// only Vendor's own fields and the audit scores are individually queryable.
model VendorQuestionnaire {
  id             String                    @id @default(uuid())
  vendorId       String
  vendor         Vendor                    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  revisionNumber Int                       @default(1)
  status         VendorQuestionnaireStatus @default(SENT)
  submittedAt    DateTime?

  // One JSON blob per VSAQ section (§1–18). Null until the vendor fills it.
  businessProfile         Json?
  manufacturingCapability Json?
  equipmentDetails        Json?
  productionCapacity      Json?
  qualityManagement       Json?
  engineeringCapability   Json?
  supplyChain             Json?
  traceability            Json?
  logistics               Json?
  sustainability          Json?
  informationSecurity     Json?
  businessContinuity      Json?
  ehs                     Json?
  financialInformation    Json?
  customerSupport         Json?
  compliance              Json?
  references              Json?
  declaration             Json?

  /// Uploaded quality-certificate files (R2-backed, guarded by Vault's rules).
  /// [{ storageKey, name, sizeBytes, contentType }] — metadata only.
  qualityCertificateFiles Json?

  invites VendorQuestionnaireInvite[]
  audits  VendorAudit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vendorId])
  @@map("vendor_questionnaires")
}

/// Token-based public invite to fill a questionnaire — same shape as Vault's
/// external share link (crypto token, expiry, revoke, optional password).
model VendorQuestionnaireInvite {
  id              String              @id @default(uuid())
  questionnaireId String
  questionnaire   VendorQuestionnaire @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
  token           String              @unique
  expiresAt       DateTime
  revokedAt       DateTime?
  passwordHash    String?
  createdById     String
  createdBy       Employee            @relation("VendorInviteCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt       DateTime            @default(now())

  @@index([questionnaireId])
  @@map("vendor_questionnaire_invites")
}

/// Internal audit of a specific questionnaire revision. totalScore and
/// classification are COMPUTED on read from the 10 weighted scores (sum=100) —
/// never stored. Finalizing sets Vendor.status to the classification.
model VendorAudit {
  id              String              @id @default(uuid())
  vendorId        String
  vendor          Vendor              @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  questionnaireId String
  questionnaire   VendorQuestionnaire @relation(fields: [questionnaireId], references: [id], onDelete: Restrict)
  auditType       VendorAuditType
  auditDate       DateTime
  auditorId       String
  auditor         Employee            @relation("VendorAuditor", fields: [auditorId], references: [id], onDelete: Restrict)

  // Weighted category scores — maxes 20/10/20/10/5/10/10/5/5/5 = 100.
  manufacturingCapabilityScore Decimal @db.Decimal(5, 2)
  capacityScore                Decimal @db.Decimal(5, 2)
  qualitySystemScore           Decimal @db.Decimal(5, 2)
  engineeringScore             Decimal @db.Decimal(5, 2)
  financialStabilityScore      Decimal @db.Decimal(5, 2)
  supplyChainScore             Decimal @db.Decimal(5, 2)
  exportReadinessScore         Decimal @db.Decimal(5, 2)
  sustainabilityScore          Decimal @db.Decimal(5, 2)
  ehsScore                     Decimal @db.Decimal(5, 2)
  customerReferencesScore      Decimal @db.Decimal(5, 2)

  auditNotes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vendorId])
  @@index([questionnaireId])
  @@map("vendor_audits")
}

// ── Supplier Qualification (SCM — raw materials) ─────────────────────
// A DISTINCT module from Vendor Qualification (see vendor-vs-supplier-
// terminology.md): raw-material suppliers, their own questionnaire sections
// and 6-category weighted audit. Reuses the shared token-invite mechanism
// (src/common/utils/token-invite) and Vault's storage guardrails. A future
// task adds the hard BOM-release gate once Item Master + BillOfMaterials exist.

enum SupplierStatus {
  PENDING_QUESTIONNAIRE
  QUESTIONNAIRE_SUBMITTED
  UNDER_AUDIT
  APPROVED_PREFERRED
  APPROVED
  CONDITIONALLY_APPROVED
  NOT_APPROVED
}

enum SupplierQuestionnaireStatus {
  SENT
  SUBMITTED
}

enum SupplierAuditType {
  PHYSICAL
  VIRTUAL
}

/// How a questionnaire reached SUBMITTED. Null until submitted. Supplier-sourced
/// data is more authoritative than data entered second-hand by internal staff,
/// so the distinction is preserved for anyone reviewing a classification.
enum SupplierFilledBy {
  EXTERNAL_SUPPLIER
  INTERNAL_STAFF
}

model Supplier {
  id                       String                   @id @default(uuid())
  /// Plain, matchable company name (future Item↔Supplier reconciliation).
  companyName              String
  registeredAddress        String                   @db.Text
  /// Factory / origin location of the raw materials.
  factoryAddress           String                   @db.Text
  yearEstablished          String
  numberOfEmployees        String
  annualTurnover           String
  msmeUdyamCertificate     String?
  contactPersonName        String
  contactPersonDesignation String
  contactEmail             String
  contactPhone             String
  website                  String?
  status                   SupplierStatus           @default(PENDING_QUESTIONNAIRE)
  createdById              String
  createdBy                Employee                 @relation("SupplierCreator", fields: [createdById], references: [id], onDelete: Restrict)
  questionnaires           SupplierQuestionnaire[]
  audits                   SupplierAudit[]
  notifications            Notification[]
  itemLinks                ItemSupplier[]           @relation("SupplierItemLinks")
  purchaseOrders           PurchaseOrder[]
  apInvoices               AccountsPayableInvoice[]
  apPayments               AccountsPayablePayment[]
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt

  @@index([status])
  @@map("suppliers")
}

/// One questionnaire revision. Section content is opaque JSON, one column per
/// section. `packagingAndDelivery` is optional (not required to submit).
model SupplierQuestionnaire {
  id             String                      @id @default(uuid())
  supplierId     String
  supplier       Supplier                    @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  revisionNumber Int                         @default(1)
  status         SupplierQuestionnaireStatus @default(SENT)
  submittedAt    DateTime?
  /// Which path produced the submission. Null until SUBMITTED.
  filledBy       SupplierFilledBy?

  materialRange          Json?
  materialCertifications Json?
  compliance             Json?
  qualityCertifications  Json?
  commercialTerms        Json?
  packagingAndDelivery   Json?
  logistics              Json?
  references             Json?
  declaration            Json?

  /// Uploaded certificate files (R2-backed, Vault guardrails).
  /// [{ storageKey, name, sizeBytes, contentType }] — metadata only.
  certificateFiles Json?

  invites SupplierQuestionnaireInvite[]
  audits  SupplierAudit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([supplierId])
  @@map("supplier_questionnaires")
}

/// Token-based public invite (shared mechanism: crypto token, expiry, revoke,
/// optional password).
model SupplierQuestionnaireInvite {
  id              String                @id @default(uuid())
  questionnaireId String
  questionnaire   SupplierQuestionnaire @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
  token           String                @unique
  expiresAt       DateTime
  revokedAt       DateTime?
  passwordHash    String?
  createdById     String
  createdBy       Employee              @relation("SupplierInviteCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt       DateTime              @default(now())

  @@index([questionnaireId])
  @@map("supplier_questionnaire_invites")
}

/// Internal audit of a questionnaire revision. Six weighted scores summing to
/// 100; totalScore + classification computed on read (thresholds 90/80/70).
model SupplierAudit {
  id              String                @id @default(uuid())
  supplierId      String
  supplier        Supplier              @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  questionnaireId String
  questionnaire   SupplierQuestionnaire @relation(fields: [questionnaireId], references: [id], onDelete: Restrict)
  auditType       SupplierAuditType
  auditDate       DateTime
  auditorId       String
  auditor         Employee              @relation("SupplierAuditor", fields: [auditorId], references: [id], onDelete: Restrict)

  // Weighted category scores — maxes 30/15/20/15/10/10 = 100.
  materialCertificationsQualityScore Decimal @db.Decimal(5, 2)
  complianceScore                    Decimal @db.Decimal(5, 2)
  commercialTermsScore               Decimal @db.Decimal(5, 2)
  logisticsDeliveryScore             Decimal @db.Decimal(5, 2)
  financialStabilityScore            Decimal @db.Decimal(5, 2)
  referencesScore                    Decimal @db.Decimal(5, 2)

  auditNotes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([supplierId])
  @@index([questionnaireId])
  @@map("supplier_audits")
}

// ─────────────────────────────────────────────────────────────────────────
// Bill of Materials + Item Master + Inventory (R&D / Store)
//
// R&D employees prepare revision-controlled BOMs for a Product; an R&D Head
// technically approves them. At project kickoff the released BOM is snapshotted
// and compared against store inventory to produce a stock-availability report.
// Quantities use Decimal(14,4) (finer than money's 14,2 — BOM per-unit
// quantities are often fractional); percentages use Decimal(5,2).
// ─────────────────────────────────────────────────────────────────────────

enum ItemType {
  RAW_MATERIAL
  COMPONENT
  SUBASSEMBLY
  FINISHED_GOOD
  CONSUMABLE
}

enum BomStatus {
  DRAFT
  PENDING_APPROVAL
  REJECTED
  RELEASED
  OBSOLETE
}

/// Make vs. buy classification of a BOM line.
enum BomLineSource {
  MAKE
  BUY
}

/// The kind of workflow action captured in a BomEvent (audit/history trail).
enum BomEventType {
  CREATED
  UPDATED
  SUBMITTED
  APPROVED
  REJECTED
  RELEASED
  OBSOLETED
  REVISION_CREATED
}

/// Which quantity bucket a stock adjustment targets. availableQuantity is
/// always DERIVED (onHand - reserved - blocked), never adjusted directly.
enum StockBucket {
  ON_HAND
  BLOCKED
}

/// Item Master. BOM lines and stock records reference items here rather than
/// free-text material names. Items are never hard-deleted when referenced —
/// they are marked inactive instead.
model Item {
  id                    String   @id @default(uuid())
  itemCode              String   @unique
  name                  String
  description           String?  @db.Text
  itemType              ItemType
  baseUnitOfMeasure     String
  isActive              Boolean  @default(true)
  /// Default wastage % applied to BOM lines using this item unless the line
  /// overrides it. Optional. Decimal(5,2).
  defaultWastagePercent Decimal? @db.Decimal(5, 2)
  drawingSpecReference  String?
  standardLeadTimeDays  Int?

  boms               Bom[]                  @relation("ItemBoms")
  bomLines           BomLine[]
  products           Product[]              @relation("ProductItem")
  stockBalances      StockBalance[]
  stockAdjustments   StockAdjustment[]
  reservations       StockReservation[]
  supplierLinks      ItemSupplier[]
  purchaseOrderLines PurchaseOrderLine[]
  grnLines           GoodsReceiptNoteLine[]
  ncrs               NonConformanceReport[]
  materialIndents    MaterialIndent[]
  materialIssueNotes MaterialIssueNote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([itemType])
  @@index([isActive])
  @@map("items")
}

/// Links a raw-material/component Item to a qualified Supplier. Powers the BOM
/// release hard-gate: a BOM referencing a RAW_MATERIAL item cannot be released
/// unless that item has at least one ItemSupplier whose Supplier status is
/// APPROVED or APPROVED_PREFERRED.
model ItemSupplier {
  id                 String   @id @default(uuid())
  itemId             String
  item               Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  supplierId         String
  supplier           Supplier @relation("SupplierItemLinks", fields: [supplierId], references: [id], onDelete: Cascade)
  /// Optional supplier's own part number for this item.
  supplierPartNumber String?
  createdById        String
  createdBy          Employee @relation("ItemSupplierLinkedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt          DateTime @default(now())

  @@unique([itemId, supplierId])
  @@index([itemId])
  @@index([supplierId])
  @@map("item_suppliers")
}

/// One BOM revision (header) for a Product. Only one RELEASED revision is
/// normally active at a time — enforced in the service transaction when a new
/// revision is released (the prior RELEASED one becomes OBSOLETE). Unique
/// (productId, revisionNumber) prevents duplicate revision numbers per product.
model Bom {
  id             String    @id @default(uuid())
  /// Keyed on the Item Master (NOT Product) so a SUBASSEMBLY/COMPONENT item that
  /// is never sold as a Product still has somewhere to attach its own BOM —
  /// this is what enables genuine multi-level explosion.
  itemId         String
  item           Item      @relation("ItemBoms", fields: [itemId], references: [id], onDelete: Restrict)
  revisionNumber Int
  status         BomStatus @default(DRAFT)
  effectiveDate  DateTime?
  revisionNotes  String?   @db.Text

  createdById      String
  createdBy        Employee  @relation("BomCreator", fields: [createdById], references: [id], onDelete: Restrict)
  submittedById    String?
  submittedBy      Employee? @relation("BomSubmitter", fields: [submittedById], references: [id], onDelete: SetNull)
  submittedAt      DateTime?
  approvedById     String?
  approvedBy       Employee? @relation("BomApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt       DateTime?
  rejectedById     String?
  rejectedBy       Employee? @relation("BomRejecter", fields: [rejectedById], references: [id], onDelete: SetNull)
  rejectedAt       DateTime?
  rejectionComment String?   @db.Text

  /// Signature snapshot captured at approval (mirrors OrderConfirmationSheet /
  /// Bid): the approver's typed-signature text + font at the moment of approval.
  approverSignatureTextSnapshot String?
  approverSignatureFontSnapshot SignatureFont?

  lines             BomLine[]
  events            BomEvent[]
  notifications     Notification[]
  kickoffSelections KickoffBomSelection[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([itemId, revisionNumber])
  @@index([itemId])
  @@index([status])
  @@map("boms")
}

/// A single material line on a BOM revision.
model BomLine {
  id                   String        @id @default(uuid())
  bomId                String
  bom                  Bom           @relation(fields: [bomId], references: [id], onDelete: Cascade)
  itemId               String
  item                 Item          @relation(fields: [itemId], references: [id], onDelete: Restrict)
  /// Quantity of this item per ONE finished product unit. Decimal(14,4).
  quantityPerUnit      Decimal       @db.Decimal(14, 4)
  unitOfMeasure        String
  wastagePercent       Decimal       @default(0) @db.Decimal(5, 2)
  makeBuy              BomLineSource @default(BUY)
  notes                String?       @db.Text
  drawingSpecReference String?
  sequence             Int           @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bomId])
  @@index([itemId])
  @@map("bom_lines")
}

/// Immutable workflow-event / approval-history trail for a BOM (in addition to
/// the global audit log). Records who did what and any comment.
model BomEvent {
  id        String       @id @default(uuid())
  bomId     String
  bom       Bom          @relation(fields: [bomId], references: [id], onDelete: Cascade)
  type      BomEventType
  actorId   String?
  actor     Employee?    @relation("BomEventActor", fields: [actorId], references: [id], onDelete: SetNull)
  comment   String?      @db.Text
  createdAt DateTime     @default(now())

  @@index([bomId, createdAt])
  @@map("bom_events")
}

/// A physical store / warehouse location that holds stock.
model StoreLocation {
  id       String  @id @default(uuid())
  code     String  @unique
  name     String
  isActive Boolean @default(true)

  stockBalances      StockBalance[]
  stockAdjustments   StockAdjustment[]
  reservations       StockReservation[]
  grnLines           GoodsReceiptNoteLine[]
  materialIssueNotes MaterialIssueNote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("store_locations")
}

/// On-hand / reserved / blocked balance for one item at one location.
/// availableQuantity is DERIVED on read (onHand - reserved - blocked) and is
/// never stored as an independently editable value.
model StockBalance {
  id              String        @id @default(uuid())
  itemId          String
  item            Item          @relation(fields: [itemId], references: [id], onDelete: Restrict)
  storeLocationId String
  storeLocation   StoreLocation @relation(fields: [storeLocationId], references: [id], onDelete: Restrict)

  onHandQuantity   Decimal @default(0) @db.Decimal(14, 4)
  reservedQuantity Decimal @default(0) @db.Decimal(14, 4)
  blockedQuantity  Decimal @default(0) @db.Decimal(14, 4)

  /// Optional inbound-supply visibility for the EXPECTED_BEFORE_REQUIRED_DATE
  /// availability status.
  expectedReceiptQuantity Decimal?  @db.Decimal(14, 4)
  expectedReceiptDate     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([itemId, storeLocationId])
  @@index([itemId])
  @@map("stock_balances")
}

/// Append-only history of every stock movement (actor, reason, delta, bucket).
model StockAdjustment {
  id              String        @id @default(uuid())
  itemId          String
  item            Item          @relation(fields: [itemId], references: [id], onDelete: Restrict)
  storeLocationId String
  storeLocation   StoreLocation @relation(fields: [storeLocationId], references: [id], onDelete: Restrict)
  bucket          StockBucket   @default(ON_HAND)
  /// Signed change applied to the bucket (positive = increase). Decimal(14,4).
  quantityChange  Decimal       @db.Decimal(14, 4)
  reason          String
  actorId         String?
  actor           Employee?     @relation("StockAdjustmentActor", fields: [actorId], references: [id], onDelete: SetNull)
  createdAt       DateTime      @default(now())

  @@index([itemId, storeLocationId])
  @@index([createdAt])
  @@map("stock_adjustments")
}

/// A material reservation held against a specific project kickoff. Reservations
/// increment StockBalance.reservedQuantity in the same transaction. Cancelling
/// releases the quantity. Re-running the kickoff report treats reservations
/// belonging to the SAME kickoff as already-earmarked (not a competing demand),
/// so it never double-counts them.
model StockReservation {
  id              String         @id @default(uuid())
  kickoffId       String
  kickoff         ProjectKickoff @relation("KickoffReservations", fields: [kickoffId], references: [id], onDelete: Cascade)
  itemId          String
  item            Item           @relation(fields: [itemId], references: [id], onDelete: Restrict)
  storeLocationId String
  storeLocation   StoreLocation  @relation(fields: [storeLocationId], references: [id], onDelete: Restrict)
  quantity        Decimal        @db.Decimal(14, 4)
  isActive        Boolean        @default(true)

  createdById   String
  createdBy     Employee  @relation("ReservationCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt     DateTime  @default(now())
  cancelledById String?
  cancelledBy   Employee? @relation("ReservationCanceller", fields: [cancelledById], references: [id], onDelete: SetNull)
  cancelledAt   DateTime?

  @@index([kickoffId])
  @@index([itemId, storeLocationId])
  @@map("stock_reservations")
}

// ── Kickoff stock-availability snapshot ──────────────────────────────────
// The report is snapshotted the first time it is generated so later BOM
// revisions never retroactively change a historical kickoff report.

/// One stock-availability report per kickoff (created on first generate).
model KickoffStockReport {
  id                String         @id @default(uuid())
  kickoffId         String         @unique
  kickoff           ProjectKickoff @relation(fields: [kickoffId], references: [id], onDelete: Cascade)
  generatedAt       DateTime       @default(now())
  /// Chosen decimal precision for requirement math, recorded for provenance.
  quantityPrecision Int            @default(4)

  bomSelections KickoffBomSelection[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("kickoff_stock_reports")
}

/// Which released BOM revision was selected for a given ordered product at
/// snapshot time. Stores the revision id + number for provenance; the copied
/// lines below preserve historical accuracy independent of the live BOM.
model KickoffBomSelection {
  id                String             @id @default(uuid())
  reportId          String
  report            KickoffStockReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  /// The order line item this selection was generated for.
  orderLineItemId   String
  productId         String
  productName       String
  productSku        String
  orderedQuantity   Decimal            @db.Decimal(14, 4)
  bomId             String
  bom               Bom                @relation(fields: [bomId], references: [id], onDelete: Restrict)
  bomRevisionNumber Int

  lines KickoffBomSnapshotLine[]

  createdAt DateTime @default(now())

  @@index([reportId])
  @@map("kickoff_bom_selections")
}

/// A copied BOM line captured at snapshot time. Enough data is copied
/// (item identity, quantities, wastage, UoM) that the report is reproducible
/// even after the source BOM is obsoleted or edited into a new revision.
model KickoffBomSnapshotLine {
  id              String              @id @default(uuid())
  selectionId     String
  selection       KickoffBomSelection @relation(fields: [selectionId], references: [id], onDelete: Cascade)
  itemId          String
  itemCode        String
  itemName        String
  unitOfMeasure   String
  quantityPerUnit Decimal             @db.Decimal(14, 4)
  wastagePercent  Decimal             @db.Decimal(5, 2)

  createdAt DateTime @default(now())

  @@index([selectionId])
  @@map("kickoff_bom_snapshot_lines")
}

// ── Finance & Accounts foundation ───────────────────────────────────────

enum FiscalYearStatus {
  OPEN
  SOFT_CLOSED
  CLOSED
}

enum AccountingPeriodStatus {
  OPEN
  SOFT_CLOSED
  CLOSED
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  COST_OF_GOODS_SOLD
  EXPENSE
  OTHER_INCOME
  OTHER_EXPENSE
}

enum CashFlowCategory {
  OPERATING
  INVESTING
  FINANCING
  NON_CASH
}

enum NormalBalance {
  DEBIT
  CREDIT
}

enum JournalStatus {
  DRAFT
  PENDING_APPROVAL
  POSTED
  REJECTED
  REVERSED
}

/// India financial year (1 April through 31 March). Periods are generated as
/// twelve calendar months and lock posting independently.
model FiscalYear {
  id          String             @id @default(uuid())
  name        String             @unique
  startsOn    DateTime
  endsOn      DateTime
  status      FiscalYearStatus   @default(OPEN)
  createdById String
  createdBy   Employee           @relation("FiscalYearCreator", fields: [createdById], references: [id], onDelete: Restrict)
  periods     AccountingPeriod[]
  budgets     FinanceBudget[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([startsOn, endsOn])
  @@map("fiscal_years")
}

model AccountingPeriod {
  id                  String                     @id @default(uuid())
  fiscalYearId        String
  fiscalYear          FiscalYear                 @relation(fields: [fiscalYearId], references: [id], onDelete: Restrict)
  periodNumber        Int
  name                String
  startsOn            DateTime
  endsOn              DateTime
  status              AccountingPeriodStatus     @default(OPEN)
  journals            JournalEntry[]
  periodClose         PeriodClose?
  budgetLines         FinanceBudgetLine[]
  depreciationEntries AssetDepreciationEntry[]
  scheduleExecutions  FinanceScheduleExecution[]
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt

  @@unique([fiscalYearId, periodNumber])
  @@index([startsOn, endsOn])
  @@map("accounting_periods")
}

model LedgerAccount {
  id                                String               @id @default(uuid())
  code                              String               @unique
  name                              String
  accountType                       AccountType
  normalBalance                     NormalBalance
  description                       String?              @db.Text
  parentId                          String?
  parent                            LedgerAccount?       @relation("AccountHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children                          LedgerAccount[]      @relation("AccountHierarchy")
  isControlAccount                  Boolean              @default(false)
  isActive                          Boolean              @default(true)
  cashFlowCategory                  CashFlowCategory?
  createdById                       String
  createdBy                         Employee             @relation("LedgerAccountCreator", fields: [createdById], references: [id], onDelete: Restrict)
  journalLines                      JournalLine[]
  bankAccounts                      FinanceBankAccount[]
  budgetLines                       FinanceBudgetLine[]
  fixedAssetCosts                   FixedAsset[]         @relation("FixedAssetCostAccount")
  fixedAssetAccumulatedDepreciation FixedAsset[]         @relation("FixedAssetAccumulatedDepAccount")
  fixedAssetDepreciationExpenses    FixedAsset[]         @relation("FixedAssetDepExpenseAccount")
  fixedAssetAcquisitionCredits      FixedAsset[]         @relation("FixedAssetAcquisitionCreditAccount")
  scheduleDebits                    FinanceSchedule[]    @relation("FinanceScheduleDebitAccount")
  scheduleCredits                   FinanceSchedule[]    @relation("FinanceScheduleCreditAccount")
  createdAt                         DateTime             @default(now())
  updatedAt                         DateTime             @updatedAt

  @@index([accountType, isActive])
  @@index([parentId])
  @@map("ledger_accounts")
}

enum ManagementPackStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PUBLISHED
}

enum YearEndRolloverStatus {
  DRAFT
  PENDING_APPROVAL
  COMPLETED
}

model FinanceAuditorGrant {
  id          String    @id @default(uuid())
  employeeId  String    @unique
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  grantedById String
  grantedAt   DateTime  @default(now())
  revokedById String?
  revokedAt   DateTime?

  @@index([isActive, expiresAt])
  @@map("finance_auditor_grants")
}

model ManagementReportPack {
  id            String               @id @default(uuid())
  packNumber    String               @unique
  title         String
  periodFrom    DateTime
  periodTo      DateTime
  status        ManagementPackStatus @default(DRAFT)
  snapshot      Json
  createdById   String
  submittedById String?
  submittedAt   DateTime?
  approvedById  String?
  approvedAt    DateTime?
  publishedAt   DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([status, periodTo])
  @@map("management_report_packs")
}

model YearEndRollover {
  id                        String                  @id @default(uuid())
  sourceFiscalYearId        String                  @unique
  targetFiscalYearId        String
  status                    YearEndRolloverStatus   @default(DRAFT)
  retainedEarningsAccountId String
  snapshot                  Json
  createdById               String
  submittedById             String?
  submittedAt               DateTime?
  approvedById              String?
  approvedAt                DateTime?
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt
  openingBalances           AccountOpeningBalance[]

  @@index([status])
  @@map("year_end_rollovers")
}

model AccountOpeningBalance {
  id           String          @id @default(uuid())
  rolloverId   String
  rollover     YearEndRollover @relation(fields: [rolloverId], references: [id], onDelete: Cascade)
  fiscalYearId String
  accountId    String
  debit        Decimal         @default(0) @db.Decimal(18, 2)
  credit       Decimal         @default(0) @db.Decimal(18, 2)
  createdAt    DateTime        @default(now())

  @@unique([fiscalYearId, accountId])
  @@index([rolloverId])
  @@map("account_opening_balances")
}

model CostCenter {
  id               String              @id @default(uuid())
  code             String              @unique
  name             String
  description      String?             @db.Text
  isActive         Boolean             @default(true)
  createdById      String
  createdBy        Employee            @relation("CostCenterCreator", fields: [createdById], references: [id], onDelete: Restrict)
  journalLines     JournalLine[]
  budgetLines      FinanceBudgetLine[]
  financeSchedules FinanceSchedule[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@map("cost_centers")
}

/// Supported document currency. INR is the functional/base currency.
model Currency {
  code          String         @id @db.VarChar(3)
  name          String
  symbol        String
  decimalPlaces Int            @default(2)
  isBase        Boolean        @default(false)
  isActive      Boolean        @default(true)
  exchangeRates ExchangeRate[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("currencies")
}

/// Manually maintained rate: one unit of foreign currency expressed in INR.
model ExchangeRate {
  id           String   @id @default(uuid())
  currencyCode String   @db.VarChar(3)
  currency     Currency @relation(fields: [currencyCode], references: [code], onDelete: Restrict)
  effectiveOn  DateTime
  rateToInr    Decimal  @db.Decimal(18, 6)
  source       String
  createdById  String
  createdBy    Employee @relation("ExchangeRateCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt    DateTime @default(now())

  @@unique([currencyCode, effectiveOn])
  @@index([effectiveOn])
  @@map("exchange_rates")
}

model FinanceSequence {
  entity    String
  year      Int
  lastValue Int      @default(0)
  updatedAt DateTime @updatedAt

  @@id([entity, year])
  @@map("finance_sequences")
}

/// Manual journal header. Only POSTED entries contribute to financial reports.
/// Posted entries are immutable; correction is by an explicit reversal.
model JournalEntry {
  id                String                    @id @default(uuid())
  journalNumber     String                    @unique
  entryDate         DateTime
  periodId          String
  period            AccountingPeriod          @relation(fields: [periodId], references: [id], onDelete: Restrict)
  description       String                    @db.Text
  reference         String?
  status            JournalStatus             @default(DRAFT)
  createdById       String
  createdBy         Employee                  @relation("JournalCreator", fields: [createdById], references: [id], onDelete: Restrict)
  submittedById     String?
  submittedBy       Employee?                 @relation("JournalSubmitter", fields: [submittedById], references: [id], onDelete: SetNull)
  submittedAt       DateTime?
  approvedById      String?
  approvedBy        Employee?                 @relation("JournalApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt        DateTime?
  rejectedById      String?
  rejectedBy        Employee?                 @relation("JournalRejecter", fields: [rejectedById], references: [id], onDelete: SetNull)
  rejectedAt        DateTime?
  rejectionComment  String?                   @db.Text
  reversedById      String?
  reversedBy        Employee?                 @relation("JournalReverser", fields: [reversedById], references: [id], onDelete: SetNull)
  reversedAt        DateTime?
  reversalOfId      String?                   @unique
  reversalOf        JournalEntry?             @relation("JournalReversal", fields: [reversalOfId], references: [id], onDelete: Restrict)
  reversalEntry     JournalEntry?             @relation("JournalReversal")
  lines             JournalLine[]
  salesInvoice      SalesInvoice?             @relation("SalesInvoiceJournal")
  customerReceipt   CustomerReceipt?          @relation("CustomerReceiptJournal")
  apInvoice         AccountsPayableInvoice?   @relation("ApInvoiceJournal")
  apPayment         AccountsPayablePayment?   @relation("ApPaymentJournal")
  financeNote       FinanceAdjustmentNote?    @relation("FinanceNoteJournal")
  bankMatches       BankTransactionMatch[]
  depreciationEntry AssetDepreciationEntry?
  scheduleExecution FinanceScheduleExecution?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  @@index([entryDate, status])
  @@index([periodId, status])
  @@map("journal_entries")
}

model JournalLine {
  id               String        @id @default(uuid())
  journalId        String
  journal          JournalEntry  @relation(fields: [journalId], references: [id], onDelete: Cascade)
  sequence         Int
  accountId        String
  account          LedgerAccount @relation(fields: [accountId], references: [id], onDelete: Restrict)
  description      String?
  debit            Decimal       @default(0) @db.Decimal(18, 2)
  credit           Decimal       @default(0) @db.Decimal(18, 2)
  costCenterId     String?
  costCenter       CostCenter?   @relation(fields: [costCenterId], references: [id], onDelete: Restrict)
  projectReference String?

  @@unique([journalId, sequence])
  @@index([accountId])
  @@index([costCenterId])
  @@map("journal_lines")
}

// ─────────────────────────────────────────────────────────────────────────
// Purchasing (Stores Phase 1) — Purchase Orders. GRN/QC/material-issue are
// later phases; this is the self-contained foundation.
// ─────────────────────────────────────────────────────────────────────────

/// PO lifecycle. Phase 1 only performs the MANUAL transitions
/// DRAFT → ISSUED → CANCELLED. PARTIALLY_RECEIVED / FULLY_RECEIVED are reserved
/// here so Phase 2 can plug in receipt-based derivation (computed from GRN data)
/// without a migration — the enum values already exist.
enum PurchaseOrderStatus {
  DRAFT
  ISSUED
  PARTIALLY_RECEIVED
  FULLY_RECEIVED
  CANCELLED
}

/// A purchase order raised on exactly ONE trading partner — either a Supplier
/// (raw-material qualification track) or a Vendor (general qualification track).
/// Exactly-one-of is enforced in the service AND by a DB CHECK constraint added
/// in the migration. There is deliberately NO stored received-quantity anywhere;
/// receipt progress is computed from GRN data in a later phase.
model PurchaseOrder {
  id       String              @id @default(uuid())
  /// PO-YYYY-#### via the shared year-prefixed sequence (SalesNumberingService),
  /// resetting annually like Bids/Orders.
  poNumber String              @unique
  status   PurchaseOrderStatus @default(DRAFT)

  /// Exactly one of supplierId / vendorId is set (CHECK constraint in migration).
  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  vendorId   String?
  vendor     Vendor?   @relation(fields: [vendorId], references: [id], onDelete: Restrict)

  orderDate            DateTime  @default(now())
  expectedDeliveryDate DateTime?
  notes                String?   @db.Text

  createdById String
  createdBy   Employee  @relation("PurchaseOrderCreator", fields: [createdById], references: [id], onDelete: Restrict)
  /// Set when the PO moves DRAFT → ISSUED.
  issuedAt    DateTime?
  /// Set when the PO is CANCELLED.
  cancelledAt DateTime?

  lines             PurchaseOrderLine[]
  goodsReceiptNotes GoodsReceiptNote[]
  apInvoices        AccountsPayableInvoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([supplierId])
  @@index([vendorId])
  @@map("purchase_orders")
}

/// One ordered line. lineTotal is stored (orderedQuantity × unitPrice, computed
/// at write) mirroring OrderLineItem. unitOfMeasure is snapshotted from the Item
/// at creation. NO receivedQuantity — that is computed from GRN data later.
model PurchaseOrderLine {
  id              String        @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  itemId          String
  item            Item          @relation(fields: [itemId], references: [id], onDelete: Restrict)
  orderedQuantity Decimal       @db.Decimal(14, 4)
  unitPrice       Decimal       @db.Decimal(14, 2)
  /// UoM snapshot at PO time (Item.baseUnitOfMeasure can change later).
  unitOfMeasure   String
  lineTotal       Decimal       @db.Decimal(14, 2)
  notes           String?       @db.Text
  sequence        Int           @default(0)

  grnLines       GoodsReceiptNoteLine[]
  apInvoiceLines AccountsPayableInvoiceLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([purchaseOrderId])
  @@index([itemId])
  @@map("purchase_order_lines")
}

