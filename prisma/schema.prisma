  exceptionReason String?               @db.Text
  match           BankTransactionMatch?
  createdAt       DateTime              @default(now())

  @@unique([statementId, sequence])
  @@index([transactionDate])
  @@index([resolution])
  @@map("bank_statement_lines")
}

model BankTransactionMatch {
  id                String                  @id @default(uuid())
  statementLineId   String                  @unique
  statementLine     BankStatementLine       @relation(fields: [statementLineId], references: [id], onDelete: Cascade)
