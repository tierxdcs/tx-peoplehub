  importedById     String
  importedBy       Employee            @relation("BankStatementImporter", fields: [importedById], references: [id], onDelete: Restrict)
  submittedById    String?
  submittedBy      Employee?           @relation("BankStatementSubmitter", fields: [submittedById], references: [id], onDelete: SetNull)
  submittedAt      DateTime?
  approvedById     String?
  approvedBy       Employee?           @relation("BankStatementApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt       DateTime?
