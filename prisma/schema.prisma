  customerReceipt   CustomerReceipt?        @relation(fields: [customerReceiptId], references: [id], onDelete: Restrict)
  apPaymentId       String?                 @unique
  apPayment         AccountsPayablePayment? @relation(fields: [apPaymentId], references: [id], onDelete: Restrict)
  journalEntryId    String?                 @unique
  journalEntry      JournalEntry?           @relation(fields: [journalEntryId], references: [id], onDelete: Restrict)
  confidenceScore   Decimal                 @db.Decimal(5, 2)
  matchReason       String
  confirmedById     String?
  confirmedBy       Employee?               @relation("BankMatchConfirmer", fields: [confirmedById], references: [id], onDelete: SetNull)
  confirmedAt       DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@map("bank_transaction_matches")
}

