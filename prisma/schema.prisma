/// An additive internal share: grants one employee VIEW/EDIT on one file or
/// folder, ON TOP OF whatever the resource's default scope / folder
/// permissions already give them. Folded into VaultAccessService — never
/// reduces existing access. resourceId is polymorphic per resourceType, so
/// there is no FK on it (a share is cleaned up in the service, or orphaned
/// harmlessly if the resource is hard-deleted).
model VaultInternalShare {
  id                   String                 @id @default(uuid())
  resourceType         VaultShareResourceType
  resourceId           String
  sharedWithEmployeeId String
  sharedWithEmployee   Employee               @relation("VaultShareRecipient", fields: [sharedWithEmployeeId], references: [id], onDelete: Cascade)
  permission           VaultSharePermission
  sharedById           String
  sharedBy             Employee               @relation("VaultShareGrantor", fields: [sharedById], references: [id], onDelete: Cascade)
  createdAt            DateTime               @default(now())

  // One live share per (resource, recipient): re-sharing updates the level.
  @@unique([resourceType, resourceId, sharedWithEmployeeId])
  @@index([sharedWithEmployeeId])
  @@index([resourceType, resourceId])
  @@map("vault_internal_shares")
}

/// A public, unauthenticated external share link. `token` is a cryptographically
/// random secret (the only credential), permission is ALWAYS VIEW (no edit,
/// ever). For a FILE it PINS `pinnedVersionId` — the version current at
/// creation time — and keeps serving that even after newer versions land
/// (not a live "current" pointer). Optional passwordHash + expiresAt (default
/// 24h) + revokedAt gate access. PERSONAL folders can't be link-shared whole
/// (service-enforced); individual files within them can.
model VaultExternalShareLink {
  id              String                   @id @default(uuid())
  resourceType    VaultShareResourceType
  resourceId      String
  token           String                   @unique
  /// Always VIEW — kept as a column for audit clarity, never anything else.
  permission      VaultSharePermission     @default(VIEW)
  /// Pinned version for FILE links (null for FOLDER links). No FK action on
  /// delete beyond SetNull so a pruned version doesn't cascade-remove the link
  /// row (the link simply stops resolving — handled in the service).
  pinnedVersionId String?
  pinnedVersion   VaultFileVersion?        @relation(fields: [pinnedVersionId], references: [id], onDelete: SetNull)
  passwordHash    String?
  expiresAt       DateTime
  revokedAt       DateTime?
  createdById     String
  createdBy       Employee                 @relation("VaultExternalShareCreator", fields: [createdById], references: [id], onDelete: Cascade)
  accessLogs      VaultExternalAccessLog[]
  createdAt       DateTime                 @default(now())

  @@index([resourceType, resourceId])
  @@map("vault_external_share_links")
}

/// Audit trail for every public-link access ATTEMPT (success or failure —
/// expired/revoked/bad-password hits are logged too). IP + user agent captured
/// for security review.
model VaultExternalAccessLog {
  id          String                 @id @default(uuid())
  shareLinkId String
  shareLink   VaultExternalShareLink @relation(fields: [shareLinkId], references: [id], onDelete: Cascade)
  accessedAt  DateTime               @default(now())
  ipAddress   String?
  userAgent   String?

  @@index([shareLinkId])
  @@map("vault_external_access_logs")
}

// ---- Kanban models ----

/// A Trello-like board. NOT vertical-scoped — access is by explicit membership
/// (KanbanBoardMember) only, plus SUPER_ADMIN as a full override. Created by a
/// Scrum Master or SUPER_ADMIN; the creator is auto-added as a member.
model KanbanBoard {
  id              String              @id @default(uuid())
  name            String
  createdById     String
  createdBy       Employee            @relation("KanbanBoardCreator", fields: [createdById], references: [id], onDelete: Restrict)
  status          KanbanBoardStatus   @default(ACTIVE)
  members         KanbanBoardMember[]
  lists           KanbanList[]
  sprints         KanbanSprint[]
  labels          KanbanLabel[]
  projectKickoffs ProjectKickoff[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([status])
  @@map("kanban_boards")
}

/// Explicit board membership — the sole access mechanism (besides SUPER_ADMIN).
model KanbanBoardMember {
  id         String      @id @default(uuid())
  boardId    String
  board      KanbanBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  employeeId String
  employee   Employee    @relation("KanbanBoardMember", fields: [employeeId], references: [id], onDelete: Cascade)
  addedById  String
  addedBy    Employee    @relation("KanbanBoardMemberAddedBy", fields: [addedById], references: [id], onDelete: Restrict)
  addedAt    DateTime    @default(now())

  @@unique([boardId, employeeId])
  @@index([employeeId])
  @@map("kanban_board_members")
}

/// A column on a board. Created by Scrum Master / SUPER_ADMIN only.
model KanbanList {
  id          String       @id @default(uuid())
  boardId     String
  board       KanbanBoard  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  name        String
  /// Fractional ordering, same scheme as KanbanCard.position — reordering a
  /// list is a single-row update between two neighbours' positions.
  position    Float
  /// Marks a "done"-type column. A card sitting here is never flagged overdue
  /// even if its dueDate has passed. Settable by Scrum Master / SUPER_ADMIN.
  isDoneList  Boolean      @default(false)
  createdById String
  createdBy   Employee     @relation("KanbanListCreator", fields: [createdById], references: [id], onDelete: Restrict)
  cards       KanbanCard[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([boardId, position])
  @@map("kanban_lists")
}

/// Persistent audit of the one-time done-list backfill. Kept so administrators
/// can review and correct heuristic selections instead of relying on SQL logs.
model KanbanDoneListBackfillReport {
  id               String   @id @default(uuid())
  boardId          String   @unique
  boardName        String
  selectedListId   String
  selectedListName String
  selectionReason  String
  createdAt        DateTime @default(now())

  @@map("kanban_done_list_backfill_report")
}

/// A time-boxed sprint on a board. Status (UPCOMING/ACTIVE/COMPLETED) is
/// COMPUTED from dates at read time, never stored. endDate is computed once at
/// creation (startDate + durationWeeks*7d) and stored. SM / SUPER_ADMIN only.
model KanbanSprint {
  id            String               @id @default(uuid())
  boardId       String
  board         KanbanBoard          @relation(fields: [boardId], references: [id], onDelete: Cascade)
  name          String
  durationWeeks KanbanSprintDuration
  startDate     DateTime
  endDate       DateTime
  createdById   String
  createdBy     Employee             @relation("KanbanSprintCreator", fields: [createdById], references: [id], onDelete: Restrict)
  cards         KanbanCard[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([boardId])
  @@map("kanban_sprints")
}

/// A card in a list. Members create/edit/move/comment; only SM/SUPER_ADMIN may
/// set sprintId. assigneeId need NOT be a board member — assignment itself
/// grants a non-member restricted "card-only" access to this one card.
model KanbanCard {
  id                String                 @id @default(uuid())
  listId            String
  list              KanbanList             @relation(fields: [listId], references: [id], onDelete: Cascade)
  title             String
  description       String?                @db.Text
  assigneeId        String?
  assignee          Employee?              @relation("KanbanCardAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  /// Which vertical/department this card's work belongs to. Server-managed and
  /// synchronized from the assignee's vertical; clients cannot edit it. Powers per-vertical
  /// completion on a project board (e.g. "Production 2/7 done") for order
  /// progress tracking (see ORDER_TRACKING.md).
  verticalId        String?
  vertical          Vertical?              @relation(fields: [verticalId], references: [id], onDelete: SetNull)
  startDate         DateTime?
  dueDate           DateTime?
  priority          LeadPriority           @default(MEDIUM)
  sprintId          String?
  sprint            KanbanSprint?          @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  /// Fractional ordering within the list — inserting between two cards uses a
  /// value between their positions, so a move is a single-row update (no
  /// reindex). Re-spaced only when adjacent values get too close.
  position          Float
  createdById       String
  createdBy         Employee               @relation("KanbanCardCreator", fields: [createdById], references: [id], onDelete: Restrict)
  status            KanbanCardStatus       @default(ACTIVE)
  comments          KanbanCardComment[]
  activity          KanbanCardActivity[]
  attachments       KanbanCardAttachment[]
  notifications     Notification[]
  labels            KanbanCardLabel[]
  kickoffActionItem KickoffActionItem?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@index([listId, position])
  @@index([sprintId])
  @@index([assigneeId])
  @@index([verticalId])
  @@map("kanban_cards")
}

/// A board-scoped colored label. Definition (create/edit/delete) is restricted
/// to Scrum Master / SUPER_ADMIN; any member may attach an existing label to a
/// card (via KanbanCardLabel).
model KanbanLabel {
  id        String            @id @default(uuid())
  boardId   String
  board     KanbanBoard       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  name      String
  /// Free-form color token (e.g. a hex or a named swatch) — the UI maps it.
  color     String
  cards     KanbanCardLabel[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([boardId])
  @@map("kanban_labels")
}

/// Join table: which labels are attached to which cards.
model KanbanCardLabel {
  cardId  String
  card    KanbanCard  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  labelId String
  label   KanbanLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([cardId, labelId])
  @@index([labelId])
  @@map("kanban_card_labels")
}

/// A user-authored comment on a card.
model KanbanCardComment {
  id        String     @id @default(uuid())
  cardId    String
  card      KanbanCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  authorId  String
  author    Employee   @relation("KanbanCommentAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  text      String     @db.Text
  createdAt DateTime   @default(now())

  @@index([cardId, createdAt])
  @@map("kanban_card_comments")
}

/// Auto-generated, human-readable card timeline (separate from AuditLog).
/// Written whenever a card's list/assignee/sprint/priority/dates change.
model KanbanCardActivity {
  id          String     @id @default(uuid())
  cardId      String
  card        KanbanCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  actorId     String
  actor       Employee   @relation("KanbanActivityActor", fields: [actorId], references: [id], onDelete: Restrict)
  description String
  createdAt   DateTime   @default(now())

  @@index([cardId, createdAt])
  @@map("kanban_card_activity")
}

/// A file attached to a Kanban card. Bytes live in R2 (storageKey), uploaded
/// browser→R2 via a presigned PUT and reusing VaultStorageService directly —
/// NOT the Vault folder/permission model (a card attachment is scoped to the
/// card, not a vault folder). PENDING until the upload is confirmed (headObject
/// verifies it landed), then ACTIVE; only ACTIVE rows are surfaced.
model KanbanCardAttachment {
  id           String                     @id @default(uuid())
  cardId       String
  card         KanbanCard                 @relation(fields: [cardId], references: [id], onDelete: Cascade)
  filename     String
  contentType  String
  sizeBytes    BigInt
  /// R2 object key: kanban/cards/{cardId}/attachments/{id}
  storageKey   String
  status       KanbanCardAttachmentStatus @default(PENDING)
  uploadedById String
  uploadedBy   Employee                   @relation("KanbanAttachmentUploader", fields: [uploadedById], references: [id], onDelete: Restrict)
  createdAt    DateTime                   @default(now())

  @@index([cardId, createdAt])
  @@map("kanban_card_attachments")
}

enum KanbanCardAttachmentStatus {
  PENDING
  ACTIVE
}

/// Generic in-app notification (things worth KNOWING). Distinct from the
/// pending-approvals counters (things needing ACTION). Poll-based, like the
/// rest of the app's notification surfaces.
model Notification {
  id                String           @id @default(uuid())
  employeeId        String
  employee          Employee         @relation("NotificationRecipient", fields: [employeeId], references: [id], onDelete: Cascade)
  type              NotificationType
  /// Deep-link target for card-based notifications (Kanban). Null for others.
  relatedCardId     String?
  relatedCard       KanbanCard?      @relation(fields: [relatedCardId], references: [id], onDelete: Cascade)
  /// Deep-link target for vendor-based notifications (SCM). Null for others.
  /// A notification carries at most one related-entity id, by type.
  relatedVendorId   String?
  relatedVendor     Vendor?          @relation(fields: [relatedVendorId], references: [id], onDelete: Cascade)
  /// Deep-link target for supplier-based notifications (SCM raw-materials).
  relatedSupplierId String?
  relatedSupplier   Supplier?        @relation(fields: [relatedSupplierId], references: [id], onDelete: Cascade)
  /// Deep-link target for BOM workflow notifications (R&D). Null for others.
  relatedBomId      String?
  relatedBom        Bom?             @relation(fields: [relatedBomId], references: [id], onDelete: Cascade)
  message           String
  isRead            Boolean          @default(false)
  createdAt         DateTime         @default(now())

  @@index([employeeId, isRead])
  @@map("notifications")
}

// ── Project Kickoff ──────────────────────────────────────────────────
// A structured record of the cross-functional kickoff held once an Order's
// Confirmation Sheet is EXECUTED. Action items are mirrored as real Kanban
// cards on an auto-provisioned project board; their status is READ from the
// card's list at query time (no stored action-item status → no drift).

enum KickoffMeetingMode {
  IN_PERSON
  VIRTUAL
  HYBRID
}

enum KickoffStatus {
  DRAFT
  COMPLETED
}

enum KickoffMilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  DELAYED
}

enum KickoffRiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum KickoffRiskStatus {
  OPEN
  MITIGATED
  CLOSED
}

model ProjectKickoff {
  id               String             @id @default(uuid())
  orderId          String
  order            Order              @relation(fields: [orderId], references: [id], onDelete: Restrict)
  projectName      String
  meetingDate      DateTime
  meetingMode      KickoffMeetingMode @default(VIRTUAL)
  meetingLocation  String?
  overviewAndScope String?            @db.Text
  minutesNotes     String?            @db.Text
  status           KickoffStatus      @default(DRAFT)
  /// The project board auto-provisioned at creation (§5). Restrict so a board
  /// backing a kickoff can't be deleted out from under it.
  kanbanBoardId    String
  kanbanBoard      KanbanBoard        @relation(fields: [kanbanBoardId], references: [id], onDelete: Restrict)
  createdById      String
  createdBy        Employee           @relation("KickoffCreator", fields: [createdById], references: [id], onDelete: Restrict)

  attendees         KickoffAttendee[]
  milestones        KickoffMilestone[]
  actionItems       KickoffActionItem[]
  risks             KickoffRisk[]
  stockReport       KickoffStockReport?
  stockReservations StockReservation[]  @relation("KickoffReservations")
  materialIndents   MaterialIndent[]
  rfqs              Rfq[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([createdById])
  @@map("project_kickoffs")
}

/// One attendance record. Exactly one of employeeId / externalName is set
/// (internal vs. external attendee) — enforced at the service layer.
model KickoffAttendee {
  id                   String         @id @default(uuid())
  kickoffId            String
  kickoff              ProjectKickoff @relation(fields: [kickoffId], references: [id], onDelete: Cascade)
  employeeId           String?
  employee             Employee?      @relation("KickoffAttendeeEmployee", fields: [employeeId], references: [id], onDelete: SetNull)
  externalName         String?
  externalOrganization String?
  designation          String?
  department           String?
  createdAt            DateTime       @default(now())

  @@index([kickoffId])
  @@map("kickoff_attendees")
}

/// A project-level checkpoint. Standalone (NOT linked to Kanban) — milestones
/// are checkpoints, distinct from individually-actionable tasks.
model KickoffMilestone {
  id         String                 @id @default(uuid())
  kickoffId  String
  kickoff    ProjectKickoff         @relation(fields: [kickoffId], references: [id], onDelete: Cascade)
  name       String
  targetDate DateTime
  ownerId    String?
  owner      Employee?              @relation("KickoffMilestoneOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  status     KickoffMilestoneStatus @default(PENDING)
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt

  @@index([kickoffId])
  @@map("kickoff_milestones")
}

/// An actionable task. Mirrored 1:1 to a Kanban card; the item's DISPLAYED
/// status is derived from that card's list at read time (no stored status).
model KickoffActionItem {
  id           String         @id @default(uuid())
  kickoffId    String
  kickoff      ProjectKickoff @relation(fields: [kickoffId], references: [id], onDelete: Cascade)
  description  String
  ownerId      String
  owner        Employee       @relation("KickoffActionItemOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  dueDate      DateTime?
  /// The linked Kanban card. Unique (1:1). SetNull so archiving the card
  /// doesn't delete the action item; the item just loses its live status.
  kanbanCardId String?        @unique
  kanbanCard   KanbanCard?    @relation(fields: [kanbanCardId], references: [id], onDelete: SetNull)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([kickoffId])
  @@map("kickoff_action_items")
}

/// A project risk with a likelihood/impact matrix and mitigation plan.
model KickoffRisk {
  id             String            @id @default(uuid())
  kickoffId      String
  kickoff        ProjectKickoff    @relation(fields: [kickoffId], references: [id], onDelete: Cascade)
  description    String
  likelihood     KickoffRiskLevel  @default(MEDIUM)
  impact         KickoffRiskLevel  @default(MEDIUM)
  mitigationPlan String?           @db.Text
  ownerId        String?
  owner          Employee?         @relation("KickoffRiskOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  status         KickoffRiskStatus @default(OPEN)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([kickoffId])
  @@map("kickoff_risks")
}

// ── Vendor Qualification (SCM) ─────────────────────────────────────
// Vendor Master + self-assessment questionnaire (vendor fills online via a
// token link) + internal audit with weighted scoring → classification. This
// is the first real Vendor/Vendor Master; Project Kickoff's free-text
// vendorName reconciles to Vendor.companyName in a FUTURE task (keep
// companyName a plain matchable string).

enum VendorStatus {
  PENDING_QUESTIONNAIRE
  QUESTIONNAIRE_SUBMITTED
  UNDER_AUDIT
  APPROVED_PREFERRED
  APPROVED
  CONDITIONALLY_APPROVED
  NOT_APPROVED
}

enum VendorQuestionnaireStatus {
  SENT
  SUBMITTED
}

enum VendorAuditType {
  PHYSICAL
  VIRTUAL
}

model Vendor {
  id                       String                   @id @default(uuid())
  /// Plain, matchable company name — the future reconciliation target for
  /// Project Kickoff's free-text vendorName. Deliberately not normalized away.
  companyName              String
  /// Only companyName + contactEmail are required at creation — everything else
  /// below is optional and expected to arrive via the vendor's own questionnaire.
  registeredAddress        String?                  @db.Text
  factoryAddress           String?                  @db.Text
  yearEstablished          String?
  numberOfEmployees        String?
  annualTurnover           String?
  msmeUdyamCertificate     String?
  contactPersonName        String?
  contactPersonDesignation String?
  contactEmail             String
  contactPhone             String?
  website                  String?
  status                   VendorStatus             @default(PENDING_QUESTIONNAIRE)
  createdById              String
  createdBy                Employee                 @relation("VendorCreator", fields: [createdById], references: [id], onDelete: Restrict)
  questionnaires           VendorQuestionnaire[]
  audits                   VendorAudit[]
  notifications            Notification[]
  purchaseOrders           PurchaseOrder[]
  apInvoices               AccountsPayableInvoice[]
  apPayments               AccountsPayablePayment[]
  rfqInvitees              RfqInvitee[]
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt

  @@index([status])
  @@map("vendors")
}

/// One questionnaire revision. Section content is stored as opaque JSON (one
/// column per VSAQ section) — 100+ narrative fields don't each need a column;
/// only Vendor's own fields and the audit scores are individually queryable.
model VendorQuestionnaire {
  id             String                    @id @default(uuid())
  vendorId       String
  vendor         Vendor                    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  revisionNumber Int                       @default(1)
  status         VendorQuestionnaireStatus @default(SENT)
  submittedAt    DateTime?

  // One JSON blob per VSAQ section (§1–18). Null until the vendor fills it.
  businessProfile         Json?
  manufacturingCapability Json?
  equipmentDetails        Json?
  productionCapacity      Json?
  qualityManagement       Json?
  engineeringCapability   Json?
  supplyChain             Json?
  traceability            Json?
  logistics               Json?
  sustainability          Json?
  informationSecurity     Json?
  businessContinuity      Json?
  ehs                     Json?
  financialInformation    Json?
  customerSupport         Json?
  compliance              Json?
  references              Json?
  declaration             Json?

  /// Uploaded quality-certificate files (R2-backed, guarded by Vault's rules).
  /// [{ storageKey, name, sizeBytes, contentType }] — metadata only.
  qualityCertificateFiles Json?

  invites VendorQuestionnaireInvite[]
  audits  VendorAudit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vendorId])
  @@map("vendor_questionnaires")
}

/// Token-based public invite to fill a questionnaire — same shape as Vault's
/// external share link (crypto token, expiry, revoke, optional password).
model VendorQuestionnaireInvite {
  id              String              @id @default(uuid())
  questionnaireId String
  questionnaire   VendorQuestionnaire @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
  token           String              @unique
  expiresAt       DateTime
  revokedAt       DateTime?
  passwordHash    String?
  createdById     String
  createdBy       Employee            @relation("VendorInviteCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt       DateTime            @default(now())

  @@index([questionnaireId])
  @@map("vendor_questionnaire_invites")
}

/// Internal audit of a specific questionnaire revision. totalScore and
/// classification are COMPUTED on read from the 10 weighted scores (sum=100) —
/// never stored. Finalizing sets Vendor.status to the classification.
model VendorAudit {
  id              String              @id @default(uuid())
  vendorId        String
  vendor          Vendor              @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  questionnaireId String
  questionnaire   VendorQuestionnaire @relation(fields: [questionnaireId], references: [id], onDelete: Restrict)
  auditType       VendorAuditType
  auditDate       DateTime
  auditorId       String
  auditor         Employee            @relation("VendorAuditor", fields: [auditorId], references: [id], onDelete: Restrict)

  // Weighted category scores — maxes 20/10/20/10/5/10/10/5/5/5 = 100.
  manufacturingCapabilityScore Decimal @db.Decimal(5, 2)
  capacityScore                Decimal @db.Decimal(5, 2)
  qualitySystemScore           Decimal @db.Decimal(5, 2)
  engineeringScore             Decimal @db.Decimal(5, 2)
  financialStabilityScore      Decimal @db.Decimal(5, 2)
  supplyChainScore             Decimal @db.Decimal(5, 2)
  exportReadinessScore         Decimal @db.Decimal(5, 2)
  sustainabilityScore          Decimal @db.Decimal(5, 2)
  ehsScore                     Decimal @db.Decimal(5, 2)
  customerReferencesScore      Decimal @db.Decimal(5, 2)

  auditNotes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vendorId])
  @@index([questionnaireId])
  @@map("vendor_audits")
}

// ── Supplier Qualification (SCM — raw materials) ─────────────────────
// A DISTINCT module from Vendor Qualification (see vendor-vs-supplier-
// terminology.md): raw-material suppliers, their own questionnaire sections
// and 6-category weighted audit. Reuses the shared token-invite mechanism
// (src/common/utils/token-invite) and Vault's storage guardrails. A future
// task adds the hard BOM-release gate once Item Master + BillOfMaterials exist.

enum SupplierStatus {
  PENDING_QUESTIONNAIRE
  QUESTIONNAIRE_SUBMITTED
  UNDER_AUDIT
  APPROVED_PREFERRED
  APPROVED
  CONDITIONALLY_APPROVED
  NOT_APPROVED
}

enum SupplierQuestionnaireStatus {
  SENT
  SUBMITTED
}

enum SupplierAuditType {
  PHYSICAL
  VIRTUAL
}

/// How a questionnaire reached SUBMITTED. Null until submitted. Supplier-sourced
/// data is more authoritative than data entered second-hand by internal staff,
/// so the distinction is preserved for anyone reviewing a classification.
enum SupplierFilledBy {
  EXTERNAL_SUPPLIER
  INTERNAL_STAFF
}

model Supplier {
  id                       String                   @id @default(uuid())
  /// Plain, matchable company name (future Item↔Supplier reconciliation).
  companyName              String
  /// Only companyName + contactEmail are required at creation — everything else
  /// below is optional and expected to arrive via the supplier's own questionnaire.
  registeredAddress        String?                  @db.Text
  /// Factory / origin location of the raw materials.
  factoryAddress           String?                  @db.Text
  yearEstablished          String?
  numberOfEmployees        String?
  annualTurnover           String?
  msmeUdyamCertificate     String?
  contactPersonName        String?
  contactPersonDesignation String?
  contactEmail             String
  contactPhone             String?
  website                  String?
  status                   SupplierStatus           @default(PENDING_QUESTIONNAIRE)
  createdById              String
  createdBy                Employee                 @relation("SupplierCreator", fields: [createdById], references: [id], onDelete: Restrict)
  questionnaires           SupplierQuestionnaire[]
  audits                   SupplierAudit[]
  notifications            Notification[]
  itemLinks                ItemSupplier[]           @relation("SupplierItemLinks")
  purchaseOrders           PurchaseOrder[]
  apInvoices               AccountsPayableInvoice[]
  apPayments               AccountsPayablePayment[]
  rfqInvitees              RfqInvitee[]
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt

  @@index([status])
  @@map("suppliers")
}

/// One questionnaire revision. Section content is opaque JSON, one column per
/// section. `packagingAndDelivery` is optional (not required to submit).
model SupplierQuestionnaire {
  id             String                      @id @default(uuid())
  supplierId     String
  supplier       Supplier                    @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  revisionNumber Int                         @default(1)
  status         SupplierQuestionnaireStatus @default(SENT)
  submittedAt    DateTime?
  /// Which path produced the submission. Null until SUBMITTED.
  filledBy       SupplierFilledBy?

  materialRange          Json?
  materialCertifications Json?
  compliance             Json?
  qualityCertifications  Json?
  commercialTerms        Json?
  packagingAndDelivery   Json?
  logistics              Json?
  references             Json?
  declaration            Json?

  /// Uploaded certificate files (R2-backed, Vault guardrails).
  /// [{ storageKey, name, sizeBytes, contentType }] — metadata only.
  certificateFiles Json?

  invites SupplierQuestionnaireInvite[]
  audits  SupplierAudit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([supplierId])
  @@map("supplier_questionnaires")
}

/// Token-based public invite (shared mechanism: crypto token, expiry, revoke,
/// optional password).
model SupplierQuestionnaireInvite {
  id              String                @id @default(uuid())
  questionnaireId String
  questionnaire   SupplierQuestionnaire @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
  token           String                @unique
  expiresAt       DateTime
  revokedAt       DateTime?
  passwordHash    String?
  createdById     String
  createdBy       Employee              @relation("SupplierInviteCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt       DateTime              @default(now())

  @@index([questionnaireId])
  @@map("supplier_questionnaire_invites")
}

/// Internal audit of a questionnaire revision. Six weighted scores summing to
/// 100; totalScore + classification computed on read (thresholds 90/80/70).
model SupplierAudit {
  id              String                @id @default(uuid())
  supplierId      String
  supplier        Supplier              @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  questionnaireId String
  questionnaire   SupplierQuestionnaire @relation(fields: [questionnaireId], references: [id], onDelete: Restrict)
  auditType       SupplierAuditType
  auditDate       DateTime
  auditorId       String
  auditor         Employee              @relation("SupplierAuditor", fields: [auditorId], references: [id], onDelete: Restrict)

  // Weighted category scores — maxes 30/15/20/15/10/10 = 100.
  materialCertificationsQualityScore Decimal @db.Decimal(5, 2)
  complianceScore                    Decimal @db.Decimal(5, 2)
  commercialTermsScore               Decimal @db.Decimal(5, 2)
  logisticsDeliveryScore             Decimal @db.Decimal(5, 2)
  financialStabilityScore            Decimal @db.Decimal(5, 2)
  referencesScore                    Decimal @db.Decimal(5, 2)

  auditNotes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([supplierId])
  @@index([questionnaireId])
  @@map("supplier_audits")
}

// ─────────────────────────────────────────────────────────────────────────
// Bill of Materials + Item Master + Inventory (R&D / Store)
//
// R&D employees prepare revision-controlled BOMs for a Product; an R&D Head
// technically approves them. At project kickoff the released BOM is snapshotted
// and compared against store inventory to produce a stock-availability report.
// Quantities use Decimal(14,4) (finer than money's 14,2 — BOM per-unit
// quantities are often fractional); percentages use Decimal(5,2).
// ─────────────────────────────────────────────────────────────────────────

enum ItemType {
  RAW_MATERIAL
  COMPONENT
  SUBASSEMBLY
  FINISHED_GOOD
  CONSUMABLE
}

enum BomStatus {
  DRAFT
  PENDING_APPROVAL
  REJECTED
  RELEASED
  OBSOLETE
}

/// Make vs. buy classification of a BOM line.
enum BomLineSource {
  MAKE
  BUY
}

/// The kind of workflow action captured in a BomEvent (audit/history trail).
enum BomEventType {
  CREATED
  UPDATED
  SUBMITTED
  APPROVED
  REJECTED
  RELEASED
  OBSOLETED
  REVISION_CREATED
}

/// Which quantity bucket a stock adjustment targets. availableQuantity is
/// always DERIVED (onHand - reserved - blocked), never adjusted directly.
enum StockBucket {
  ON_HAND
  BLOCKED
}

/// Item Master. BOM lines and stock records reference items here rather than
/// free-text material names. Items are never hard-deleted when referenced —
/// they are marked inactive instead.
model Item {
  id                    String   @id @default(uuid())
  itemCode              String   @unique
  name                  String
  description           String?  @db.Text
  itemType              ItemType
  baseUnitOfMeasure     String
  isActive              Boolean  @default(true)
  /// Default wastage % applied to BOM lines using this item unless the line
  /// overrides it. Optional. Decimal(5,2).
  defaultWastagePercent Decimal? @db.Decimal(5, 2)
  drawingSpecReference  String?
  standardLeadTimeDays  Int?

  boms                 Bom[]                  @relation("ItemBoms")
  bomLines             BomLine[]
  products             Product[]              @relation("ProductItem")
  stockBalances        StockBalance[]
  stockAdjustments     StockAdjustment[]
  reservations         StockReservation[]
  supplierLinks        ItemSupplier[]
  purchaseOrderLines   PurchaseOrderLine[]
  grnLines             GoodsReceiptNoteLine[]
  ncrs                 NonConformanceReport[]
  materialIndents      MaterialIndent[]
  materialIssueNotes   MaterialIssueNote[]
  deliveryChallanLines DeliveryChallanLine[]
  rfqLines             RfqLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([itemType])
  @@index([isActive])
  @@map("items")
}

/// Links a raw-material/component Item to a qualified Supplier. Powers the BOM
/// release hard-gate: a BOM referencing a RAW_MATERIAL item cannot be released
/// unless that item has at least one ItemSupplier whose Supplier status is
/// APPROVED or APPROVED_PREFERRED.
model ItemSupplier {
  id                 String   @id @default(uuid())
  itemId             String
  item               Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  supplierId         String
  supplier           Supplier @relation("SupplierItemLinks", fields: [supplierId], references: [id], onDelete: Cascade)
  /// Optional supplier's own part number for this item.
  supplierPartNumber String?
  createdById        String
  createdBy          Employee @relation("ItemSupplierLinkedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt          DateTime @default(now())

  @@unique([itemId, supplierId])
  @@index([itemId])
  @@index([supplierId])
  @@map("item_suppliers")
}

/// One BOM revision (header) for a Product. Only one RELEASED revision is
/// normally active at a time — enforced in the service transaction when a new
/// revision is released (the prior RELEASED one becomes OBSOLETE). Unique
/// (productId, revisionNumber) prevents duplicate revision numbers per product.
model Bom {
  id             String    @id @default(uuid())
  /// Keyed on the Item Master (NOT Product) so a SUBASSEMBLY/COMPONENT item that
  /// is never sold as a Product still has somewhere to attach its own BOM —
  /// this is what enables genuine multi-level explosion.
  itemId         String
  item           Item      @relation("ItemBoms", fields: [itemId], references: [id], onDelete: Restrict)
  revisionNumber Int
  status         BomStatus @default(DRAFT)
  effectiveDate  DateTime?
  revisionNotes  String?   @db.Text

  createdById      String
  createdBy        Employee  @relation("BomCreator", fields: [createdById], references: [id], onDelete: Restrict)
  submittedById    String?
  submittedBy      Employee? @relation("BomSubmitter", fields: [submittedById], references: [id], onDelete: SetNull)
  submittedAt      DateTime?
  approvedById     String?
  approvedBy       Employee? @relation("BomApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt       DateTime?
  rejectedById     String?
  rejectedBy       Employee? @relation("BomRejecter", fields: [rejectedById], references: [id], onDelete: SetNull)
  rejectedAt       DateTime?
  rejectionComment String?   @db.Text

  /// Signature snapshot captured at approval (mirrors OrderConfirmationSheet /
  /// Bid): the approver's typed-signature text + font at the moment of approval.
  approverSignatureTextSnapshot String?
  approverSignatureFontSnapshot SignatureFont?

  lines             BomLine[]
  events            BomEvent[]
  notifications     Notification[]
  kickoffSelections KickoffBomSelection[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([itemId, revisionNumber])
  @@index([itemId])
  @@index([status])
  @@map("boms")
}

/// A single material line on a BOM revision.
model BomLine {
  id                   String        @id @default(uuid())
  bomId                String
  bom                  Bom           @relation(fields: [bomId], references: [id], onDelete: Cascade)
  itemId               String
  item                 Item          @relation(fields: [itemId], references: [id], onDelete: Restrict)
  /// Quantity of this item per ONE finished product unit. Decimal(14,4).
  quantityPerUnit      Decimal       @db.Decimal(14, 4)
  unitOfMeasure        String
  wastagePercent       Decimal       @default(0) @db.Decimal(5, 2)
  makeBuy              BomLineSource @default(BUY)
  notes                String?       @db.Text
  drawingSpecReference String?
  sequence             Int           @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bomId])
  @@index([itemId])
  @@map("bom_lines")
}

/// Immutable workflow-event / approval-history trail for a BOM (in addition to
/// the global audit log). Records who did what and any comment.
model BomEvent {
  id        String       @id @default(uuid())
  bomId     String
  bom       Bom          @relation(fields: [bomId], references: [id], onDelete: Cascade)
  type      BomEventType
  actorId   String?
  actor     Employee?    @relation("BomEventActor", fields: [actorId], references: [id], onDelete: SetNull)
  comment   String?      @db.Text
  createdAt DateTime     @default(now())

  @@index([bomId, createdAt])
  @@map("bom_events")
}

/// A physical store / warehouse location that holds stock.
model StoreLocation {
  id       String  @id @default(uuid())
  code     String  @unique
  name     String
  isActive Boolean @default(true)

  stockBalances      StockBalance[]
  stockAdjustments   StockAdjustment[]
  reservations       StockReservation[]
  grnLines           GoodsReceiptNoteLine[]
  materialIssueNotes MaterialIssueNote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("store_locations")
}

/// On-hand / reserved / blocked balance for one item at one location.
/// availableQuantity is DERIVED on read (onHand - reserved - blocked) and is
/// never stored as an independently editable value.
model StockBalance {
  id              String        @id @default(uuid())
  itemId          String
  item            Item          @relation(fields: [itemId], references: [id], onDelete: Restrict)
  storeLocationId String
  storeLocation   StoreLocation @relation(fields: [storeLocationId], references: [id], onDelete: Restrict)

  onHandQuantity   Decimal @default(0) @db.Decimal(14, 4)
  reservedQuantity Decimal @default(0) @db.Decimal(14, 4)
  blockedQuantity  Decimal @default(0) @db.Decimal(14, 4)

  /// Optional inbound-supply visibility for the EXPECTED_BEFORE_REQUIRED_DATE
  /// availability status.
  expectedReceiptQuantity Decimal?  @db.Decimal(14, 4)
  expectedReceiptDate     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([itemId, storeLocationId])
  @@index([itemId])
  @@map("stock_balances")
}

/// Append-only history of every stock movement (actor, reason, delta, bucket).
model StockAdjustment {
  id              String        @id @default(uuid())
  itemId          String
  item            Item          @relation(fields: [itemId], references: [id], onDelete: Restrict)
  storeLocationId String
  storeLocation   StoreLocation @relation(fields: [storeLocationId], references: [id], onDelete: Restrict)
  bucket          StockBucket   @default(ON_HAND)
  /// Signed change applied to the bucket (positive = increase). Decimal(14,4).
  quantityChange  Decimal       @db.Decimal(14, 4)
  reason          String
  actorId         String?
  actor           Employee?     @relation("StockAdjustmentActor", fields: [actorId], references: [id], onDelete: SetNull)
  createdAt       DateTime      @default(now())

  @@index([itemId, storeLocationId])
  @@index([createdAt])
  @@map("stock_adjustments")
}

/// A material reservation held against a specific project kickoff. Reservations
/// increment StockBalance.reservedQuantity in the same transaction. Cancelling
/// releases the quantity. Re-running the kickoff report treats reservations
/// belonging to the SAME kickoff as already-earmarked (not a competing demand),
/// so it never double-counts them.
model StockReservation {
  id              String         @id @default(uuid())
  kickoffId       String
  kickoff         ProjectKickoff @relation("KickoffReservations", fields: [kickoffId], references: [id], onDelete: Cascade)
  itemId          String
  item            Item           @relation(fields: [itemId], references: [id], onDelete: Restrict)
  storeLocationId String
  storeLocation   StoreLocation  @relation(fields: [storeLocationId], references: [id], onDelete: Restrict)
  quantity        Decimal        @db.Decimal(14, 4)
  isActive        Boolean        @default(true)

  createdById   String
  createdBy     Employee  @relation("ReservationCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt     DateTime  @default(now())
  cancelledById String?
  cancelledBy   Employee? @relation("ReservationCanceller", fields: [cancelledById], references: [id], onDelete: SetNull)
  cancelledAt   DateTime?

  @@index([kickoffId])
  @@index([itemId, storeLocationId])
  @@map("stock_reservations")
}

// ── Kickoff stock-availability snapshot ──────────────────────────────────
// The report is snapshotted the first time it is generated so later BOM
// revisions never retroactively change a historical kickoff report.

/// One stock-availability report per kickoff (created on first generate).
model KickoffStockReport {
  id                String         @id @default(uuid())
  kickoffId         String         @unique
  kickoff           ProjectKickoff @relation(fields: [kickoffId], references: [id], onDelete: Cascade)
  generatedAt       DateTime       @default(now())
  /// Chosen decimal precision for requirement math, recorded for provenance.
  quantityPrecision Int            @default(4)

  bomSelections KickoffBomSelection[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("kickoff_stock_reports")
}

/// Which released BOM revision was selected for a given ordered product at
/// snapshot time. Stores the revision id + number for provenance; the copied
/// lines below preserve historical accuracy independent of the live BOM.
model KickoffBomSelection {
  id                String             @id @default(uuid())
  reportId          String
  report            KickoffStockReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  /// The order line item this selection was generated for.
  orderLineItemId   String
  productId         String
  productName       String
  productSku        String
  orderedQuantity   Decimal            @db.Decimal(14, 4)
  bomId             String
  bom               Bom                @relation(fields: [bomId], references: [id], onDelete: Restrict)
  bomRevisionNumber Int

  lines KickoffBomSnapshotLine[]

  createdAt DateTime @default(now())

  @@index([reportId])
  @@map("kickoff_bom_selections")
}

/// A copied BOM line captured at snapshot time. Enough data is copied
/// (item identity, quantities, wastage, UoM) that the report is reproducible
/// even after the source BOM is obsoleted or edited into a new revision.
model KickoffBomSnapshotLine {
  id              String              @id @default(uuid())
  selectionId     String
  selection       KickoffBomSelection @relation(fields: [selectionId], references: [id], onDelete: Cascade)
  itemId          String
  itemCode        String
  itemName        String
  unitOfMeasure   String
  quantityPerUnit Decimal             @db.Decimal(14, 4)
  wastagePercent  Decimal             @db.Decimal(5, 2)

  createdAt DateTime @default(now())

  @@index([selectionId])
  @@map("kickoff_bom_snapshot_lines")
}

// ── Finance & Accounts foundation ───────────────────────────────────────

enum FiscalYearStatus {
  OPEN
  SOFT_CLOSED
  CLOSED
}

enum AccountingPeriodStatus {
  OPEN
  SOFT_CLOSED
  CLOSED
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  COST_OF_GOODS_SOLD
  EXPENSE
  OTHER_INCOME
  OTHER_EXPENSE
}

enum CashFlowCategory {
  OPERATING
  INVESTING
  FINANCING
  NON_CASH
}

enum NormalBalance {
  DEBIT
  CREDIT
}

enum JournalStatus {
  DRAFT
  PENDING_APPROVAL
  POSTED
  REJECTED
  REVERSED
}

/// India financial year (1 April through 31 March). Periods are generated as
/// twelve calendar months and lock posting independently.
model FiscalYear {
  id          String             @id @default(uuid())
  name        String             @unique
  startsOn    DateTime
  endsOn      DateTime
  status      FiscalYearStatus   @default(OPEN)
  createdById String
  createdBy   Employee           @relation("FiscalYearCreator", fields: [createdById], references: [id], onDelete: Restrict)
  periods     AccountingPeriod[]
  budgets     FinanceBudget[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([startsOn, endsOn])
  @@map("fiscal_years")
}

model AccountingPeriod {
  id                  String                     @id @default(uuid())
  fiscalYearId        String
  fiscalYear          FiscalYear                 @relation(fields: [fiscalYearId], references: [id], onDelete: Restrict)
  periodNumber        Int
  name                String
  startsOn            DateTime
  endsOn              DateTime
  status              AccountingPeriodStatus     @default(OPEN)
  journals            JournalEntry[]
  periodClose         PeriodClose?
  budgetLines         FinanceBudgetLine[]
  depreciationEntries AssetDepreciationEntry[]
  scheduleExecutions  FinanceScheduleExecution[]
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt

  @@unique([fiscalYearId, periodNumber])
  @@index([startsOn, endsOn])
  @@map("accounting_periods")
}

model LedgerAccount {
  id                                String               @id @default(uuid())
  code                              String               @unique
  name                              String
  accountType                       AccountType
  normalBalance                     NormalBalance
  description                       String?              @db.Text
  parentId                          String?
  parent                            LedgerAccount?       @relation("AccountHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children                          LedgerAccount[]      @relation("AccountHierarchy")
  isControlAccount                  Boolean              @default(false)
  isActive                          Boolean              @default(true)
  cashFlowCategory                  CashFlowCategory?
  createdById                       String
  createdBy                         Employee             @relation("LedgerAccountCreator", fields: [createdById], references: [id], onDelete: Restrict)
  journalLines                      JournalLine[]
  bankAccounts                      FinanceBankAccount[]
  budgetLines                       FinanceBudgetLine[]
  fixedAssetCosts                   FixedAsset[]         @relation("FixedAssetCostAccount")
  fixedAssetAccumulatedDepreciation FixedAsset[]         @relation("FixedAssetAccumulatedDepAccount")
  fixedAssetDepreciationExpenses    FixedAsset[]         @relation("FixedAssetDepExpenseAccount")
  fixedAssetAcquisitionCredits      FixedAsset[]         @relation("FixedAssetAcquisitionCreditAccount")
  scheduleDebits                    FinanceSchedule[]    @relation("FinanceScheduleDebitAccount")
  scheduleCredits                   FinanceSchedule[]    @relation("FinanceScheduleCreditAccount")
  contraFromVouchers                ContraVoucher[]      @relation("ContraFromAccount")
  contraToVouchers                  ContraVoucher[]      @relation("ContraToAccount")
  createdAt                         DateTime             @default(now())
  updatedAt                         DateTime             @updatedAt

  @@index([accountType, isActive])
  @@index([parentId])
  @@map("ledger_accounts")
}

enum ManagementPackStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PUBLISHED
}

enum YearEndRolloverStatus {
  DRAFT
  PENDING_APPROVAL
  COMPLETED
}

model FinanceAuditorGrant {
  id          String    @id @default(uuid())
  employeeId  String    @unique
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  grantedById String
  grantedAt   DateTime  @default(now())
  revokedById String?
  revokedAt   DateTime?

  @@index([isActive, expiresAt])
  @@map("finance_auditor_grants")
}

model ManagementReportPack {
  id            String               @id @default(uuid())
  packNumber    String               @unique
  title         String
  periodFrom    DateTime
  periodTo      DateTime
  status        ManagementPackStatus @default(DRAFT)
  snapshot      Json
  createdById   String
  submittedById String?
  submittedAt   DateTime?
  approvedById  String?
  approvedAt    DateTime?
  publishedAt   DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([status, periodTo])
  @@map("management_report_packs")
}

model YearEndRollover {
  id                        String                  @id @default(uuid())
  sourceFiscalYearId        String                  @unique
  targetFiscalYearId        String
  status                    YearEndRolloverStatus   @default(DRAFT)
  retainedEarningsAccountId String
  snapshot                  Json
  createdById               String
  submittedById             String?
  submittedAt               DateTime?
  approvedById              String?
  approvedAt                DateTime?
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt
  openingBalances           AccountOpeningBalance[]

  @@index([status])
  @@map("year_end_rollovers")
}

model AccountOpeningBalance {
  id           String          @id @default(uuid())
  rolloverId   String
  rollover     YearEndRollover @relation(fields: [rolloverId], references: [id], onDelete: Cascade)
  fiscalYearId String
  accountId    String
  debit        Decimal         @default(0) @db.Decimal(18, 2)
  credit       Decimal         @default(0) @db.Decimal(18, 2)
  createdAt    DateTime        @default(now())

  @@unique([fiscalYearId, accountId])
  @@index([rolloverId])
  @@map("account_opening_balances")
}

model CostCenter {
  id               String              @id @default(uuid())
  code             String              @unique
  name             String
  description      String?             @db.Text
  isActive         Boolean             @default(true)
  createdById      String
  createdBy        Employee            @relation("CostCenterCreator", fields: [createdById], references: [id], onDelete: Restrict)
  journalLines     JournalLine[]
  budgetLines      FinanceBudgetLine[]
  financeSchedules FinanceSchedule[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@map("cost_centers")
}

/// Supported document currency. INR is the functional/base currency.
model Currency {
  code          String         @id @db.VarChar(3)
  name          String
  symbol        String
  decimalPlaces Int            @default(2)
  isBase        Boolean        @default(false)
  isActive      Boolean        @default(true)
  exchangeRates ExchangeRate[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("currencies")
}

/// Manually maintained rate: one unit of foreign currency expressed in INR.
model ExchangeRate {
  id           String   @id @default(uuid())
  currencyCode String   @db.VarChar(3)
  currency     Currency @relation(fields: [currencyCode], references: [code], onDelete: Restrict)
  effectiveOn  DateTime
  rateToInr    Decimal  @db.Decimal(18, 6)
  source       String
  createdById  String
  createdBy    Employee @relation("ExchangeRateCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt    DateTime @default(now())

  @@unique([currencyCode, effectiveOn])
  @@index([effectiveOn])
  @@map("exchange_rates")
}

model FinanceSequence {
  entity    String
  year      Int
  lastValue Int      @default(0)
  updatedAt DateTime @updatedAt

  @@id([entity, year])
  @@map("finance_sequences")
}

/// Manual journal header. Only POSTED entries contribute to financial reports.
/// Posted entries are immutable; correction is by an explicit reversal.
model JournalEntry {
  id                String                    @id @default(uuid())
  journalNumber     String                    @unique
  entryDate         DateTime
  periodId          String
  period            AccountingPeriod          @relation(fields: [periodId], references: [id], onDelete: Restrict)
  description       String                    @db.Text
  reference         String?
  status            JournalStatus             @default(DRAFT)
  createdById       String
  createdBy         Employee                  @relation("JournalCreator", fields: [createdById], references: [id], onDelete: Restrict)
  submittedById     String?
  submittedBy       Employee?                 @relation("JournalSubmitter", fields: [submittedById], references: [id], onDelete: SetNull)
  submittedAt       DateTime?
  approvedById      String?
  approvedBy        Employee?                 @relation("JournalApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt        DateTime?
  rejectedById      String?
  rejectedBy        Employee?                 @relation("JournalRejecter", fields: [rejectedById], references: [id], onDelete: SetNull)
  rejectedAt        DateTime?
  rejectionComment  String?                   @db.Text
  reversedById      String?
  reversedBy        Employee?                 @relation("JournalReverser", fields: [reversedById], references: [id], onDelete: SetNull)
  reversedAt        DateTime?
  reversalOfId      String?                   @unique
  reversalOf        JournalEntry?             @relation("JournalReversal", fields: [reversalOfId], references: [id], onDelete: Restrict)
  reversalEntry     JournalEntry?             @relation("JournalReversal")
  lines             JournalLine[]
  salesInvoice      SalesInvoice?             @relation("SalesInvoiceJournal")
  customerReceipt   CustomerReceipt?          @relation("CustomerReceiptJournal")
  apInvoice         AccountsPayableInvoice?   @relation("ApInvoiceJournal")
  apPayment         AccountsPayablePayment?   @relation("ApPaymentJournal")
  financeNote       FinanceAdjustmentNote?    @relation("FinanceNoteJournal")
  contraVoucher     ContraVoucher?            @relation("ContraVoucherJournal")
  bankMatches       BankTransactionMatch[]
  depreciationEntry AssetDepreciationEntry?
  scheduleExecution FinanceScheduleExecution?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  @@index([entryDate, status])
  @@index([periodId, status])
  @@map("journal_entries")
}

model JournalLine {
  id               String        @id @default(uuid())
  journalId        String
  journal          JournalEntry  @relation(fields: [journalId], references: [id], onDelete: Cascade)
  sequence         Int
  accountId        String
  account          LedgerAccount @relation(fields: [accountId], references: [id], onDelete: Restrict)
  description      String?
  debit            Decimal       @default(0) @db.Decimal(18, 2)
  credit           Decimal       @default(0) @db.Decimal(18, 2)
  costCenterId     String?
