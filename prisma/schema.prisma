// ─────────────────────────────────────────────────────────────────────────
// Purchasing (Stores Phase 1) — Purchase Orders. GRN/QC/material-issue are
// later phases; this is the self-contained foundation.
// ─────────────────────────────────────────────────────────────────────────

/// PO lifecycle. Phase 1 only performs the MANUAL transitions
/// DRAFT → ISSUED → CANCELLED. PARTIALLY_RECEIVED / FULLY_RECEIVED are reserved
/// here so Phase 2 can plug in receipt-based derivation (computed from GRN data)
/// without a migration — the enum values already exist.
enum PurchaseOrderStatus {
  DRAFT
  ISSUED
  PARTIALLY_RECEIVED
  FULLY_RECEIVED
  CANCELLED
}

/// A purchase order raised on exactly ONE trading partner — either a Supplier
/// (raw-material qualification track) or a Vendor (general qualification track).
/// Exactly-one-of is enforced in the service AND by a DB CHECK constraint added
/// in the migration. There is deliberately NO stored received-quantity anywhere;
/// receipt progress is computed from GRN data in a later phase.
model PurchaseOrder {
  id       String              @id @default(uuid())
  /// PO-YYYY-#### via the shared year-prefixed sequence (SalesNumberingService),
  /// resetting annually like Bids/Orders.
  poNumber String              @unique
  status   PurchaseOrderStatus @default(DRAFT)

  /// Exactly one of supplierId / vendorId is set (CHECK constraint in migration).
  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  vendorId   String?
  vendor     Vendor?   @relation(fields: [vendorId], references: [id], onDelete: Restrict)

  orderDate            DateTime  @default(now())
  expectedDeliveryDate DateTime?
  notes                String?   @db.Text

  createdById String
  createdBy   Employee  @relation("PurchaseOrderCreator", fields: [createdById], references: [id], onDelete: Restrict)
  /// Set when the PO moves DRAFT → ISSUED.
  issuedAt    DateTime?
  /// Set when the PO is CANCELLED.
  cancelledAt DateTime?

  lines             PurchaseOrderLine[]
  goodsReceiptNotes GoodsReceiptNote[]
  apInvoices        AccountsPayableInvoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([supplierId])
  @@index([vendorId])
  @@map("purchase_orders")
}

/// One ordered line. lineTotal is stored (orderedQuantity × unitPrice, computed
/// at write) mirroring OrderLineItem. unitOfMeasure is snapshotted from the Item
/// at creation. NO receivedQuantity — that is computed from GRN data later.
model PurchaseOrderLine {
  id              String        @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  itemId          String
  item            Item          @relation(fields: [itemId], references: [id], onDelete: Restrict)
  orderedQuantity Decimal       @db.Decimal(14, 4)
  unitPrice       Decimal       @db.Decimal(14, 2)
  /// UoM snapshot at PO time (Item.baseUnitOfMeasure can change later).
  unitOfMeasure   String
  lineTotal       Decimal       @db.Decimal(14, 2)
  notes           String?       @db.Text
  sequence        Int           @default(0)

  grnLines       GoodsReceiptNoteLine[]
  apInvoiceLines AccountsPayableInvoiceLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([purchaseOrderId])
  @@index([itemId])
  @@map("purchase_order_lines")
}

