/**
 * Contra voucher — a bank/cash transfer that involves neither a customer nor
 * a vendor (bank-to-cash, cash-to-bank, inter-bank). The one genuinely new
 * entity in the Tally-style presentation layer; everything else re-presents
 * existing entities. Posts through the shared `postJournalTx` helper like
 * every other subledger document — no parallel posting path. Both ledgers are
 * restricted (at the service layer, using the account-group taxonomy seeded
 * in prisma/seed.ts) to bank/cash-eligible accounts; a transfer between two
 * non-bank/cash ledgers belongs in a Journal Voucher instead.
 */
model ContraVoucher {
  id                  String              @id @default(uuid())
  voucherNumber       String              @unique
  voucherDate         DateTime
  fromLedgerAccountId String
  fromLedgerAccount   LedgerAccount       @relation("ContraFromAccount", fields: [fromLedgerAccountId], references: [id], onDelete: Restrict)
  toLedgerAccountId   String
  toLedgerAccount     LedgerAccount       @relation("ContraToAccount", fields: [toLedgerAccountId], references: [id], onDelete: Restrict)
  amount              Decimal             @db.Decimal(18, 2)
  narration           String?             @db.Text
  status              ContraVoucherStatus @default(DRAFT)
  createdById         String
  createdBy           Employee            @relation("ContraVoucherCreator", fields: [createdById], references: [id], onDelete: Restrict)
  submittedById       String?
  submittedBy         Employee?           @relation("ContraVoucherSubmitter", fields: [submittedById], references: [id], onDelete: SetNull)
  submittedAt         DateTime?
  approvedById        String?
  approvedBy          Employee?           @relation("ContraVoucherApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt          DateTime?
  rejectionComment    String?             @db.Text
  journalEntryId      String?             @unique
  journalEntry        JournalEntry?       @relation("ContraVoucherJournal", fields: [journalEntryId], references: [id], onDelete: Restrict)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([voucherDate])
