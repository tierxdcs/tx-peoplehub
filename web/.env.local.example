# NestJS API origin (this project's backend, run separately).
NEXT_PUBLIC_API_URL=http://localhost:3000

# Gates the employee-facing "My Payslips" screen. Leave unset/false until
# the Payroll module's StatutoryConfig rates have CA/compliance sign-off
# (see the Payroll module spec §7) — until then, payslips are generated
# from placeholder rates and must not be presented to employees as real.
NEXT_PUBLIC_PAYSLIPS_ENABLED=false
